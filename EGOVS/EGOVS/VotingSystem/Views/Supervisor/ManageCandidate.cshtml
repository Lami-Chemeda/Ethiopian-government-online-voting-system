@{
    ViewData["Title"] = "Manage Candidates";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ethiopian Voting System</title>
    <style>
        /* CSS Styles - NO CHANGES */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
             background: linear-gradient(135deg, #1d3557 0%, #457b9d 25%, #a8dadc 50%, #f1faee 75%, #ffffff 100%);
            min-height: 100vh;
            padding: 20px;
            position: relative;
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: #1e3c72;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
            transition: all 0.3s ease;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn:hover {
            background: linear-gradient(45deg, #FFA500, #FF8C00);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            overflow: hidden;
            margin-top: 60px;
        }

        .header {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .content {
            padding: 40px;
        }

        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .action-btn {
            background: linear-gradient(45deg, #1e3c72, #2a5298);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            background: linear-gradient(45deg, #2a5298, #1e3c72);
            transform: translateY(-2px);
        }

        .form-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            margin-top: 20px;
            display: none;
        }

        .form-group {
            margin-bottom: 15px;
            position: relative;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #1e3c72;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }

        .form-group textarea {
            height: 100px;
            resize: vertical;
        }

        .submit-btn {
            background: linear-gradient(45deg, #1e3c72, #2a5298);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            background: linear-gradient(45deg, #2a5298, #1e3c72);
            transform: translateY(-2px);
        }

        .candidates-list {
            margin-top: 30px;
        }

        .candidate-item {
            background: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
            border-left: 4px solid #1e3c72;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .candidate-photo {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #1e3c72;
            margin-right: 15px;
        }

        .candidate-logo {
            width: 60px;
            height: 60px;
            object-fit: contain;
            margin-right: 15px;
            border: 2px solid #1e3c72;
            border-radius: 8px;
            background: white;
            padding: 5px;
        }

        .candidate-symbol {
            width: 50px;
            height: 50px;
            object-fit: contain;
            margin-right: 15px;
            border: 2px solid #1e3c72;
            border-radius: 8px;
            background: white;
            padding: 5px;
            font-size: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .candidate-info {
            flex: 1;
            display: flex;
            align-items: center;
        }

        .candidate-details {
            flex: 1;
        }

        .candidate-actions button {
            margin-left: 10px;
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .edit-btn {
            background: #FFA500;
            color: white;
        }

        .delete-btn {
            background: #DC143C;
            color: white;
        }

        .status-btn {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #808080;
        }

        .message {
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
            text-align: center;
            display: none;
        }

        .success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .status-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }

        .status-active {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #DC143C;
            color: white;
        }

        .password-toggle {
            position: relative;
        }

        .password-toggle input {
            padding-right: 40px;
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
        }

        .upload-section {
            margin: 15px 0;
            padding: 15px;
            border: 2px dashed #1d3557;
            border-radius: 8px;
            background: #f8f9fa;
            text-align: center;
        }

        .upload-btn {
            background: #1d3557;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin: 5px;
        }

        .upload-btn:hover {
            background: #457b9d;
        }

        .file-input {
            display: none;
        }

        .photo-preview-container {
            text-align: center;
            margin-top: 10px;
        }

        .photo-preview {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #1d3557;
            margin: 0 auto;
            display: none;
        }

        .logo-preview {
            width: 120px;
            height: 120px;
            object-fit: contain;
            border: 2px solid #1d3557;
            border-radius: 8px;
            background: white;
            padding: 10px;
            margin: 0 auto;
            display: none;
        }

        .symbol-preview {
            width: 100px;
            height: 100px;
            object-fit: contain;
            border: 2px solid #1d3557;
            border-radius: 8px;
            background: white;
            padding: 10px;
            margin: 0 auto;
            display: none;
        }

        .upload-instructions {
            background: #e7f3ff;
            border: 1px solid #b3d9ff;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 10px;
            text-align: center;
        }

        .vote-count {
            background: #e7f3ff;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            color: #1e3c72;
            margin-left: 10px;
        }

        .required::after {
            content: " *";
            color: red;
        }

        .readonly-field {
            background-color: #f8f9fa !important;
            cursor: not-allowed !important;
            color: #6c757d !important;
        }

        .extracted-field {
            background-color: #f8f9fa !important;
            border: 2px solid #28a745 !important;
            color: #155724 !important;
            font-weight: bold !important;
            cursor: not-allowed !important;
        }

        .field-status {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: inline-block;
        }

        .field-status.auto-filled {
            background: #d4edda;
            color: #155724;
        }

        .error-field {
            border: 2px solid #dc3545 !important;
            background-color: #f8d7da !important;
        }

        .field-error {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: none;
        }

        .field-error.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .field-error.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .validation-hint {
            font-size: 11px;
            color: #6c757d;
            margin-top: 2px;
            display: block;
        }

        .id-preview-container {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .id-preview {
            flex: 1;
            text-align: center;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: white;
        }

        .id-preview.active {
            border-color: #28a745;
            background: #f8fff9;
        }

        .upload-quality-tips {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            padding: 10px;
            border-radius: 6px;
            margin-top: 10px;
            font-size: 14px;
            text-align: left;
        }

        .upload-quality-tips h6 {
            margin: 0 0 8px 0;
            color: #856404;
        }

        .upload-quality-tips ul {
            margin: 0;
            padding-left: 20px;
        }

        .upload-quality-tips li {
            margin-bottom: 5px;
        }

        .action-buttons-ocr {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .extract-btn {
            background: #28a745;
        }

        .extract-btn:hover {
            background: #218838;
        }

        .demo-btn {
            background: #6c757d;
        }

        .demo-btn:hover {
            background: #5a6268;
        }

        .ocr-processing {
            background: linear-gradient(135deg, #e3f2fd, #bbdefb);
            border: 2px solid #1d3557;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            text-align: center;
            display: none;
        }

        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 0.2em solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border-animation .75s linear infinite;
        }

        @@keyframes spinner-border-animation {
            to { 
                transform: rotate(360deg); 
            }
        }

        .image-preview-row {
            display: flex;
            gap: 20px;
            margin: 15px 0;
        }

        .image-preview-col {
            flex: 1;
            text-align: center;
        }

        .preview-title {
            font-weight: bold;
            margin-bottom: 10px;
            color: #1e3c72;
        }

        .symbol-section {
            background: #f0f8ff;
            padding: 15px;
            border-radius: 8px;
            border: 2px solid #1d3557;
            margin: 15px 0;
        }

        .symbol-options {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }

        .symbol-option {
            border: 2px solid #ddd;
            border-radius: 8px;
            padding: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .symbol-option:hover {
            border-color: #1d3557;
            background: #e7f3ff;
        }

        .symbol-option.selected {
            border-color: #1d3557;
            background: #1d3557;
            color: white;
        }

        .symbol-icon {
            font-size: 24px;
            margin-bottom: 5px;
        }

        .color-picker {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .color-preview {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: 2px solid #ddd;
        }
    </style>
</head>
<body>
    <a class="back-btn" href="/Supervisor/Dashboard">
        ← Back to Dashboard
    </a>
    
    <div class="container">
        <div class="header">
            <h1>🗳️ Manage Candidates</h1>
            <p>Create, Update, and Delete Election Candidates</p>
        </div>

        <div class="content">
            <div id="message" class="message"></div>

            <!-- Candidates Section -->
            <div id="candidates">
                <div class="action-buttons">
                    <button class="action-btn" onclick="showForm('createCandidateForm')">➕ Create Candidate</button>
                    <button class="action-btn" onclick="showForm('updateCandidateForm')">✏️ Update Candidate</button>
                    <button class="action-btn" onclick="showForm('deleteCandidateForm')">🗑️ Delete Candidate</button>
                </div>

                <!-- Create Candidate Form -->
                <div id="createCandidateForm" class="form-section">
                    <h3>Create New Candidate</h3>
                    <form id="createCandidateFormElement" enctype="multipart/form-data">
                        <!-- National ID Field -->
                        <div class="form-group">
                            <label for="candidateNationalId" class="required">National ID (FAN)</label>
                            <input type="text" id="candidateNationalId" name="NationalId" placeholder="Enter National ID" required />
                            <div class="field-status auto-filled" id="candidateNationalIdStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <!-- Enhanced ID Upload Section -->
                        <div class="upload-section">
                            <div class="upload-instructions">
                                <strong>📁 Upload National ID Card Photos</strong><br>
                                Upload clear photos of front and back sides of candidate's ID card
                            </div>

                            <div class="upload-quality-tips">
                                <h6>📝 For Best OCR Results:</h6>
                                <ul>
                                    <li>Use high-quality scanned images or photos</li>
                                    <li>Ensure good lighting without shadows or glare</li>
                                    <li>Place ID on flat surface</li>
                                    <li>Capture entire ID card clearly</li>
                                    <li>File formats: JPG, PNG, BMP (Max 5MB)</li>
                                </ul>
                            </div>
                            
                            <div class="id-preview-container">
                                <div class="id-preview" id="candidateFrontPreviewContainer">
                                    <div><strong>Front Side</strong></div>
                                    <div id="candidateFrontPreviewText">No file selected</div>
                                    <div id="candidateFrontPreviewImage"></div>
                                    <input type="file" id="candidateFrontIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('candidateFrontIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Front Image
                                    </button>
                                </div>
                                
                                <div class="id-preview" id="candidateBackPreviewContainer">
                                    <div><strong>Back Side</strong></div>
                                    <div id="candidateBackPreviewText">No file selected</div>
                                    <div id="candidateBackPreviewImage"></div>
                                    <input type="file" id="candidateBackIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('candidateBackIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Back Image
                                    </button>
                                </div>
                            </div>

                            <div class="action-buttons-ocr">
                                <button type="button" class="upload-btn extract-btn" id="candidateExtractInfoBtn">
                                    🔍 Extract ID Information
                                </button>
                                <button type="button" class="upload-btn demo-btn" id="candidateAutoFillBtn">
                                    📝 Auto-fill Form
                                </button>
                            </div>

                            <div id="candidateOcrProcessing" class="ocr-processing">
                                <!-- Processing message will be inserted here -->
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="candidateFirstName" class="required">First Name</label>
                            <input type="text" id="candidateFirstName" name="FirstName" placeholder="Enter first name" required />
                            <div class="field-status auto-filled" id="candidateFirstNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="candidateMiddleName" class="required">Middle Name</label>
                            <input type="text" id="candidateMiddleName" name="MiddleName" placeholder="Enter middle name" required />
                            <div class="field-status auto-filled" id="candidateMiddleNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="candidateLastName" class="required">Last Name</label>
                            <input type="text" id="candidateLastName" name="LastName" placeholder="Enter last name" required />
                            <div class="field-status auto-filled" id="candidateLastNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="candidatePhoneNumber" class="required">Phone Number</label>
                            <input type="tel" id="candidatePhoneNumber" name="PhoneNumber" placeholder="Enter phone number" required />
                            <div class="field-status auto-filled" id="candidatePhoneNumberStatus" style="display: none;">Auto-filled from ID</div>
                            <!-- ADDED: Phone validation hint -->
                            <span class="validation-hint">Format: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)</span>
                            <div class="field-error" id="candidatePhoneNumberError"></div>
                        </div>

                        <div class="form-group">
                            <label for="candidateParty" class="required">Political Party</label>
                            <input type="text" id="candidateParty" name="Party" placeholder="Enter political party" required />
                            <!-- ADDED: Party field validation hint -->
                            <span class="validation-hint">Only letters, spaces, hyphens, and apostrophes allowed (minimum 2 characters)</span>
                            <!-- ADDED: Party field error container -->
                            <div class="field-error" id="candidatePartyError"></div>
                        </div>

                        <div class="form-group">
                            <label for="candidateBio">Biography</label>
                            <textarea id="candidateBio" name="Bio" placeholder="Enter candidate biography (optional)"></textarea>
                        </div>

                        <!-- NEW: Symbol and Party Color Section -->
                        <div class="symbol-section">
                            <h4>🎯 Election Symbol & Party Color</h4>
                            
                            <div class="form-group">
                                <label for="candidateSymbolName" class="required">Symbol Name</label>
                                <select id="candidateSymbolName" name="SymbolName" required>
                                    <option value="">Select a Symbol</option>
                                    <option value="Lion" selected>Lion</option>
                                    <option value="Eagle">Eagle</option>
                                    <option value="Star">Star</option>
                                    <option value="Sun">Sun</option>
                                    <option value="Tree">Tree</option>
                                    <option value="Dove">Dove</option>
                                    <option value="Book">Book</option>
                                    <option value="Scale">Scale</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="candidateSymbolUnicode" class="required">Symbol Unicode</label>
                                <select id="candidateSymbolUnicode" name="SymbolUnicode" required>
                                    <option value="">Select Symbol Icon</option>
                                    <option value="🦁" selected>🦁 Lion</option>
                                    <option value="🦅">🦅 Eagle</option>
                                    <option value="⭐">⭐ Star</option>
                                    <option value="☀️">☀️ Sun</option>
                                    <option value="🌳">🌳 Tree</option>
                                    <option value="🕊️">🕊️ Dove</option>
                                    <option value="📚">📚 Book</option>
                                    <option value="⚖️">⚖️ Scale</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="candidatePartyColor" class="required">Party Color</label>
                                <div class="color-picker">
                                    <input type="color" id="candidatePartyColor" name="PartyColor" value="#1d3557" required>
                                    <div class="color-preview" id="candidateColorPreview" style="background-color: #1d3557;"></div>
                                    <span id="candidateColorValue">#1d3557</span>
                                </div>
                            </div>

                            <!-- Symbol Image Upload -->
                            <div class="upload-section">
                                <div class="upload-instructions">
                                    <strong>🖼️ Symbol Image</strong><br>
                                    Upload party symbol image (optional - will use default if not provided)
                                </div>
                                <input type="file" id="candidateSymbolUpload" class="file-input" accept="image/*" />
                                <button type="button" class="upload-btn" onclick="document.getElementById('candidateSymbolUpload').click()">
                                    🖼️ Choose Symbol Image
                                </button>
                                <div class="photo-preview-container">
                                    <div class="preview-title">Symbol Preview</div>
                                    <img id="candidateSymbolPreview" class="symbol-preview" alt="Symbol preview" />
                                </div>
                            </div>
                        </div>

                        <!-- Image Uploads Row -->
                        <div class="image-preview-row">
                            <!-- Candidate Photo Upload -->
                            <div class="image-preview-col">
                                <div class="upload-section">
                                    <div class="upload-instructions">
                                        <strong>📸 Candidate Photo</strong><br>
                                        Upload a professional photo
                                    </div>
                                    <input type="file" id="candidatePhotoUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('candidatePhotoUpload').click()">
                                        📷 Choose Photo
                                    </button>
                                    <div class="photo-preview-container">
                                        <div class="preview-title">Photo Preview</div>
                                        <img id="candidatePhotoPreview" class="photo-preview" alt="Candidate photo preview" />
                                    </div>
                                </div>
                            </div>

                            <!-- Candidate Logo Upload -->
                            <div class="image-preview-col">
                                <div class="upload-section">
                                    <div class="upload-instructions">
                                        <strong>🏢 Party Logo</strong><br>
                                        Upload party logo (optional)
                                    </div>
                                    <input type="file" id="candidateLogoUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('candidateLogoUpload').click()">
                                        🏢 Choose Logo
                                    </button>
                                    <div class="photo-preview-container">
                                        <div class="preview-title">Logo Preview</div>
                                        <img id="candidateLogoPreview" class="logo-preview" alt="Party logo preview" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group password-toggle">
                            <label for="candidatePassword" class="required">Password</label>
                            <input type="password" id="candidatePassword" name="Password" placeholder="Enter password" required />
                            <button type="button" class="toggle-password" onclick="togglePassword('candidatePassword')">👁️</button>
                            <!-- ADDED: Password validation hint -->
                            <span class="validation-hint">Min 6 chars: at least one letter, one number, and one special character</span>
                            <div class="field-error" id="candidatePasswordError"></div>
                        </div>

                        <div class="form-group password-toggle">
