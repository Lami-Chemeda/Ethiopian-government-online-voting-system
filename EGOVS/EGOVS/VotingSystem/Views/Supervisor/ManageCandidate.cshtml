            }

            showMessage('✅ Candidate ID information successfully extracted! Fields are now locked.', true);
        }

        async function extractCandidateIDInformation() {
            if (!candidateFrontImageFile && !candidateBackImageFile) {
                showMessage('Please upload at least one ID image (front or back)', false);
                return;
            }

            try {
                showCandidateOCRProcessing('🔍 Scanning Candidate ID card...');

                const formData = new FormData();
                if (candidateFrontImageFile) formData.append('FrontImage', candidateFrontImageFile);
                if (candidateBackImageFile) formData.append('BackImage', candidateBackImageFile);

                const response = await fetch('/Home/ProcessIDPhotos', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const result = await response.json();
                
                if (result.success) {
                    extractedCandidateIDData = result.data;
                    showMessage(`✅ ${result.message || 'Candidate ID information extracted successfully!'}`, true);
                    fillCandidateFormWithIDData(result.data);
                } else {
                    showMessage('❌ ' + (result.error || 'Failed to extract candidate ID information'), false);
                }
                
            } catch (error) {
                showMessage('❌ Error scanning candidate ID: ' + error.message, false);
            } finally {
                setTimeout(() => {
                    hideCandidateOCRProcessing();
                }, 2000);
            }
        }

