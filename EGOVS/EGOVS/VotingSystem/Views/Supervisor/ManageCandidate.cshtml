                markCandidateFieldAsExtractedFromOCR('Nationality');
            } else {
                document.getElementById('candidateNationality').value = 'Ethiopian';
                markCandidateFieldAsExtractedFromOCR('Nationality');
            }
            if (data.region && data.region.trim() !== '') {
                document.getElementById('candidateRegion').value = data.region;
                markCandidateFieldAsExtractedFromOCR('Region');
            }
            if (data.sex && data.sex.trim() !== '') {
                document.getElementById('candidateSex').value = data.sex;
                markCandidateFieldAsExtractedFromOCR('Sex');
            }
            if (data.age && data.age > 0) {
                document.getElementById('candidateAge').value = data.age;
                markCandidateFieldAsExtractedFromOCR('Age');
            } else if (data.dateOfBirth) {
                const age = calculateAgeFromDate(data.dateOfBirth);
