    <script>
        // Ethiopia regions data
        const ethiopiaRegions = [
            "Tigray", "Afar", "Amhara", "Oromia", "Somali", "Benishangul-Gumuz", 
            "Southern Nations, Nationalities, and Peoples' Region", "Gambela", 
            "Harari", "Addis Ababa", "Dire Dawa"
        ];

        // Global variables
        let allCandidates = [];
        let candidateFrontImageFile = null;
        let candidateBackImageFile = null;
        let extractedCandidateIDData = null;

        // ========== VALIDATION FUNCTIONS (Enhanced from Manager) ==========
        
        function validatePhoneNumber(phone) {
            phone = phone.trim();
            
            // Remove any spaces or dashes
            phone = phone.replace(/[\s-]/g, '');
            
            // Check Ethiopian phone number patterns
            if (phone.startsWith('09') && phone.length === 10) {
                // 09XXXXXXXX - 10 digits total
                return /^09\d{8}$/.test(phone);
            } else if (phone.startsWith('251') && phone.length === 12) {
                // 251XXXXXXXXX - 12 digits total
                return /^251\d{9}$/.test(phone);
            } else if (phone.startsWith('+251') && phone.length === 13) {
                // +251XXXXXXXXX - 13 digits total
                return /^\+251\d{9}$/.test(phone);
            }
            return false;
        }

        function validatePassword(password) {
            // Minimum length 6
            if (password.length < 6) return false;
            
            // At least one letter (A-Z or a-z)
            if (!/[A-Za-z]/.test(password)) return false;
            
            // At least one number (0-9)
            if (!/\d/.test(password)) return false;
            
            // At least one special character
            if (!/[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) return false;
            
            return true;
        }

        // ADDED: Party field validation function
        function validateParty(party) {
            party = party.trim();
            
            // Check if empty
            if (!party) {
                return { isValid: false, message: 'Party name is required' };
            }
            
            // Check minimum length
            if (party.length < 2) {
                return { isValid: false, message: 'Party name must be at least 2 characters long' };
            }
            
            // Check maximum length (optional, you can adjust)
            if (party.length > 100) {
                return { isValid: false, message: 'Party name must be less than 100 characters' };
            }
            
            // Check if contains only valid characters
            // Allow letters (including Ethiopian characters), spaces, hyphens, and apostrophes
            const partyRegex = /^[A-Za-z\s\u1200-\u137F\u2D80-\u2DDF\uAB01-\uAB2F\-']+$/;
            if (!partyRegex.test(party)) {
                return { isValid: false, message: 'Party name can only contain letters, spaces, hyphens, and apostrophes' };
            }
            
            // Check if contains at least one letter (not just spaces/hyphens)
            const letterRegex = /[A-Za-z\u1200-\u137F\u2D80-\u2DDF\uAB01-\uAB2F]/;
            if (!letterRegex.test(party)) {
                return { isValid: false, message: 'Party name must contain at least one letter' };
            }
            
            return { isValid: true, message: '' };
        }

        function showFieldError(fieldId, message) {
            const field = document.getElementById(fieldId);
            const errorDiv = document.getElementById(fieldId + 'Error');
            
            if (field) {
                field.classList.add('error-field');
            }
            
            if (errorDiv) {
                errorDiv.textContent = message;
                errorDiv.className = 'field-error error';
                errorDiv.style.display = 'block';
            }
        }

        function clearFieldError(fieldId) {
            const field = document.getElementById(fieldId);
            const errorDiv = document.getElementById(fieldId + 'Error');
            
            if (field) {
                field.classList.remove('error-field');
            }
            
            if (errorDiv) {
                errorDiv.style.display = 'none';
            }
        }

        function clearAllFieldErrors() {
            document.querySelectorAll('.field-error').forEach(error => {
                error.style.display = 'none';
            });
            document.querySelectorAll('.error-field').forEach(field => {
                field.classList.remove('error-field');
            });
        }

        // ========== ORIGINAL CANDIDATE FUNCTIONS (Preserved) ==========
        
        function showForm(formId) {
            document.querySelectorAll('.form-section').forEach(form => {
                form.style.display = 'none';
            });
            document.getElementById(formId).style.display = 'block';
            
            // Clear validation errors when switching forms
            clearAllFieldErrors();
        }

        function showMessage(message, isSuccess) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = message;
            messageDiv.className = isSuccess ? 'message success' : 'message error';
            messageDiv.style.display = 'block';
            
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 5000);
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
        }

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            loadCandidatesFromServer();
            populateCandidateRegions();
            
            // Initialize candidate file upload event listeners
            const frontUpload = document.getElementById('candidateFrontIdUpload');
            const backUpload = document.getElementById('candidateBackIdUpload');
            const photoUpload = document.getElementById('candidatePhotoUpload');
            const logoUpload = document.getElementById('candidateLogoUpload');
            const symbolUpload = document.getElementById('candidateSymbolUpload');
            const updatePhotoUpload = document.getElementById('updateCandidatePhotoUpload');
            const updateLogoUpload = document.getElementById('updateCandidateLogoUpload');
            const updateSymbolUpload = document.getElementById('updateCandidateSymbolUpload');
            const extractBtn = document.getElementById('candidateExtractInfoBtn');
            const autoFillBtn = document.getElementById('candidateAutoFillBtn');
            const colorPicker = document.getElementById('candidatePartyColor');
            const updateColorPicker = document.getElementById('updateCandidatePartyColor');

            // Color picker event listeners
            if (colorPicker) {
                colorPicker.addEventListener('input', function() {
