            const password = document.getElementById('updateCandidatePassword').value;
            const confirmPassword = document.getElementById('updateCandidateConfirmPassword').value;
            const photoFile = document.getElementById('updateCandidatePhotoUpload').files[0];
            const logoFile = document.getElementById('updateCandidateLogoUpload').files[0];
            const symbolFile = document.getElementById('updateCandidateSymbolUpload').files[0];
            
            // NEW: Get symbol and color data
            const symbolName = document.getElementById('updateCandidateSymbolName').value;
            const symbolUnicode = document.getElementById('updateCandidateSymbolUnicode').value;
            const partyColor = document.getElementById('updateCandidatePartyColor').value;

            if (!nationalId) {
                showMessage('Please select a candidate to update.', false);
                return;
            }

            if (!party) {
                showMessage('Party is required.', false);
                return;
            }

            // ADDED: Party validation for update form
            const partyValidation = validateParty(party);
            if (!partyValidation.isValid) {
                showMessage('Party validation error: ' + partyValidation.message, false);
                return;
            }

            // Password validation (enhanced from manager)
            if (password) {
                if (password !== confirmPassword) {
                    showMessage('Password and Confirm Password do not match.', false);
                    return;
                }

                if (!validatePassword(password)) {
                    showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                    return;
                }
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('Party', party);
                formData.append('Bio', bio);
                
                // NEW: Add symbol and color data
                if (symbolName) formData.append('SymbolName', symbolName);
                if (symbolUnicode) formData.append('SymbolUnicode', symbolUnicode);
                if (partyColor) formData.append('PartyColor', partyColor);
                
                if (password) {
                    formData.append('Password', password);
                    formData.append('ConfirmPassword', confirmPassword);
                }
                
                if (photoFile) {
                    formData.append('PhotoFile', photoFile);
                }
                if (logoFile) {
                    formData.append('LogoFile', logoFile);
                }
                if (symbolFile) {
                    formData.append('SymbolFile', symbolFile);
                }

                const response = await fetch('/Supervisor/UpdateCandidate', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    // Reset password fields only
                    document.getElementById('updateCandidatePassword').value = '';
                    document.getElementById('updateCandidateConfirmPassword').value = '';
                    document.getElementById('updateCandidatePhotoUpload').value = '';
                    document.getElementById('updateCandidateLogoUpload').value = '';
                    document.getElementById('updateCandidateSymbolUpload').value = '';
                    document.getElementById('updateCandidatePhotoPreview').style.display = 'none';
                    document.getElementById('updateCandidateLogoPreview').style.display = 'none';
                    document.getElementById('updateCandidateSymbolPreview').style.display = 'none';
                    
                    // Clear validation errors
                    clearFieldError('updateCandidatePassword');
                    clearFieldError('updateCandidateConfirmPassword');
                    clearFieldError('updateCandidateParty'); // ADDED
                    
                    await loadCandidatesFromServer();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error updating candidate:', error);
                showMessage('❌ Error updating candidate: ' + error.message, false);
            }
        });

        // Delete Candidate functionality
        document.getElementById('deleteCandidateFormElement').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const nationalId = document.getElementById('deleteCandidateNationalId').value;

            if (!nationalId) {
                showMessage('Please select a candidate to delete.', false);
                return;
            }

            // Get candidate name for confirmation message
            const candidate = allCandidates.find(c => c.nationalId === nationalId);
            const candidateName = candidate ? `${candidate.firstName} ${candidate.lastName}` : 'this candidate';

            if (!confirm(`Are you sure you want to permanently delete ${candidateName}? This action cannot be undone.`)) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);

                const response = await fetch('/Supervisor/DeleteCandidate', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    this.reset();
                    await loadCandidatesFromServer();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error deleting candidate:', error);
                showMessage('❌ Error deleting candidate: ' + error.message, false);
            }
        });

        // Toggle Candidate Status
        async function toggleCandidateStatus(nationalId, newStatus) {
            if (!confirm(`Are you sure you want to ${newStatus ? 'activate' : 'deactivate'} this candidate?`)) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('IsActive', newStatus.toString());

                const response = await fetch('/Supervisor/ToggleCandidateStatus', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage(result.message, true);
                    await loadCandidatesFromServer();
                } else {
                    showMessage(result.message, false);
                }
            } catch (error) {
                console.error('Error updating candidate status:', error);
                showMessage('Error updating candidate status: ' + error.message, false);
            }
        }

        // Delete candidate directly
        async function deleteCandidate(nationalId) {
            // Get candidate name for confirmation message
            const candidate = allCandidates.find(c => c.nationalId === nationalId);
            const candidateName = candidate ? `${candidate.firstName} ${candidate.lastName}` : 'this candidate';

            if (!confirm(`Are you sure you want to permanently delete ${candidateName}? This action cannot be undone.`)) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);

                const response = await fetch('/Supervisor/DeleteCandidate', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage(result.message, true);
                    await loadCandidatesFromServer();
                } else {
                    showMessage(result.message, false);
                }
            } catch (error) {
                console.error('Error deleting candidate:', error);
                showMessage('Error deleting candidate: ' + error.message, false);
            }
        }

        function editCandidate(nationalId) {
            showForm('updateCandidateForm');
            document.getElementById('updateCandidateNationalId').value = nationalId;
            loadCandidateData(nationalId);
        }
    </script>
</body>
</html>