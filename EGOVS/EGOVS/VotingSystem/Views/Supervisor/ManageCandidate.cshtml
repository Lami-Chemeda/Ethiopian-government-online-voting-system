                    document.getElementById('updateCandidateColorValue').textContent = this.value;
                });
            }

            if (frontUpload) {
                frontUpload.addEventListener('change', function(e) {
                    handleCandidateFileUpload(e, 'front');
                });
            }
            if (backUpload) {
                backUpload.addEventListener('change', function(e) {
                    handleCandidateFileUpload(e, 'back');
                });
            }
            if (photoUpload) {
                photoUpload.addEventListener('change', function(e) {
                    handleCandidatePhotoUpload(e);
                });
            }
            if (logoUpload) {
                logoUpload.addEventListener('change', function(e) {
                    handleCandidateLogoUpload(e);
                });
            }
            if (symbolUpload) {
                symbolUpload.addEventListener('change', function(e) {
                    handleCandidateSymbolUpload(e);
                });
            }
            if (updatePhotoUpload) {
                updatePhotoUpload.addEventListener('change', function(e) {
                    handleUpdateCandidatePhotoUpload(e);
                });
            }
            if (updateLogoUpload) {
                updateLogoUpload.addEventListener('change', function(e) {
                    handleUpdateCandidateLogoUpload(e);
                });
            }
            if (updateSymbolUpload) {
                updateSymbolUpload.addEventListener('change', function(e) {
                    handleUpdateCandidateSymbolUpload(e);
                });
            }
            if (extractBtn) {
                extractBtn.addEventListener('click', extractCandidateIDInformation);
            }
            if (autoFillBtn) {
                autoFillBtn.addEventListener('click', autoFillCandidateForm);
            }

            // Enhanced National ID checking with specific messages
            document.getElementById('candidateNationalId').addEventListener('blur', async function() {
                const nationalId = this.value.trim();
                
                if (nationalId.length > 0) {
                    try {
                        const response = await fetch(`/Supervisor/CheckNationalId?nationalId=${encodeURIComponent(nationalId)}`);
                        const result = await response.json();
                        
                        if (result.exists) {
                            showMessage('❌ ' + result.message, false);
                            this.classList.add('error-field');
                        } else {
                            this.classList.remove('error-field');
                        }
                    } catch (error) {
                        console.error('Error checking National ID:', error);
                    }
                }
            });

            // Setup real-time validation listeners
            setupCandidateValidationListeners();
        });

        function setupCandidateValidationListeners() {
            // Create form validations
            const createPhone = document.getElementById('candidatePhoneNumber');
            const createPassword = document.getElementById('candidatePassword');
            const createConfirmPassword = document.getElementById('candidateConfirmPassword');
            const createParty = document.getElementById('candidateParty'); // ADDED

            // Update form validations
            const updatePassword = document.getElementById('updateCandidatePassword');
            const updateConfirmPassword = document.getElementById('updateCandidateConfirmPassword');
            const updateParty = document.getElementById('updateCandidateParty'); // ADDED

            if (createPhone) {
                createPhone.addEventListener('blur', function() {
                    const phone = this.value.trim();
                    if (phone && !validatePhoneNumber(phone)) {
                        showFieldError('candidatePhoneNumber', 
                            'Invalid format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)');
                    } else {
                        clearFieldError('candidatePhoneNumber');
                    }
                });
            }

            if (createPassword) {
                createPassword.addEventListener('input', function() {
                    const password = this.value;
                    if (password && !validatePassword(password)) {
                        showFieldError('candidatePassword', 
                            'Password must be at least 6 characters with at least one letter, one number, and one special character');
                    } else {
                        clearFieldError('candidatePassword');
                    }
                });
            }

            if (createConfirmPassword) {
                createConfirmPassword.addEventListener('input', function() {
                    const password = document.getElementById('candidatePassword').value;
                    const confirmPassword = this.value;
                    
                    if (password && confirmPassword && password !== confirmPassword) {
                        showFieldError('candidateConfirmPassword', 'Passwords do not match');
                    } else {
                        clearFieldError('candidateConfirmPassword');
                    }
                });
            }

            // ADDED: Party field validation for create form
            if (createParty) {
                createParty.addEventListener('blur', function() {
                    const party = this.value.trim();
                    const validation = validateParty(party);
                    if (!validation.isValid) {
                        showFieldError('candidateParty', validation.message);
                    } else {
                        clearFieldError('candidateParty');
                    }
                });

                // Also validate on input to clear errors as user types
                createParty.addEventListener('input', function() {
                    const party = this.value.trim();
                    if (party && party.length > 0) {
                        clearFieldError('candidateParty');
                    }
                });
            }

            if (updatePassword) {
                updatePassword.addEventListener('input', function() {
                    const password = this.value;
                    if (password && !validatePassword(password)) {
                        showFieldError('updateCandidatePassword', 
                            'Password must be at least 6 characters with at least one letter, one number, and one special character');
                    } else {
                        clearFieldError('updateCandidatePassword');
                    }
                });
            }

            if (updateConfirmPassword) {
                updateConfirmPassword.addEventListener('input', function() {
                    const password = document.getElementById('updateCandidatePassword').value;
                    const confirmPassword = this.value;
                    
                    if (password && confirmPassword && password !== confirmPassword) {
                        showFieldError('updateCandidateConfirmPassword', 'Passwords do not match');
                    } else {
                        clearFieldError('updateCandidateConfirmPassword');
                    }
                });
            }

            // ADDED: Party field validation for update form
            if (updateParty) {
                updateParty.addEventListener('blur', function() {
                    const party = this.value.trim();
                    const validation = validateParty(party);
                    if (!validation.isValid) {
                        showFieldError('updateCandidateParty', validation.message);
                    } else {
                        clearFieldError('updateCandidateParty');
                    }
                });

                // Also validate on input to clear errors as user types
                updateParty.addEventListener('input', function() {
                    const party = this.value.trim();
                    if (party && party.length > 0) {
                        clearFieldError('updateCandidateParty');
                    }
                });
            }
        }

        // ========== CANDIDATE DATA FUNCTIONS (Preserved from Original) ==========
        
        async function loadCandidatesFromServer() {
            try {
                console.log('Loading candidates from server...');
                const response = await fetch('/Supervisor/GetCandidates');
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                console.log('Candidates loaded:', result);
                
                if (result.success) {
                    allCandidates = result.candidates;
                    displayCandidates(allCandidates);
                    populateCandidateDropdowns(allCandidates);
                    showMessage('✅ Candidates loaded successfully!', true);
                } else {
                    showMessage('Error loading candidates: ' + result.message, false);
                }
            } catch (error) {
                console.error('Error loading candidates:', error);
                showMessage('Error loading candidates: ' + error.message, false);
            }
        }

        function displayCandidates(candidates) {
            const container = document.getElementById('candidatesContainer');
            container.innerHTML = '';
            
            if (candidates.length === 0) {
                container.innerHTML = '<p>No candidates found.</p>';
                return;
            }
            
            candidates.forEach(candidate => {
                const candidateDiv = document.createElement('div');
                candidateDiv.className = 'candidate-item';
                
                const photoHtml = candidate.photoUrl 
                    ? `<img src="${candidate.photoUrl}" alt="Candidate photo" class="candidate-photo" onerror="this.style.display='none'">`
                    : '<div class="candidate-photo" style="background: #ddd; display: flex; align-items: center; justify-content: center; color: #666; font-size: 12px;">No Photo</div>';
                
                const logoHtml = candidate.logo 
                    ? `<img src="${candidate.logo}" alt="Party logo" class="candidate-logo" onerror="this.style.display='none'">`
