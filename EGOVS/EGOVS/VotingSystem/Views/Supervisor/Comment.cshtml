@model (List<CommentViewModel> ReceivedComments, List<CommentViewModel> SentComments, List<Voter> AvailableVoters, List<object> AvailableAdmins)

@{
    ViewData["Title"] = "Supervisor Comments";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ethiopian e-Voting System</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1d3557;
            --secondary-color: #457b9d;
            --accent-color: #e63946;
            --success-color: #2a9d8f;
            --warning-color: #e9c46a;
            --light-color: #f1faee;
            --dark-color: #1d3557;
            --text-color: #2d3748;
            --border-radius: 16px;
            --box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Roboto', sans-serif;
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 25%, #a8dadc 50%, #f1faee 75%, #ffffff 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            margin: 0;
            padding: 0;
            position: relative;
            overflow-x: hidden;
            line-height: 1.6;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: radial-gradient(circle at 10% 20%, rgba(232, 65, 24, 0.08) 0%, transparent 40%),
                            radial-gradient(circle at 90% 80%, rgba(20, 126, 59, 0.08) 0%, transparent 40%),
                            radial-gradient(circle at 50% 50%, rgba(252, 209, 22, 0.06) 0%, transparent 50%),
                            linear-gradient(45deg, transparent 48%, rgba(29, 53, 87, 0.03) 50%, transparent 52%);
            z-index: -2;
            animation: backgroundShift 20s ease-in-out infinite;
        }

        @@keyframes backgroundShift {
            0%, 100% { transform: translateX(0px) translateY(0px); }
            50% { transform: translateX(-10px) translateY(-10px); }
        }

        .main-container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(20px);
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            width: 100%;
            max-width: 1200px;
            position: relative;
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: slideInUp 0.8s ease-out;
            margin: 20px 0;
            overflow: hidden;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(50px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .header {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 40px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.8em;
            font-weight: 300;
            position: relative;
            z-index: 1;
        }

        .header p {
            font-size: 1.2em;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .back-home-btn {
            position: absolute;
            top: 30px;
            left: 30px;
            padding: 12px 20px;
            background: var(--accent-color);
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: var(--transition);
            font-size: 15px;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
            font-family: 'Inter', sans-serif;
            z-index: 2;
        }

        .back-home-btn:hover {
            background: #c1121f;
            transform: translateX(-5px) scale(1.05);
            box-shadow: 0 6px 20px rgba(193, 18, 31, 0.4);
        }

        .content {
            padding: 40px;
            min-height: 500px;
        }

        /* Tab Styles */
        .tabs-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .tabs-header {
            display: flex;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            padding: 0;
        }

        .tab-btn {
            flex: 1;
            padding: 20px;
            background: none;
            border: none;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .tab-btn::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 3px;
            background: var(--warning-color);
            transition: var(--transition);
            transform: translateX(-50%);
        }

        .tab-btn.active::before {
            width: 100%;
        }

        .tab-btn:hover {
            background: rgba(255,255,255,0.1);
        }

        .tab-content {
            display: none;
            padding: 30px;
            animation: fadeIn 0.5s ease-in-out;
        }

        .tab-content.active {
            display: block;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-color);
        }

        .form-control {
            width: 100%;
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 16px;
            transition: var(--transition);
            background: white;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(69, 123, 157, 0.1);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 120px;
            font-family: inherit;
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--success-color), #1a936f);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            width: 100%;
        }

        .submit-btn:hover {
            background: linear-gradient(135deg, #1a936f, var(--success-color));
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(42, 157, 143, 0.4);
        }

        /* Multi-select Styles */
        .multi-select-container {
            position: relative;
        }

        .multi-select-dropdown {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            padding: 15px;
            position: relative;
            min-height: 50px;
            display: flex;
            align-items: center;
        }

        .multi-select-dropdown::after {
            content: '▼';
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
        }

        .multi-select-dropdown.open::after {
            content: '▲';
        }

        .selected-voters {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }

        .voter-tag {
            background: var(--secondary-color);
            color: white;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        .voter-tag .remove-btn {
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            padding: 0;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
        }

        .voter-tag .remove-btn:hover {
            background: rgba(255,255,255,0.2);
        }

        .dropdown-options {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid #e2e8f0;
            border-top: none;
            border-radius: 0 0 8px 8px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .dropdown-options.open {
            display: block;
        }

        .voter-option {
            padding: 12px 15px;
            cursor: pointer;
            border-bottom: 1px solid #f1f3f4;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition);
        }

        .voter-option:hover {
            background: #f8f9fa;
        }

        .voter-option.selected {
            background: var(--light-color);
            border-left: 4px solid var(--success-color);
        }

        .voter-option input[type="checkbox"] {
            margin: 0;
        }

        .voter-option input[type="radio"] {
            margin: 0;
        }

        .voter-info {
            flex: 1;
        }

        .voter-name {
            font-weight: 600;
            color: var(--text-color);
        }

        .voter-details {
            font-size: 12px;
            color: #666;
        }

        .select-all {
            padding: 12px 15px;
            border-bottom: 2px solid #e2e8f0;
            background: #f8f9fa;
            font-weight: 600;
            color: var(--primary-color);
        }

        .selected-count {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

        /* Comment List Styles */
        .comments-list {
            max-height: 500px;
            overflow-y: auto;
        }

        .comment-item {
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: var(--transition);
            border-left: 5px solid var(--success-color);
            position: relative;
        }

        .comment-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(42, 157, 143, 0.15);
        }

        .comment-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        .comment-sender {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sender-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 1.2em;
        }

        .sender-info h4 {
            color: var(--primary-color);
            margin-bottom: 5px;
            font-size: 1.3em;
        }

        .sender-badge {
            background: var(--secondary-color);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }

        .comment-time {
            color: #6c757d;
            font-size: 0.9em;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .comment-content {
            color: var(--text-color);
            line-height: 1.6;
            font-size: 1.05em;
            padding: 15px 0;
            border-top: 1px solid #e9ecef;
            border-bottom: 1px solid #e9ecef;
            margin: 15px 0;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
        }

        .empty-icon {
            font-size: 4em;
            color: #a8dadc;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: var(--secondary-color);
            margin-bottom: 10px;
            font-size: 1.5em;
        }

        /* Delete Button Styles */
        .delete-btn {
            background: #e63946;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8em;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .delete-btn:hover {
            background: #c1121f;
            transform: scale(1.05);
        }

        .comment-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #f1f3f4;
            gap: 10px;
        }

        .comment-meta {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .comment-type {
            background: #a8dadc;
            color: #1d3557;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: bold;
        }

        .read-status {
            background: var(--secondary-color);
            color: white;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: bold;
        }

        /* Alert Styles */
        .alert {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideInAlert 0.3s ease;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeaa7;
        }

       @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .container {
                margin: 10px;
                padding: 0;
            }

            .content {
                padding: 20px;
            }

            .header {
                padding: 30px 20px;
            }

            .header h1 {
                font-size: 2.2em;
            }

            .tabs-header {
                flex-direction: column;
            }

            .tab-btn {
                padding: 15px;
            }

            .comment-header {
                flex-direction: column;
                gap: 10px;
            }

            .back-home-btn {
                position: relative;
                top: 0;
                left: 0;
                margin: 20px;
                align-self: flex-start;
            }

            .selected-voters {
                gap: 5px;
            }

            .voter-tag {
                font-size: 12px;
                padding: 4px 8px;
            }

            .comment-actions {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
            }

            .comment-meta {
                width: 100%;
                justify-content: space-between;
            }

            .delete-btn {
                align-self: flex-end;
            }
        }

        @@media (max-width: 480px) {
            .main-container {
                padding: 10px;
            }

            .header h1 {
                font-size: 1.8em;
            }

            .content {
                padding: 15px;
            }

            .comment-item {
                padding: 15px;
            }

            .sender-avatar {
                width: 40px;
                height: 40px;
                font-size: 1em;
            }

            .comment-meta {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="container">
            <a href="@Url.Action("Dashboard", "Supervisor")" class="back-home-btn">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>

            <div class="header">
                <h1><i class="fas fa-comments"></i> Communication Center</h1>
                <p>Manage Communications with Voters and Administration</p>
            </div>

            <div class="content">
                <!-- Display TempData messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["Warning"]
                    </div>
                }

                <div class="tabs-container">
                    <div class="tabs-header">
                        <button class="tab-btn active" data-tab="to-voter">
                            <i class="fas fa-user"></i> Message to Voters
                        </button>
                        <button class="tab-btn" data-tab="to-admin">
                            <i class="fas fa-user-shield"></i> Message to Admin
                        </button>
                        <button class="tab-btn" data-tab="received">
                            <i class="fas fa-inbox"></i> From Admin
                        </button>
                    </div>

                    <!-- Message to Voters Tab -->
                    <div class="tab-content active" id="to-voter">
                        <h3 style="color: var(--primary-color); margin-bottom: 20px;">
                            <i class="fas fa-users"></i> Send Message to Multiple Voters
                        </h3>
                        <form method="post" action="@Url.Action("CreateCommentToVoter", "Supervisor")" id="voterMessageForm">
                            <div class="form-group">
                                <label for="voterSelect">Select Voters:</label>
                                <div class="multi-select-container">
                                    <div class="multi-select-dropdown" id="voterDropdown">
                                        Click to select voters...
                                    </div>
                                    <div class="dropdown-options" id="voterOptions">
                                        <div class="select-all">
                                            <input type="checkbox" id="selectAllVoters">
                                            <label for="selectAllVoters">Select All Voters</label>
                                        </div>
                                        @if (Model.AvailableVoters != null && Model.AvailableVoters.Any())
                                        {
                                            @foreach (var voter in Model.AvailableVoters)
                                            {
                                                <div class="voter-option" data-name="@voter.FirstName @voter.LastName" data-id="@voter.NationalId">
                                                    <input type="checkbox" value="@voter.NationalId" id="voter_@voter.NationalId">
                                                    <div class="voter-info">
                                                        <div class="voter-name">@voter.FirstName @voter.LastName</div>
                                                        <div class="voter-details">ID: @voter.NationalId | Phone: @voter.PhoneNumber</div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="voter-option" style="justify-content: center; color: #666;">
                                                <i class="fas fa-exclamation-circle"></i> No voters found in the database
                                            </div>
                                        }
                                    </div>
                                    <div class="selected-voters" id="selectedVoters"></div>
                                    <div class="selected-count" id="selectedCount">0 voters selected</div>
                                </div>
                                <input type="hidden" id="selectedVoterIds" name="voterNationalIds">
                                <input type="hidden" id="selectedVoterNames" name="voterNames">
                            </div>
                            <div class="form-group">
                                <label for="subjectVoter">Subject:</label>
                                <input type="text" class="form-control" id="subjectVoter" name="subject" value="Important Voting Information" required>
                            </div>
                            <div class="form-group">
                                <label for="contentVoter">Your Message:</label>
                                <textarea class="form-control" id="contentVoter" name="content" placeholder="Enter your message to the selected voters..." required maxlength="1000"></textarea>
                                <small style="color: #666; margin-top: 5px; display: block;">This message will be sent to all selected voters. Maximum 1000 characters.</small>
                            </div>
                            <button type="submit" class="submit-btn">
                                <i class="fas fa-paper-plane"></i> Send to Selected Voters
                            </button>
                        </form>
                    </div>

                    <!-- Message to Admin Tab -->
                    <div class="tab-content" id="to-admin">
                        <h3 style="color: var(--primary-color); margin-bottom: 20px;">
                            <i class="fas fa-user-shield"></i> Send Message to Administration
                        </h3>
                        <form method="post" action="@Url.Action("CreateCommentToAdmin", "Supervisor")" id="adminMessageForm">
                            <div class="form-group">
                                <label for="adminSelect">Select Admin (Optional):</label>
                                <div class="multi-select-container">
                                    <div class="multi-select-dropdown" id="adminDropdown">
                                        Click to select specific admin (or leave for general admin)
                                    </div>
                                    <div class="dropdown-options" id="adminOptions">
                                        <div class="select-all">
                                            <input type="radio" name="adminSelection" id="generalAdmin" value="general" checked>
                                            <label for="generalAdmin">Send to General Administration</label>
                                        </div>
                                        @if (Model.AvailableAdmins != null && Model.AvailableAdmins.Any())
                                        {
                                            @foreach (var admin in Model.AvailableAdmins)
                                            {
                                                <div class="voter-option" data-name="@((admin as dynamic)?.FirstName ?? "") @((admin as dynamic)?.LastName ?? "")" data-id="@((admin as dynamic)?.NationalId ?? "")">
                                                    <input type="radio" name="adminSelection" value="@((admin as dynamic)?.NationalId ?? "")" id="admin_@((admin as dynamic)?.NationalId ?? "")">
                                                    <div class="voter-info">
                                                        <div class="voter-name">@((admin as dynamic)?.FirstName ?? "") @((admin as dynamic)?.LastName ?? "")</div>
                                                        <div class="voter-details">ID: @((admin as dynamic)?.NationalId ?? "") | Phone: @((admin as dynamic)?.PhoneNumber ?? "")</div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="voter-option" style="justify-content: center; color: #666;">
                                                <i class="fas fa-exclamation-circle"></i> No active admins found
                                            </div>
                                        }
                                    </div>
                                </div>
                                <input type="hidden" id="selectedAdminId" name="adminNationalId">
                                <input type="hidden" id="selectedAdminName" name="adminName">
                            </div>
                            <div class="form-group">
                                <label for="subjectAdmin">Subject:</label>
                                <input type="text" class="form-control" id="subjectAdmin" name="subject" value="System Feedback" required>
                            </div>
                            <div class="form-group">
                                <label for="contentAdmin">Your Message:</label>
                                <textarea class="form-control" id="contentAdmin" name="content" placeholder="Enter your message to the administration..." required maxlength="1000"></textarea>
                                <small style="color: #666; margin-top: 5px; display: block;">Maximum 1000 characters</small>
                            </div>
                            <button type="submit" class="submit-btn">
                                <i class="fas fa-paper-plane"></i> Send to Administration
                            </button>
                        </form>
                    </div>

                    <!-- Received Messages Tab -->
<div class="tab-content" id="received">
    <h3 style="color: var(--primary-color); margin-bottom: 20px;">
        <i class="fas fa-inbox"></i> Messages from Administration
    </h3>
    <div class="comments-list">
        @if (Model.ReceivedComments != null && Model.ReceivedComments.Any())
        {
            foreach (var comment in Model.ReceivedComments)
            {
                <div class="comment-item @(comment.IsRead ? "read" : "unread")" data-comment-id="@comment.Id" onclick="markAsRead(@comment.Id, this)">
                    <div class="comment-header">
                        <div class="comment-sender">
                            <div class="sender-avatar">
                                @if (!string.IsNullOrEmpty(comment.SenderName))
                                {
                                    @comment.SenderName.Substring(0, 1)
                                }
                                else
                                {
                                    @:A
                                }
                            </div>
                            <div class="sender-info">
                                <h4>@comment.SenderName</h4>
                                <div class="sender-badge">
                                    <i class="fas fa-user-shield"></i>
                                    @comment.SenderType
                                </div>
                            </div>
                        </div>
                        <div class="comment-time">
                            <i class="far fa-clock"></i>
                            @comment.TimeAgo
                        </div>
                    </div>
                    <div class="comment-content">
                        <p>@comment.Content</p>
                    </div>
                    <div class="comment-actions">
                        <div class="comment-meta">
                            <span style="background: var(--warning-color); color: var(--primary-color); padding: 4px 12px; border-radius: 15px; font-weight: bold; font-size: 0.9em;">
                                <i class="fas fa-tag"></i> @comment.Subject
                            </span>
                            <span class="comment-type">
                                <i class="fas fa-comment-dots"></i>
                                @comment.CommentType
                            </span>
                            <span class="read-status @(comment.IsRead ? "read" : "unread")" id="read-status-@comment.Id" style="background: @(comment.IsRead ? "#2a9d8f" : "#e63946");">
                                <i class="fas fa-@(comment.IsRead ? "eye" : "eye-slash")"></i>
                                @(comment.IsRead ? "Read" : "Unread")
                            </span>
                        </div>
                        <button class="delete-btn" onclick="deleteComment(@comment.Id, event)">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="far fa-comments"></i>
                </div>
                <h3>No Messages Yet</h3>
                <p>You haven't received any messages from the administration yet.</p>
            </div>
        }
    </div>
</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add AntiForgeryToken for security -->
    @Html.AntiForgeryToken()

   <script>
    // Function to mark comment as read (EXACTLY like voter controller)
    // Function to mark comment as read (EXACTLY like voter controller)
async function markAsRead(commentId, element) {
    try {
        console.log('Marking comment as read:', commentId);
        
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        console.log('AntiForgeryToken found:', !!token);
        
        const requestBody = {
            commentId: commentId
        };
        
        console.log('Sending request body:', requestBody);
        
        const response = await fetch('@Url.Action("MarkCommentAsRead", "Supervisor")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(requestBody)
        });

        console.log('Response status:', response.status);
        
        const result = await response.json();
        console.log('Server response:', result);
        
        if (result.success) {
            // Update UI exactly like voter controller
            element.classList.add('read');
            element.classList.remove('unread');
            
            const readStatus = document.getElementById(`read-status-${commentId}`);
            if (readStatus) {
                readStatus.innerHTML = '<i class="fas fa-eye"></i> Read';
                readStatus.style.background = "#2a9d8f";
                readStatus.classList.add('read');
                readStatus.classList.remove('unread');
            }
            
            console.log('Comment marked as read successfully');
        } else {
            console.error('Failed to mark comment as read:', result.message);
            showAlert(result.message || 'Failed to mark comment as read', 'error');
        }
    } catch (error) {
        console.error('Error marking comment as read:', error);
        showAlert('Error marking comment as read. Please try again.', 'error');
    }
}

    // Function to delete comment (EXACTLY like voter controller)
    // Function to delete comment (EXACTLY like voter controller)
async function deleteComment(commentId, event) {
    if (event) {
        event.stopPropagation();
    }
    
    if (!confirm('Are you sure you want to delete this message?')) {
        return;
    }

    try {
        console.log('Deleting comment:', commentId);
        
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        const requestBody = {
            commentId: commentId
        };
        
        console.log('Sending request body:', requestBody);
        
        const response = await fetch('@Url.Action("DeleteComment", "Supervisor")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(requestBody)
        });

        console.log('Response status:', response.status);
        
        const result = await response.json();
        console.log('Server response:', result);
        
        if (result.success) {
            const commentElement = document.querySelector(`[data-comment-id="${commentId}"]`);
            if (commentElement) {
                commentElement.style.opacity = '0';
                commentElement.style.transform = 'translateX(-100px)';
                setTimeout(() => {
                    commentElement.remove();
                    updateCommentsCount();
                }, 300);
            }
            
            showAlert('Message deleted successfully!', 'success');
        } else {
            console.error('Delete failed:', result.message);
            showAlert(result.message || 'Failed to delete message', 'error');
        }
    } catch (error) {
        console.error('Error deleting message:', error);
        showAlert('Error deleting message. Please try again.', 'error');
    }
}

    // Function to show alert messages
    function showAlert(message, type) {
        const existingAlerts = document.querySelectorAll('.alert');
        existingAlerts.forEach(alert => alert.remove());

        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type}`;
        alertDiv.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check' : 'exclamation'}-circle"></i>
            ${message}
        `;
        
        const content = document.querySelector('.content');
        const tabsContainer = document.querySelector('.tabs-container');
        content.insertBefore(alertDiv, tabsContainer);
        
        setTimeout(() => {
            if (alertDiv.parentElement) {
                alertDiv.style.opacity = '0';
                alertDiv.style.transform = 'translateY(-10px)';
                setTimeout(() => alertDiv.remove(), 300);
            }
        }, 5000);
    }

    // Update comments count after deletion
    function updateCommentsCount() {
        const commentItems = document.querySelectorAll('.comment-item');
        console.log(`Remaining comments: ${commentItems.length}`);
    }

    // Initialize when page loads
    document.addEventListener('DOMContentLoaded', function() {
        // Add click handlers to comment items for mark as read
        const commentItems = document.querySelectorAll('#received .comment-item');
        
        commentItems.forEach(item => {
            const commentId = item.getAttribute('data-comment-id');
            
            // Add click event to mark as read when clicking anywhere on the comment
            item.addEventListener('click', function(e) {
                // Don't trigger if delete button was clicked
                if (!e.target.closest('.delete-btn')) {
                    const isRead = item.querySelector('.read-status').textContent.includes('Read');
                    if (!isRead) {
                        markAsRead(commentId, item);
                    }
                }
            });
        });

        // Add smooth animations
        commentItems.forEach((item, index) => {
            item.style.opacity = '0';
            item.style.transform = 'translateY(20px)';
            
            setTimeout(() => {
                item.style.transition = 'all 0.5s ease';
                item.style.opacity = '1';
                item.style.transform = 'translateY(0)';
            }, index * 100);
        });

        // Auto-hide alerts after 5 seconds
        setTimeout(() => {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 0.5s ease';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 5000);
    });

    // Keep all your existing multi-select and form functionality below
    // Multi-select functionality for voters
    document.addEventListener('DOMContentLoaded', function() {
        const voterDropdown = document.getElementById('voterDropdown');
        const voterOptions = document.getElementById('voterOptions');
        const selectedVoters = document.getElementById('selectedVoters');
        const selectedCount = document.getElementById('selectedCount');
        const selectAllCheckbox = document.getElementById('selectAllVoters');
        const voterCheckboxes = voterOptions.querySelectorAll('input[type="checkbox"]:not(#selectAllVoters)');
        const selectedVoterIds = document.getElementById('selectedVoterIds');
        const selectedVoterNames = document.getElementById('selectedVoterNames');

        let selectedVotersMap = new Map();

        // Toggle dropdown for voters
        voterDropdown.addEventListener('click', function(e) {
            e.stopPropagation();
            voterOptions.classList.toggle('open');
            voterDropdown.classList.toggle('open');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!voterDropdown.contains(e.target) && !adminDropdown.contains(e.target)) {
                voterOptions.classList.remove('open');
                voterDropdown.classList.remove('open');
                adminOptions.classList.remove('open');
                adminDropdown.classList.remove('open');
            }
        });

        // Handle voter selection
        voterCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const voterId = this.value;
                const voterOption = this.closest('.voter-option');
                const voterName = voterOption.getAttribute('data-name');

                if (this.checked) {
                    selectedVotersMap.set(voterId, voterName);
                    voterOption.classList.add('selected');
                } else {
                    selectedVotersMap.delete(voterId);
                    voterOption.classList.remove('selected');
                }

                updateSelectedVotersDisplay();
                updateSelectAllCheckbox();
            });
        });

        // Select all functionality for voters
        selectAllCheckbox.addEventListener('change', function() {
            voterCheckboxes.forEach(checkbox => {
                checkbox.checked = this.checked;
                const voterOption = checkbox.closest('.voter-option');
                const voterId = checkbox.value;
                const voterName = voterOption.getAttribute('data-name');

                if (this.checked) {
                    selectedVotersMap.set(voterId, voterName);
                    voterOption.classList.add('selected');
                } else {
                    selectedVotersMap.delete(voterId);
                    voterOption.classList.remove('selected');
                }
            });

            updateSelectedVotersDisplay();
        });

        function updateSelectedVotersDisplay() {
            // Clear current display
            selectedVoters.innerHTML = '';
            
            // Add selected voter tags
            selectedVotersMap.forEach((name, id) => {
                const tag = document.createElement('div');
                tag.className = 'voter-tag';
                tag.innerHTML = `
                    ${name}
                    <button type="button" class="remove-btn" data-id="${id}">×</button>
                `;
                selectedVoters.appendChild(tag);
            });

            // Update count
            const count = selectedVotersMap.size;
            selectedCount.textContent = `${count} voter${count !== 1 ? 's' : ''} selected`;

            // Update dropdown text
            if (count === 0) {
                voterDropdown.textContent = 'Click to select voters...';
            } else if (count === 1) {
                voterDropdown.textContent = selectedVotersMap.values().next().value;
            } else {
                voterDropdown.textContent = `${count} voters selected`;
            }

            // Update hidden fields
            selectedVoterIds.value = Array.from(selectedVotersMap.keys()).join(',');
            selectedVoterNames.value = Array.from(selectedVotersMap.values()).join(',');
        }

        function updateSelectAllCheckbox() {
            const totalVoters = voterCheckboxes.length;
            const selectedCount = selectedVotersMap.size;
            selectAllCheckbox.checked = selectedCount === totalVoters && totalVoters > 0;
            selectAllCheckbox.indeterminate = selectedCount > 0 && selectedCount < totalVoters;
        }

        // Remove voter tag
        selectedVoters.addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-btn')) {
                const voterId = e.target.getAttribute('data-id');
                const checkbox = document.querySelector(`input[value="${voterId}"]`);
                if (checkbox) {
                    checkbox.checked = false;
                    checkbox.dispatchEvent(new Event('change'));
                }
            }
        });

        // Tab functionality
        const tabBtns = document.querySelectorAll('.tab-btn');
        const tabContents = document.querySelectorAll('.tab-content');

        tabBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const tabId = this.getAttribute('data-tab');
                
                // Remove active class from all buttons and contents
                tabBtns.forEach(b => b.classList.remove('active'));
                tabContents.forEach(c => c.classList.remove('active'));
                
                // Add active class to current button and content
                this.classList.add('active');
                document.getElementById(tabId).classList.add('active');
            });
        });
    });

    // Admin selection functionality
    const adminDropdown = document.getElementById('adminDropdown');
    const adminOptions = document.getElementById('adminOptions');
    const adminRadios = adminOptions.querySelectorAll('input[type="radio"]');
    const selectedAdminId = document.getElementById('selectedAdminId');
    const selectedAdminName = document.getElementById('selectedAdminName');

    // Set default to general admin
    selectedAdminId.value = '';
    selectedAdminName.value = 'General Administration';

    // Toggle dropdown for admins
    adminDropdown.addEventListener('click', function(e) {
        e.stopPropagation();
        adminOptions.classList.toggle('open');
        adminDropdown.classList.toggle('open');
    });

    // Handle admin selection
    adminRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            if (this.value === 'general') {
                // General admin selected
                adminDropdown.textContent = 'Send to General Administration';
                selectedAdminId.value = '';
                selectedAdminName.value = 'General Administration';
            } else {
                // Specific admin selected
                const adminOption = this.closest('.voter-option');
                const adminName = adminOption.getAttribute('data-name');
                const adminId = this.value;

                adminDropdown.textContent = adminName;
                selectedAdminId.value = adminId;
                selectedAdminName.value = adminName;

                // Update UI
                adminRadios.forEach(r => {
                    r.closest('.voter-option')?.classList.remove('selected');
                });
                adminOption.classList.add('selected');
            }

            // Close dropdown
            adminOptions.classList.remove('open');
            adminDropdown.classList.remove('open');
        });
    });
</script>
</body>
</html>