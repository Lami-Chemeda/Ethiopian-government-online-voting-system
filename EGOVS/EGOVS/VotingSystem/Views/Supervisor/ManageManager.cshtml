            const phoneNumber = document.getElementById('managerPhoneNumber').value.trim();
            const email = document.getElementById('managerEmail').value.trim();
            const username = document.getElementById('managerUsername').value.trim();
            const password = document.getElementById('managerPassword').value;
            const confirmPassword = document.getElementById('managerConfirmPassword').value;
            const nationality = document.getElementById('managerNationality').value;
            const region = document.getElementById('managerRegion').value;
            const age = parseInt(document.getElementById('managerAge').value);
            const sex = document.getElementById('managerSex').value;

            // Basic validation
            if (!nationalId || !firstName || !middleName || !lastName || !phoneNumber || !password || !confirmPassword || !nationality || !region || !age || !sex) {
                showMessage('Please fill in all required fields.', false);
                return;
            }

            // Phone validation
            if (!validatePhoneNumber(phoneNumber)) {
                showMessage('Invalid phone number format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)', false);
                return;
            }

            // Email validation (optional)
            if (email && !validateEmail(email)) {
                showMessage('Email must contain at least one letter, @@ symbol, and at least one number (e.g., user123@@example.com)', false);
                return;
            }

            // Username validation (optional)
            if (username && !validateUsername(username)) {
                showMessage('Username can only contain letters (A-Z, a-z), numbers, underscores, and hyphens', false);
                return;
            }

            // Password validation
            if (password !== confirmPassword) {
                showMessage('Passwords do not match.', false);
                return;
            }

            if (!validatePassword(password)) {
                showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                return;
            }

            // Age validation
            if (age < 18 || age > 120) {
                showMessage('Age must be between 18 and 120.', false);
                return;
            }

            // Sex validation
            if (sex !== 'Male' && sex !== 'Female') {
                showMessage('Sex must be Male or Female.', false);
                return;
            }

            try {
                // Create form data
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('FirstName', firstName);
                formData.append('MiddleName', middleName);
                formData.append('LastName', lastName);
                formData.append('PhoneNumber', phoneNumber);
                formData.append('Email', email);
                formData.append('Username', username);
                formData.append('Password', password);
                formData.append('Nationality', nationality);
                formData.append('Region', region);
                formData.append('Age', age.toString());
                formData.append('Sex', sex);

                const response = await fetch('/Supervisor/RegisterManager', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ Manager registered successfully!', true);
                    
                    // Reset form
                    this.reset();
                    
                    // Reset extracted fields
                    document.querySelectorAll('.extracted-field').forEach(field => {
                        field.classList.remove('extracted-field');
                        field.readOnly = false;
                    });
                    document.querySelectorAll('.field-status').forEach(status => {
                        status.style.display = 'none';
                    });
                    
