        // Manager OCR Functions
        function handleManagerFileUpload(event, side) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateImageFile(file)) {
                showMessage('Please select a valid image file (JPG, PNG, BMP) under 5MB', false);
                event.target.value = '';
                return;
            }

            if (side === 'front') {
                managerFrontImageFile = file;
            } else {
                managerBackImageFile = file;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageData = e.target.result;
                updateManagerPreview(side, imageData, file.name);
            };
            reader.readAsDataURL(file);
        }

        function validateImageFile(file) {
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/bmp'];
            const maxSize = 5 * 1024 * 1024;
            return allowedTypes.includes(file.type) && file.size <= maxSize;
        }

        function updateManagerPreview(side, imageData, fileName) {
            const container = document.getElementById('manager' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewContainer');
            const textElement = document.getElementById('manager' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewText');
            const imageElement = document.getElementById('manager' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewImage');

            if (container && textElement && imageElement) {
                container.classList.add('active');
                textElement.textContent = fileName;
                textElement.style.color = '#28a745';
                textElement.style.fontWeight = 'bold';
                imageElement.innerHTML = '<img src="' + imageData + '" alt="' + side + ' side preview" style="max-width: 100px; max-height: 80px; border-radius: 4px;">';
            }
        }

        function markManagerFieldAsExtractedFromOCR(fieldId) {
            const field = document.getElementById('manager' + fieldId);
            const statusElement = document.getElementById('manager' + fieldId + 'Status');
            
            if (field) {
                field.classList.add('extracted-field');
                field.readOnly = true;
                
