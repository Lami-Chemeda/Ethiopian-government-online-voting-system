@{
    ViewData["Title"] = "Manage Managers";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ethiopian Voting System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 25%, #a8dadc 50%, #f1faee 75%, #ffffff 100%);
            min-height: 100vh;
            padding: 20px;
            position: relative;
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: #1e3c72;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
            transition: all 0.3s ease;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn:hover {
            background: linear-gradient(45deg, #FFA500, #FF8C00);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            overflow: hidden;
            margin-top: 60px;
        }

        .header {
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .content {
            padding: 40px;
        }

        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .action-btn {
            background: linear-gradient(45deg, #1e3c72, #2a5298);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            background: linear-gradient(45deg, #2a5298, #1e3c72);
            transform: translateY(-2px);
        }

        .form-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            margin-top: 20px;
            display: none;
        }

        .form-group {
            margin-bottom: 15px;
            position: relative;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #1e3c72;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }

        .form-group textarea {
            height: 100px;
            resize: vertical;
        }

        .submit-btn {
            background: linear-gradient(45deg, #1e3c72, #2a5298);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            background: linear-gradient(45deg, #2a5298, #1e3c72);
            transform: translateY(-2px);
        }

        .managers-list {
            margin-top: 30px;
        }

        .manager-item {
            background: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
            border-left: 4px solid #1e3c72;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .manager-info {
            flex: 1;
        }

        .manager-details {
            flex: 1;
        }

        .manager-actions button {
            margin-left: 10px;
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .edit-btn {
            background: #FFA500;
            color: white;
        }

        .delete-btn {
            background: #DC143C;
            color: white;
        }

        .status-btn {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #808080;
        }

        .message {
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
            text-align: center;
            display: none;
        }

        .success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .status-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }

        .status-active {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #DC143C;
            color: white;
        }

        .password-toggle {
            position: relative;
        }

        .password-toggle input {
            padding-right: 40px;
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
        }

        .upload-section {
            margin: 15px 0;
            padding: 15px;
            border: 2px dashed #1d3557;
            border-radius: 8px;
            background: #f8f9fa;
            text-align: center;
        }

        .upload-btn {
            background: #1d3557;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin: 5px;
        }

        .upload-btn:hover {
            background: #457b9d;
        }

        .file-input {
            display: none;
        }

        .upload-instructions {
            background: #e7f3ff;
            border: 1px solid #b3d9ff;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 10px;
            text-align: center;
        }

        .required::after {
            content: " *";
            color: red;
        }

        .readonly-field {
            background-color: #f8f9fa !important;
            cursor: not-allowed !important;
            color: #6c757d !important;
        }

        .extracted-field {
            background-color: #f8f9fa !important;
            border: 2px solid #28a745 !important;
            color: #155724 !important;
            font-weight: bold !important;
            cursor: not-allowed !important;
        }

        .field-status {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: inline-block;
        }

        .field-status.auto-filled {
            background: #d4edda;
            color: #155724;
        }

        .error-field {
            border: 2px solid #dc3545 !important;
            background-color: #f8d7da !important;
        }

        .field-error {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: none;
        }

        .field-error.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .field-error.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .validation-hint {
            font-size: 11px;
            color: #6c757d;
            margin-top: 2px;
            display: block;
        }

        .id-preview-container {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .id-preview {
            flex: 1;
            text-align: center;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: white;
        }

        .id-preview.active {
            border-color: #28a745;
            background: #f8fff9;
        }

        .upload-quality-tips {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            padding: 10px;
            border-radius: 6px;
            margin-top: 10px;
            font-size: 14px;
            text-align: left;
        }

        .upload-quality-tips h6 {
            margin: 0 0 8px 0;
            color: #856404;
        }

        .upload-quality-tips ul {
            margin: 0;
            padding-left: 20px;
        }

        .upload-quality-tips li {
            margin-bottom: 5px;
        }

        .action-buttons-ocr {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .extract-btn {
            background: #28a745;
        }

        .extract-btn:hover {
            background: #218838;
        }

        .demo-btn {
            background: #6c757d;
        }

        .demo-btn:hover {
            background: #5a6268;
        }

        .ocr-processing {
            background: linear-gradient(135deg, #e3f2fd, #bbdefb);
            border: 2px solid #1d3557;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            text-align: center;
            display: none;
        }

        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 0.2em solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border-animation .75s linear infinite;
        }

        @@keyframes spinner-border-animation {
            to { 
                transform: rotate(360deg); 
            }
        }
    </style>
</head>
<body>
    <a class="back-btn" href="/Supervisor/Dashboard">
        ← Back to Dashboard
    </a>
    
    <div class="container">
        <div class="header">
            <h1>👥 Manage Managers</h1>
            <p>Create, Update, and Delete System Managers</p>
        </div>

        <div class="content">
            <div id="message" class="message"></div>

            <!-- Managers Section -->
            <div id="managers">
                <div class="action-buttons">
                    <button class="action-btn" onclick="showForm('createManagerForm')">➕ Create Manager</button>
                    <button class="action-btn" onclick="showForm('updateManagerForm')">✏️ Update Manager</button>
                    <button class="action-btn" onclick="showForm('deleteManagerForm')">🗑️ Delete Manager</button>
                </div>

                <!-- Create Manager Form -->
                <div id="createManagerForm" class="form-section">
                    <h3>Create New Manager</h3>
                    <form id="createManagerFormElement" enctype="multipart/form-data">
                        <!-- National ID Field -->
                        <div class="form-group">
                            <label for="managerNationalId" class="required">National ID (FAN)</label>
                            <input type="text" id="managerNationalId" name="NationalId" placeholder="Enter National ID" required />
                            <div class="field-status auto-filled" id="managerNationalIdStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <!-- Enhanced ID Upload Section -->
                        <div class="upload-section">
                            <div class="upload-instructions">
                                <strong>📁 Upload National ID Card Photos</strong><br>
                                Upload clear photos of front and back sides of manager's ID card
                            </div>

                            <div class="upload-quality-tips">
                                <h6>📝 For Best OCR Results:</h6>
                                <ul>
                                    <li>Use high-quality scanned images or photos</li>
                                    <li>Ensure good lighting without shadows or glare</li>
                                    <li>Place ID on flat surface</li>
                                    <li>Capture entire ID card clearly</li>
                                    <li>File formats: JPG, PNG, BMP (Max 5MB)</li>
                                </ul>
                            </div>
                            
                            <div class="id-preview-container">
                                <div class="id-preview" id="managerFrontPreviewContainer">
                                    <div><strong>Front Side</strong></div>
                                    <div id="managerFrontPreviewText">No file selected</div>
                                    <div id="managerFrontPreviewImage"></div>
                                    <input type="file" id="managerFrontIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('managerFrontIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Front Image
                                    </button>
                                </div>
                                
                                <div class="id-preview" id="managerBackPreviewContainer">
                                    <div><strong>Back Side</strong></div>
                                    <div id="managerBackPreviewText">No file selected</div>
                                    <div id="managerBackPreviewImage"></div>
                                    <input type="file" id="managerBackIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('managerBackIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Back Image
                                    </button>
                                </div>
                            </div>

                            <div class="action-buttons-ocr">
                                <button type="button" class="upload-btn extract-btn" id="managerExtractInfoBtn">
                                    🔍 Extract ID Information
                                </button>
                                <button type="button" class="upload-btn demo-btn" id="managerAutoFillBtn">
                                    📝 Auto-fill Form
                                </button>
                            </div>

                            <div id="managerOcrProcessing" class="ocr-processing">
                                <!-- Processing message will be inserted here -->
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="managerFirstName" class="required">First Name</label>
                            <input type="text" id="managerFirstName" name="FirstName" placeholder="Enter first name" required />
                            <div class="field-status auto-filled" id="managerFirstNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerMiddleName" class="required">Middle Name</label>
                            <input type="text" id="managerMiddleName" name="MiddleName" placeholder="Enter middle name" required />
                            <div class="field-status auto-filled" id="managerMiddleNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerLastName" class="required">Last Name</label>
                            <input type="text" id="managerLastName" name="LastName" placeholder="Enter last name" required />
                            <div class="field-status auto-filled" id="managerLastNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerPhoneNumber" class="required">Phone Number</label>
                            <input type="tel" id="managerPhoneNumber" name="PhoneNumber" placeholder="Enter phone number" required />
                            <div class="field-status auto-filled" id="managerPhoneNumberStatus" style="display: none;">Auto-filled from ID</div>
                            <span class="validation-hint">Format: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)</span>
                            <div class="field-error" id="managerPhoneNumberError"></div>
                        </div>

                        <div class="form-group">
                            <label for="managerEmail">Email</label>
                            <input type="email" id="managerEmail" name="Email" placeholder="Enter email address (optional)" />
                            <span class="validation-hint">Must contain at least one letter, @@ symbol, and at least one number</span>
                            <div class="field-error" id="managerEmailError"></div>
                        </div>

                        <div class="form-group">
                            <label for="managerUsername">Username</label>
                            <input type="text" id="managerUsername" name="Username" placeholder="Enter username (optional)" />
                            <span class="validation-hint">Only letters (A-Z, a-z), numbers, underscores, and hyphens allowed</span>
                            <div class="field-error" id="managerUsernameError"></div>
                        </div>

                        <div class="form-group password-toggle">
                            <label for="managerPassword" class="required">Password</label>
                            <input type="password" id="managerPassword" name="Password" placeholder="Enter password" required />
                            <button type="button" class="toggle-password" onclick="togglePassword('managerPassword')">👁️</button>
                            <span class="validation-hint">Min 6 chars: at least one letter, one number, and one special character</span>
                            <div class="field-error" id="managerPasswordError"></div>
                        </div>

                        <div class="form-group password-toggle">
                            <label for="managerConfirmPassword" class="required">Confirm Password</label>
                            <input type="password" id="managerConfirmPassword" name="ConfirmPassword" placeholder="Confirm password" required />
                            <button type="button" class="toggle-password" onclick="togglePassword('managerConfirmPassword')">👁️</button>
                            <div class="field-error" id="managerConfirmPasswordError"></div>
                        </div>

                        <div class="form-group">
                            <label for="managerNationality" class="required">Nationality</label>
                            <select id="managerNationality" name="Nationality" required>
                                <option value="" disabled selected>Select Nationality</option>
                                <option value="Ethiopian">Ethiopian</option>
                                <option value="Other">Other</option>
                            </select>
                            <div class="field-status auto-filled" id="managerNationalityStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerRegion" class="required">Region</label>
                            <select id="managerRegion" name="Region" required>
                                <option value="" disabled selected>Select Region</option>
                            </select>
                            <div class="field-status auto-filled" id="managerRegionStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerAge" class="required">Age</label>
                            <input type="number" id="managerAge" name="Age" min="18" max="120" placeholder="Enter age" required />
                            <div class="field-status auto-filled" id="managerAgeStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerSex" class="required">Sex</label>
                            <select id="managerSex" name="Sex" required>
                                <option value="" disabled selected>Select Sex</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <div class="field-status auto-filled" id="managerSexStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="managerIsActive">Account Status</label>
                            <select id="managerIsActive" name="IsActive">
                                <option value="true" selected>Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>

                        <button type="submit" class="submit-btn">Create Manager</button>
                    </form>
                </div>

                <!-- Update Manager Form -->
                <div id="updateManagerForm" class="form-section">
                    <h3>Update Manager</h3>
                    <form id="updateManagerFormElement">
                        <div class="form-group">
                            <label for="updateManagerNationalId">Select Manager *</label>
                            <select id="updateManagerNationalId" required onchange="loadManagerData(this.value)">
                                <option value="">Select a manager</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateManagerFirstName">First Name *</label>
                            <input type="text" id="updateManagerFirstName" name="FirstName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateManagerMiddleName">Middle Name *</label>
                            <input type="text" id="updateManagerMiddleName" name="MiddleName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateManagerLastName">Last Name *</label>
                            <input type="text" id="updateManagerLastName" name="LastName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateManagerPhoneNumber">Phone Number *</label>
                            <input type="tel" id="updateManagerPhoneNumber" name="PhoneNumber" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateManagerEmail">Email</label>
                            <input type="email" id="updateManagerEmail" name="Email" placeholder="Enter email address">
                            <span class="validation-hint">Must contain at least one letter, @@ symbol, and at least one number</span>
                            <div class="field-error" id="updateManagerEmailError"></div>
                        </div>
                        <div class="form-group">
                            <label for="updateManagerUsername">Username</label>
                            <input type="text" id="updateManagerUsername" name="Username" placeholder="Enter username">
                            <span class="validation-hint">Only letters (A-Z, a-z), numbers, underscores, and hyphens allowed</span>
                            <div class="field-error" id="updateManagerUsernameError"></div>
                        </div>
                        <div class="form-group">
                            <label for="updateManagerNationality">Nationality *</label>
                            <select id="updateManagerNationality" name="Nationality" required readonly class="readonly-field">
                                <option value="Ethiopian">Ethiopian</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateManagerRegion">Region *</label>
                            <select id="updateManagerRegion" name="Region" required readonly class="readonly-field">
                                <option value="">Select Region</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateManagerAge">Age *</label>
                            <input type="number" id="updateManagerAge" name="Age" min="18" max="120" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateManagerSex">Sex *</label>
                            <select id="updateManagerSex" name="Sex" required readonly class="readonly-field">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div class="form-group password-toggle">
                            <label for="updateManagerPassword">New Password (leave blank to keep current)</label>
                            <input type="password" id="updateManagerPassword" name="Password" placeholder="Enter new password">
                            <button type="button" class="toggle-password" onclick="togglePassword('updateManagerPassword')">👁️</button>
                            <span class="validation-hint">Min 6 chars: at least one letter, one number, and one special character</span>
                            <div class="field-error" id="updateManagerPasswordError"></div>
                        </div>
                        <div class="form-group password-toggle">
                            <label for="updateManagerConfirmPassword">Confirm New Password</label>
                            <input type="password" id="updateManagerConfirmPassword" placeholder="Confirm new password">
                            <button type="button" class="toggle-password" onclick="togglePassword('updateManagerConfirmPassword')">👁️</button>
                            <div class="field-error" id="updateManagerConfirmPasswordError"></div>
                        </div>
                        <button type="submit" class="submit-btn">Update Manager</button>
                    </form>
                </div>

                <!-- Delete Manager Form -->
                <div id="deleteManagerForm" class="form-section">
                    <h3>Delete Manager</h3>
                    <form id="deleteManagerFormElement">
                        <div class="form-group">
                            <label for="deleteManagerNationalId">Select Manager to Delete *</label>
                            <select id="deleteManagerNationalId" required>
                                <option value="">Select a manager</option>
                            </select>
                        </div>
                        <button type="submit" class="submit-btn" style="background: #DC143C;">Delete Manager</button>
                    </form>
                </div>

                <!-- Managers List -->
                <div class="managers-list">
                    <h3>Current Managers</h3>
                    <div id="managersContainer">
                        <!-- Managers will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Ethiopia regions data
        const ethiopiaRegions = [
            "Tigray", "Afar", "Amhara", "Oromia", "Somali", "Benishangul-Gumuz", 
            "Southern Nations, Nationalities, and Peoples' Region", "Gambela", 
            "Harari", "Addis Ababa", "Dire Dawa"
        ];

        // Global variables
        let allManagers = [];
        let managerFrontImageFile = null;
        let managerBackImageFile = null;
        let extractedManagerIDData = null;

        // ========== VALIDATION FUNCTIONS ==========
        
        function validatePhoneNumber(phone) {
            phone = phone.trim();
            
            // Remove any spaces or dashes
            phone = phone.replace(/[\s-]/g, '');
            
            // Check Ethiopian phone number patterns
            if (phone.startsWith('09') && phone.length === 10) {
                // 09XXXXXXXX - 10 digits total
                return /^09\d{8}$/.test(phone);
            } else if (phone.startsWith('251') && phone.length === 12) {
                // 251XXXXXXXXX - 12 digits total
                return /^251\d{9}$/.test(phone);
            } else if (phone.startsWith('+251') && phone.length === 13) {
                // +251XXXXXXXXX - 13 digits total
                return /^\+251\d{9}$/.test(phone);
            }
            return false;
        }

        function validateUsername(username) {
            if (!username || username.trim() === '') return true; // Optional field
            username = username.trim();
            // Only letters (A-Z, a-z), numbers, underscores, and hyphens allowed
            return /^[A-Za-z0-9_-]+$/.test(username);
        }

        function validateEmail(email) {
            if (!email || email.trim() === '') return true; // Optional field
            email = email.trim();
            // Must contain at least one letter, @@, and at least one number
            const hasLetter = /[A-Za-z]/.test(email);
            const hasAtSymbol = email.includes('@@');
            const hasNumber = /\d/.test(email);
            const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            
            return hasLetter && hasAtSymbol && hasNumber && emailPattern.test(email);
        }

        function validatePassword(password) {
            // Minimum length 6
            if (password.length < 6) return false;
            
            // At least one letter (A-Z or a-z)
            if (!/[A-Za-z]/.test(password)) return false;
            
            // At least one number (0-9)
            if (!/\d/.test(password)) return false;
            
            // At least one special character
            if (!/[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) return false;
            
            return true;
        }

