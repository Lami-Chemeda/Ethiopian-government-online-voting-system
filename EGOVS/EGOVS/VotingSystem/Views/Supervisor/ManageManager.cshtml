                    clearAllFieldErrors();
                    
                    // Reset file uploads
                    managerFrontImageFile = null;
                    managerBackImageFile = null;
                    extractedManagerIDData = null;
                    document.getElementById('managerFrontPreviewText').textContent = 'No file selected';
                    document.getElementById('managerBackPreviewText').textContent = 'No file selected';
                    document.getElementById('managerFrontPreviewImage').innerHTML = '';
                    document.getElementById('managerBackPreviewImage').innerHTML = '';
                    document.getElementById('managerFrontPreviewContainer').classList.remove('active');
                    document.getElementById('managerBackPreviewContainer').classList.remove('active');
                    
                    // Reload managers list
                    await loadManagersFromServer();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error creating manager:', error);
                showMessage('❌ Error creating manager: ' + error.message, false);
            }
        });

        // Update Manager functionality
        document.getElementById('updateManagerFormElement').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const nationalId = document.getElementById('updateManagerNationalId').value;
            const email = document.getElementById('updateManagerEmail').value.trim();
            const username = document.getElementById('updateManagerUsername').value.trim();
            const password = document.getElementById('updateManagerPassword').value;
            const confirmPassword = document.getElementById('updateManagerConfirmPassword').value;

            if (!nationalId) {
                showMessage('Please select a manager to update.', false);
                return;
            }

            // Email validation (optional)
            if (email && !validateEmail(email)) {
                showMessage('Email must contain at least one letter, @@ symbol, and at least one number (e.g., user123@@example.com)', false);
                return;
            }

            // Username validation (optional)
            if (username && !validateUsername(username)) {
                showMessage('Username can only contain letters (A-Z, a-z), numbers, underscores, and hyphens', false);
                return;
            }

            // Password validation (optional)
            if (password) {
                if (password !== confirmPassword) {
                    showMessage('Password and Confirm Password do not match.', false);
                    return;
                }

                if (!validatePassword(password)) {
                    showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                    return;
                }
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('Email', email);
                formData.append('Username', username);
                
                if (password) {
                    formData.append('Password', password);
                    formData.append('ConfirmPassword', confirmPassword);
                }

                const response = await fetch('/Supervisor/UpdateManager', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    // Reset password fields only
                    document.getElementById('updateManagerPassword').value = '';
                    document.getElementById('updateManagerConfirmPassword').value = '';
                    // Clear validation errors
                    clearFieldError('updateManagerPassword');
                    clearFieldError('updateManagerConfirmPassword');
                    await loadManagersFromServer();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error updating manager:', error);
                showMessage('❌ Error updating manager: ' + error.message, false);
            }
        });

        // Delete Manager functionality
        document.getElementById('deleteManagerFormElement').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const nationalId = document.getElementById('deleteManagerNationalId').value;

            if (!nationalId) {
                showMessage('Please select a manager to delete.', false);
                return;
            }

            // Get manager name for confirmation message
            const manager = allManagers.find(m => m.nationalId === nationalId);
            const managerName = manager ? manager.firstName + ' ' + manager.lastName : 'this manager';

            if (!confirm('Are you sure you want to permanently delete ' + managerName + '? This action cannot be undone.')) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);

                const response = await fetch('/Supervisor/DeleteManager', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    this.reset();
                    await loadManagersFromServer();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error deleting manager:', error);
                showMessage('❌ Error deleting manager: ' + error.message, false);
            }
        });

        // Toggle Manager Status
        async function toggleManagerStatus(nationalId, newStatus) {
            const action = newStatus ? 'activate' : 'deactivate';
            if (!confirm('Are you sure you want to ' + action + ' this manager?')) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('IsActive', newStatus.toString());

                const response = await fetch('/Supervisor/ToggleManagerStatus', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage(result.message, true);
                    await loadManagersFromServer();
                } else {
                    showMessage(result.message, false);
                }
            } catch (error) {
                console.error('Error updating manager status:', error);
                showMessage('Error updating manager status: ' + error.message, false);
            }
        }

        // Delete manager directly
        async function deleteManager(nationalId) {
            // Get manager name for confirmation message
            const manager = allManagers.find(m => m.nationalId === nationalId);
            const managerName = manager ? manager.firstName + ' ' + manager.lastName : 'this manager';

            if (!confirm('Are you sure you want to permanently delete ' + managerName + '? This action cannot be undone.')) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);

                const response = await fetch('/Supervisor/DeleteManager', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    showMessage(result.message, true);
                    await loadManagersFromServer();
                } else {
                    showMessage(result.message, false);
                }
            } catch (error) {
                console.error('Error deleting manager:', error);
                showMessage('Error deleting manager: ' + error.message, false);
            }
        }

        function editManager(nationalId) {
            showForm('updateManagerForm');
            document.getElementById('updateManagerNationalId').value = nationalId;
            loadManagerData(nationalId);
        }
    </script>
</body>
</html>