        function fillManagerFormWithIDData(data) {
            if (data.nationalId && data.nationalId.trim() !== '') {
                document.getElementById('managerNationalId').value = data.nationalId.trim();
                markManagerFieldAsExtractedFromOCR('NationalId');
            }
            if (data.firstName && data.firstName.trim() !== '') {
                document.getElementById('managerFirstName').value = data.firstName.trim();
                markManagerFieldAsExtractedFromOCR('FirstName');
            }
            if (data.middleName && data.middleName.trim() !== '') {
                document.getElementById('managerMiddleName').value = data.middleName.trim();
                markManagerFieldAsExtractedFromOCR('MiddleName');
            } else if (data.firstName && data.firstName.length > 0) {
                document.getElementById('managerMiddleName').value = data.firstName.charAt(0) + '.';
                markManagerFieldAsExtractedFromOCR('MiddleName');
            }
            if (data.lastName && data.lastName.trim() !== '') {
                document.getElementById('managerLastName').value = data.lastName.trim();
                markManagerFieldAsExtractedFromOCR('LastName');
            }
            if (data.phoneNumber && data.phoneNumber.trim() !== '') {
                const phone = data.phoneNumber.trim();
                document.getElementById('managerPhoneNumber').value = phone;
                if (validatePhoneNumber(phone)) {
                    markManagerFieldAsExtractedFromOCR('PhoneNumber');
                }
            }
            if (data.nationality && data.nationality.trim() !== '') {
                document.getElementById('managerNationality').value = data.nationality.trim();
                markManagerFieldAsExtractedFromOCR('Nationality');
            } else {
                document.getElementById('managerNationality').value = 'Ethiopian';
                markManagerFieldAsExtractedFromOCR('Nationality');
            }
            if (data.region && data.region.trim() !== '') {
                document.getElementById('managerRegion').value = data.region;
                markManagerFieldAsExtractedFromOCR('Region');
            }
            if (data.sex && data.sex.trim() !== '') {
                document.getElementById('managerSex').value = data.sex;
                markManagerFieldAsExtractedFromOCR('Sex');
            }
            if (data.age && data.age > 0) {
                document.getElementById('managerAge').value = data.age;
                markManagerFieldAsExtractedFromOCR('Age');
            } else if (data.dateOfBirth) {
                const age = calculateAgeFromDate(data.dateOfBirth);
                if (age > 0) {
                    document.getElementById('managerAge').value = age;
                    markManagerFieldAsExtractedFromOCR('Age');
                }
            }

            showMessage('✅ Manager ID information successfully extracted! Fields are now locked.', true);
        }

        async function extractManagerIDInformation() {
            if (!managerFrontImageFile && !managerBackImageFile) {
                showMessage('Please upload at least one ID image (front or back)', false);
                return;
            }

            try {
                showManagerOCRProcessing('🔍 Scanning Manager ID card...');

                const formData = new FormData();
                if (managerFrontImageFile) formData.append('FrontImage', managerFrontImageFile);
                if (managerBackImageFile) formData.append('BackImage', managerBackImageFile);

                const response = await fetch('/Home/ProcessIDPhotos', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error('HTTP error! status: ' + response.status);

                const result = await response.json();
                
                if (result.success) {
                    extractedManagerIDData = result.data;
                    showMessage('✅ ' + (result.message || 'Manager ID information extracted successfully!'), true);
                    fillManagerFormWithIDData(result.data);
                } else {
                    showMessage('❌ ' + (result.error || 'Failed to extract manager ID information'), false);
                }
                
            } catch (error) {
                showMessage('❌ Error scanning manager ID: ' + error.message, false);
            } finally {
                setTimeout(() => {
                    hideManagerOCRProcessing();
                }, 2000);
            }
        }

