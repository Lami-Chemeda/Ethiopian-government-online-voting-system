                            <option value="Female">Female</option>
                        </select>
                        <div class="field-status auto-filled" id="SexStatus" style="display: none;">Auto-filled from ID</div>
                    </div>
                </div>

                <div class="literate-section full-width">
                    <label class="required">Are you literate?</label>
                    <p style="font-size: 15px; color: #666; margin-bottom: 15px; text-align: center;">
                        <i class="fas fa-hand-pointer"></i> Please select your literacy status manually - this field cannot be auto-filled
                    </p>
                    <div class="literate-options">
                        <div class="literate-option literate-yes" onclick="selectLiterateOption('Yes')">
                            <input type="radio" id="Literate_Yes" name="Literate" value="Yes" required>
                            <div class="literate-icon"><i class="fas fa-check-circle"></i></div>
                            <label for="Literate_Yes">Yes, I can read and write</label>
                        </div>
                        <div class="literate-option literate-no" onclick="selectLiterateOption('No')">
                            <input type="radio" id="Literate_No" name="Literate" value="No">
                            <div class="literate-icon"><i class="fas fa-times-circle"></i></div>
                            <label for="Literate_No">No, I cannot read and write</label>
                        </div>
                    </div>
                    <div class="field-status manual" id="LiterateStatus" style="display: none;">Manual selection required</div>
                </div>

                <div class="image-password-section full-width" id="imagePasswordSection">
                    <label class="required">Image Password Selection</label>
                    <p style="font-size: 15px; color: #666; margin-bottom: 15px; text-align: center;">
                        <i class="fas fa-images"></i> Please select 4 images as your password. You will use these images to login.
                    </p>
                    
                    <div class="image-grid" id="imageGrid"></div>
                    
                    <div class="selected-images" id="selectedImages">
                        <h4>Selected Images: <span id="selectedCount">0</span>/4</h4>
                        <div class="selected-preview" id="selectedPreview"></div>
                    </div>
                    
                    <input type="hidden" id="ImagePassword" name="ImagePassword" />
                    <div class="field-status manual" id="ImagePasswordStatus">Manual selection required</div>
                </div>

                <div class="form-grid" id="textPasswordSection">
                    <div class="form-group">
                        <label for="Password" class="required">Password</label>
                        <input type="password" id="Password" name="Password" minlength="6" placeholder="Create a password (min. 6 characters)" required />
                    </div>

                    <div class="form-group">
                        <label for="ConfirmPassword" class="required">Confirm Password</label>
                        <input type="password" id="ConfirmPassword" name="ConfirmPassword" placeholder="Confirm your password" required />
                    </div>
                </div>

                <button type="submit" class="btn-primary full-width" id="submitBtn" style="margin-top: 20px;">
                    <i class="fas fa-user-plus"></i> Register as Voter
                </button>
                
                <div class="error" id="errorMessage"></div>
                <div class="success" id="successMessage"></div>
            </form>

            <div class="footer">
                <p>© 2024 Ethiopian Electronic Voting System. Ensuring secure and transparent elections.</p>
            </div>
