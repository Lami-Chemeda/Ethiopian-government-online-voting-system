                    </div>

                    <div class="form-group">
                        <label for="PhoneNumber" class="required">Phone Number</label>
                        <input type="tel" id="PhoneNumber" name="PhoneNumber" placeholder="+251 XXX XXX XXX" required />
                        <div class="field-status auto-filled" id="PhoneNumberStatus" style="display: none;">Auto-filled from ID</div>
                    </div>

                    <div class="form-group">
                        <label for="FirstName" class="required">First Name</label>
                        <input type="text" id="FirstName" name="FirstName" placeholder="Enter your first name" required />
                        <div class="field-status auto-filled" id="FirstNameStatus" style="display: none;">Auto-filled from ID</div>
                    </div>

                    <div class="form-group">
                        <label for="MiddleName" class="required">Middle Name</label>
                        <input type="text" id="MiddleName" name="MiddleName" placeholder="Enter your middle name" required />
                        <div class="field-status auto-filled" id="MiddleNameStatus" style="display: none;">Auto-filled from ID</div>
                    </div>

                    <div class="form-group">
                        <label for="LastName" class="required">Last Name</label>
                        <input type="text" id="LastName" name="LastName" placeholder="Enter your last name" required />
