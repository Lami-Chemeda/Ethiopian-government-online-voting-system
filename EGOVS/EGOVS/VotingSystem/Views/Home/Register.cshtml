                            <button type="button" class="upload-btn" onclick="document.getElementById('backIdUpload').click()">
                                <i class="fas fa-camera"></i> Choose Back Image
                            </button>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <button type="button" class="btn-success" id="extractInfoBtn">
                            <i class="fas fa-search"></i> Extract ID Information
                        </button>
                        <button type="button" class="btn-secondary" id="autoFillBtn">
                            <i class="fas fa-magic"></i> Auto-fill Form
