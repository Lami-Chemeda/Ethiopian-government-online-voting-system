                    <div class="id-preview-container">
                        <div class="id-preview" id="frontPreviewContainer">
                            <div><strong><i class="fas fa-id-card-alt"></i> Front Side</strong></div>
                            <div id="frontPreviewText">No file selected</div>
                            <div id="frontPreviewImage"></div>
