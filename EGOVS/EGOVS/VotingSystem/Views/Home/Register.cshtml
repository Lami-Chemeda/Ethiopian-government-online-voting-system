    <div class="processing-overlay" id="processingOverlay">
        <div class="processing-content">
            <h3 id="processingTitle">Processing Registration</h3>
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <p id="processingStatus">Please wait while we process your registration...</p>
            <div id="processingDetails"></div>
        </div>
    </div>

    <script>
        // Ethiopia regions data
        const ethiopiaRegions = [
            "Tigray", "Afar", "Amhara", "Oromia", "Somali", "Benishangul-Gumuz", 
            "Southern Nations, Nationalities, and Peoples' Region", "Gambela", 
            "Harari", "Addis Ababa", "Dire Dawa"
        ];

        // Image options for illiterate users
        const imageOptions = [
            { id: 1, name: "Globe", emoji: "🌍" },
            { id: 2, name: "Mountain", emoji: "🏔️" },
            { id: 3, name: "Coffee", emoji: "☕" },
            { id: 4, name: "Wheat", emoji: "🌾" },
            { id: 5, name: "Buffalo", emoji: "🐃" },
            { id: 6, name: "Lion", emoji: "🦁" },
            { id: 7, name: "Airplane", emoji: "✈️" },
            { id: 8, name: "Building", emoji: "🏛️" },
            { id: 9, name: "Scroll", emoji: "📜" },
            { id: 10, name: "Shield", emoji: "🔰" }
        ];

        // Global variables
        let frontImageFile = null;
        let backImageFile = null;
        let extractedIDData = null;
        let selectedImages = [];
        let isLiterate = null;

        // NEW: Ethiopian Phone Number Validation Function
        function validateEthiopianPhoneNumber(phone) {
            if (!phone) return false;
            
            // Remove all spaces, dashes, and parentheses
            const cleaned = phone.replace(/[\s\-()]/g, '');
            
            // Check different formats
            if (cleaned.startsWith('09')) {
                // Format: 09XXXXXXXXX (10 digits total)
                return cleaned.length === 10 && /^09\d{8}$/.test(cleaned);
            } else if (cleaned.startsWith('+251')) {
                // Format: +251XXXXXXXXX (13 digits with +, 9 digits after country code)
                return cleaned.length === 13 && /^\+251\d{9}$/.test(cleaned);
            } else if (cleaned.startsWith('251')) {
                // Format: 251XXXXXXXXX (12 digits total)
                return cleaned.length === 12 && /^251\d{9}$/.test(cleaned);
            }
            
            return false;
        }

        // NEW: Password Validation Function
        function validatePasswordComplexity(password) {
            if (!password) return { isValid: false, message: "Password is required" };
            
            // Minimum length check
            if (password.length < 6) {
                return {
                    isValid: false,
                    message: "Password must be at least 6 characters long"
                };
            }
            
            // At least one letter check
            if (!/[a-zA-Z]/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one letter (A-Z or a-z)"
                };
            }
            
            // At least one number check
            if (!/\d/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one number (0-9)"
                };
            }
            
            // At least one special character check
            if (!/[!@@#$%^&*]/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one special character (!@@#$%^&* etc.)"
                };
            }
            
            return {
                isValid: true,
                message: "Password is valid"
            };
        }

        // DOM Ready
        document.addEventListener('DOMContentLoaded', function() {
            initializeApp();
        });

        function initializeApp() {
            try {
                populateRegions();
                setupEventListeners();
                console.log('Voter Registration Application initialized successfully');
            } catch (error) {
                console.error('Failed to initialize application:', error);
            }
        }

        function goBackToHome() {
            console.log('Back to Home button clicked');
            window.location.href = '/';
        }

        function setupEventListeners() {
            // File upload events
            const frontUpload = document.getElementById('frontIdUpload');
            if (frontUpload) {
                frontUpload.addEventListener('change', function(e) {
                    handleFileUpload(e, 'front');
                });
            }

            const backUpload = document.getElementById('backIdUpload');
            if (backUpload) {
                backUpload.addEventListener('change', function(e) {
                    handleFileUpload(e, 'back');
                });
            }

            // Extract ID Information button
            const extractBtn = document.getElementById('extractInfoBtn');
            if (extractBtn) {
                extractBtn.addEventListener('click', extractIDInformation);
            }

            // Auto-fill Form button
            const autoFillBtn = document.getElementById('autoFillBtn');
            if (autoFillBtn) {
                autoFillBtn.addEventListener('click', autoFillForm);
            }

            // Form submission
            const form = document.getElementById('registrationForm');
            if (form) {
                form.addEventListener('submit', handleFormSubmission);
            }

            // NEW: Phone number validation on blur
            const phoneInput = document.getElementById('PhoneNumber');
            if (phoneInput) {
                phoneInput.addEventListener('blur', validatePhoneNumberOnBlur);
                phoneInput.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                });
            }

            // NEW: Password validation on blur
            const passwordInput = document.getElementById('Password');
            if (passwordInput) {
                passwordInput.addEventListener('blur', validatePasswordOnBlur);
                passwordInput.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                });
            }

            // Password confirmation validation
            const confirmPassword = document.getElementById('ConfirmPassword');
            if (confirmPassword) {
                confirmPassword.addEventListener('input', validatePasswordConfirmation);
            }

            // National ID validation
            const nationalIdField = document.getElementById('NationalId');
            if (nationalIdField) {
                nationalIdField.addEventListener('blur', async function() {
                    const nationalId = this.value.trim();
                    if (nationalId && nationalId.length >= 5) {
                        const result = await checkNationalIdExists(nationalId);
                        if (result.exists) {
                            showError(result.message);
                            this.classList.add('error-field');
                            
                            const existingError = this.parentNode.querySelector('.field-detail-error');
                            if (existingError) existingError.remove();
                            
                            const detailError = document.createElement('div');
                            detailError.className = 'field-detail-error';
                            detailError.textContent = result.message;
                            this.parentNode.appendChild(detailError);
                        } else {
                            this.classList.remove('error-field');
                            hideMessages();
                            
                            const existingError = this.parentNode.querySelector('.field-detail-error');
                            if (existingError) existingError.remove();
                        }
                    }
                });

                nationalIdField.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                    hideMessages();
                });
            }
        }

        // NEW: Phone number validation on blur
        function validatePhoneNumberOnBlur() {
            const phoneValue = this.value.trim();
            if (!phoneValue) return true;
            
            const isValid = validateEthiopianPhoneNumber(phoneValue);
            
            if (!isValid) {
                this.classList.add('error-field');
                const existingError = this.parentNode.querySelector('.field-detail-error');
                if (existingError) existingError.remove();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = 'Invalid phone number format. Valid formats: 09XXXXXXXX, +251XXXXXXXXX, 251XXXXXXXXX';
                this.parentNode.appendChild(detailError);
                return false;
            }
            
            this.classList.remove('error-field');
            const existingError = this.parentNode.querySelector('.field-detail-error');
            if (existingError) existingError.remove();
            return true;
        }

        // NEW: Password validation on blur
        function validatePasswordOnBlur() {
            const passwordValue = this.value;
            if (!passwordValue) return true;
            
            const validation = validatePasswordComplexity(passwordValue);
            
            if (!validation.isValid) {
                this.classList.add('error-field');
                const existingError = this.parentNode.querySelector('.field-detail-error');
                if (existingError) existingError.remove();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = validation.message;
                this.parentNode.appendChild(detailError);
                return false;
            }
            
            this.classList.remove('error-field');
            const existingError = this.parentNode.querySelector('.field-detail-error');
            if (existingError) existingError.remove();
            return true;
        }

        function handleFileUpload(event, side) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateImageFile(file)) {
                showError('Please select a valid image file (JPG, PNG, BMP) under 5MB');
                event.target.value = '';
                return;
            }

            if (side === 'front') {
                frontImageFile = file;
            } else {
                backImageFile = file;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageData = e.target.result;
                updatePreview(side, imageData, file.name);
            };
            reader.readAsDataURL(file);
        }

        function validateImageFile(file) {
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/bmp'];
            const maxSize = 5 * 1024 * 1024;
            return allowedTypes.includes(file.type) && file.size <= maxSize;
        }

        function updatePreview(side, imageData, fileName) {
            const container = document.getElementById(side + 'PreviewContainer');
            const textElement = document.getElementById(side + 'PreviewText');
            const imageElement = document.getElementById(side + 'PreviewImage');

            if (container && textElement && imageElement) {
                container.classList.add('active');
                textElement.textContent = fileName;
                textElement.style.color = '#28a745';
                textElement.style.fontWeight = 'bold';
                imageElement.innerHTML = '<img src="' + imageData + '" alt="' + side + ' side preview" style="max-width: 120px; max-height: 90px; border-radius: 6px;">';
            }
        }

        async function extractIDInformation() {
            if (!frontImageFile && !backImageFile) {
                showError('Please upload at least one ID image (front or back)');
                return;
            }

            try {
                showOCRProcessing('🔍 Scanning Ethiopian ID card...');

                const formData = new FormData();
                if (frontImageFile) formData.append('FrontImage', frontImageFile);
                if (backImageFile) formData.append('BackImage', backImageFile);

                const response = await fetch('/Home/ProcessIDPhotos', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error('HTTP error! status: ' + response.status);

                const result = await response.json();
                
                if (result.success) {
                    extractedIDData = result.data;
                    showSuccess('✅ ' + (result.message || 'ID information extracted successfully!'));
                    fillFormWithIDData(result.data);
                } else {
                    showError('❌ ' + (result.error || 'Failed to extract ID information'));
                }
                
            } catch (error) {
                console.error('Ethiopian ID scanning error:', error);
                showError('❌ Error scanning ID: ' + error.message);
            } finally {
                setTimeout(() => {
                    hideOCRProcessing();
                }, 2000);
            }
        }

        function showOCRProcessing(message) {
            const ocrProcessing = document.getElementById('ocrProcessing');
            if (ocrProcessing) {
                ocrProcessing.innerHTML = '<div style="text-align: center; padding: 15px;"><div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 10px;"><div class="spinner-border spinner-border-sm" role="status" style="color: #1d3557;"></div><span style="font-weight: bold; color: #1d3557;">' + message + '</span></div></div>';
                ocrProcessing.style.display = 'block';
            }
        }

        function hideOCRProcessing() {
            const ocrProcessing = document.getElementById('ocrProcessing');
            if (ocrProcessing) {
                ocrProcessing.style.display = 'none';
            }
        }

        function fillFormWithIDData(data) {
            console.log('🎯 Filling form with Ethiopian ID data:', data);
            
            // Validate and fill phone number
            if (data.phoneNumber && data.phoneNumber.trim() !== '') {
                const phoneValue = data.phoneNumber.trim();
                if (validateEthiopianPhoneNumber(phoneValue)) {
                    document.getElementById('PhoneNumber').value = phoneValue;
                    markFieldAsExtractedFromOCR('PhoneNumber');
                } else {
                    // Show warning for invalid phone number but still fill it
                    document.getElementById('PhoneNumber').value = phoneValue;
                    showError('Extracted phone number format is invalid. Please correct it.');
                }
            }
            
            // Fill other fields
            if (data.nationalId && data.nationalId.trim() !== '') {
                document.getElementById('NationalId').value = data.nationalId.trim();
                markFieldAsExtractedFromOCR('NationalId');
            }
            if (data.firstName && data.firstName.trim() !== '') {
                document.getElementById('FirstName').value = data.firstName.trim();
                markFieldAsExtractedFromOCR('FirstName');
            }
            if (data.middleName && data.middleName.trim() !== '') {
                document.getElementById('MiddleName').value = data.middleName.trim();
                markFieldAsExtractedFromOCR('MiddleName');
            }
            if (data.lastName && data.lastName.trim() !== '') {
                document.getElementById('LastName').value = data.lastName.trim();
                markFieldAsExtractedFromOCR('LastName');
            }
            if (data.nationality && data.nationality.trim() !== '') {
                document.getElementById('Nationality').value = data.nationality.trim();
                markFieldAsExtractedFromOCR('Nationality');
            } else {
                document.getElementById('Nationality').value = 'Ethiopian';
                markFieldAsExtractedFromOCR('Nationality');
            }
            if (data.region && data.region.trim() !== '') {
                document.getElementById('Region').value = data.region;
                markFieldAsExtractedFromOCR('Region');
            }
            if (data.sex && data.sex.trim() !== '') {
                document.getElementById('Sex').value = data.sex;
                markFieldAsExtractedFromOCR('Sex');
            }
            if (data.age && data.age > 0) {
                document.getElementById('Age').value = data.age;
                markFieldAsExtractedFromOCR('Age');
            }

            showSuccess('✅ ID information successfully extracted! Fields are now locked.');
        }

        function markFieldAsExtractedFromOCR(fieldId) {
            const field = document.getElementById(fieldId);
            const statusElement = document.getElementById(fieldId + 'Status');
            
            if (field) {
                field.classList.add('extracted-field');
                field.readOnly = true;
                
                if (statusElement) {
                    statusElement.style.display = 'inline-block';
                    statusElement.textContent = 'Auto-filled from ID';
                    statusElement.className = 'field-status auto-filled';
                }
            }
        }

        function autoFillForm() {
            if (!extractedIDData) {
                showError('❌ Please extract ID information first by clicking "Extract ID Information"');
                return;
            }
            fillFormWithIDData(extractedIDData);
            showSuccess('✅ ID data displayed on form! Fields are now locked.');
        }

        function selectLiterateOption(literateValue) {
            isLiterate = literateValue;
            
            document.querySelectorAll('.literate-option').forEach(option => {
                option.classList.remove('selected');
            });
            
            const clickedOption = event.currentTarget;
            clickedOption.classList.add('selected');
            
            const radioButton = clickedOption.querySelector('input[type="radio"]');
            radioButton.checked = true;
            
            const statusElement = document.getElementById('LiterateStatus');
            if (statusElement) {
                statusElement.style.display = 'inline-block';
                statusElement.textContent = 'Manually selected';
                statusElement.className = 'field-status manual';
            }
            
            handlePasswordType(literateValue === 'Yes');
            
            console.log('Literate option selected:', literateValue);
        }

        function handlePasswordType(literate) {
            const textPasswordSection = document.getElementById('textPasswordSection');
            const imagePasswordSection = document.getElementById('imagePasswordSection');
            const passwordField = document.getElementById('Password');
            const confirmPasswordField = document.getElementById('ConfirmPassword');
            
            if (literate) {
                if (textPasswordSection) textPasswordSection.style.display = 'grid';
                if (imagePasswordSection) imagePasswordSection.style.display = 'none';
                
                if (passwordField) passwordField.required = true;
                if (confirmPasswordField) confirmPasswordField.required = true;
                
                selectedImages = [];
                updateSelectedImagesDisplay();
                
            } else {
                if (textPasswordSection) textPasswordSection.style.display = 'none';
                if (imagePasswordSection) imagePasswordSection.style.display = 'block';
                
                if (passwordField) passwordField.required = false;
                if (confirmPasswordField) confirmPasswordField.required = false;
                
                if (document.getElementById('imageGrid').children.length === 0) {
                    loadImageOptions();
                }
            }
        }

        function loadImageOptions() {
            const imageGrid = document.getElementById('imageGrid');
            imageGrid.innerHTML = '';
            
            imageOptions.forEach((image) => {
                const imageOption = document.createElement('div');
                imageOption.className = 'image-option';
                imageOption.innerHTML = '<div class="emoji-image">' + image.emoji + '</div><div class="image-name">' + image.name + '</div>';
                imageOption.onclick = function() {
                    selectImage(image.id, imageOption);
                };
                imageGrid.appendChild(imageOption);
            });
        }

        function selectImage(imageId, element) {
            const index = selectedImages.indexOf(imageId);
            
            if (index === -1) {
                if (selectedImages.length < 4) {
                    selectedImages.push(imageId);
                    element.classList.add('selected');
                } else {
                    showError('You can only select 4 images for your password.');
                    return;
                }
            } else {
                selectedImages.splice(index, 1);
                element.classList.remove('selected');
            }
            
            updateSelectedImagesDisplay();
        }

        function updateSelectedImagesDisplay() {
            const selectedCount = document.getElementById('selectedCount');
            const selectedPreview = document.getElementById('selectedPreview');
            const imagePasswordField = document.getElementById('ImagePassword');
            
            if (selectedCount) selectedCount.textContent = selectedImages.length;
            
            if (selectedPreview) {
                selectedPreview.innerHTML = '';
                
                selectedImages.forEach(imageId => {
                    const image = imageOptions.find(img => img.id === imageId);
                    if (image) {
                        const selectedImage = document.createElement('div');
                        selectedImage.className = 'selected-image';
                        selectedImage.innerHTML = '<div class="emoji-image">' + image.emoji + '</div><div class="image-name">' + image.name + '</div>';
                        selectedPreview.appendChild(selectedImage);
                    }
                });
            }
            
            if (imagePasswordField) {
                imagePasswordField.value = selectedImages.join(',');
            }
        }

        function validatePasswordConfirmation() {
            const password = document.getElementById('Password');
            const confirmPassword = document.getElementById('ConfirmPassword');
            const errorDiv = document.getElementById('errorMessage');
            
            if (!password || !confirmPassword || !errorDiv) return true;
            
            if (confirmPassword.value && password.value !== confirmPassword.value) {
                errorDiv.textContent = 'Passwords do not match!';
                errorDiv.style.display = 'block';
                return false;
            } else {
                errorDiv.style.display = 'none';
                return true;
            }
        }

        async function validateFormBeforeSubmit() {
            const nationalId = document.getElementById('NationalId').value.trim();
            const password = document.getElementById('Password').value;
            const confirmPassword = document.getElementById('ConfirmPassword').value;
            const firstName = document.getElementById('FirstName').value.trim();
            const lastName = document.getElementById('LastName').value.trim();
            const phoneNumber = document.getElementById('PhoneNumber').value.trim();
            const age = document.getElementById('Age').value;
            const nationality = document.getElementById('Nationality').value;
            const region = document.getElementById('Region').value;
            const sex = document.getElementById('Sex').value;
            const literate = document.querySelector('input[name="Literate"]:checked');
            
            hideMessages();
            
            // Clear previous field errors
            document.querySelectorAll('.error-field').forEach(field => {
                field.classList.remove('error-field');
            });
            document.querySelectorAll('.field-detail-error').forEach(error => {
                error.remove();
            });
            
            if (!nationalId) {
                showError('National ID is required');
                document.getElementById('NationalId').focus();
                return false;
            }
            
            if (nationalId.length < 5) {
                showError('National ID must be at least 5 characters long');
                document.getElementById('NationalId').focus();
                return false;
            }
            
            // Final duplicate check before submission
            const duplicateCheck = await checkNationalIdExists(nationalId);
            if (duplicateCheck.exists) {
                showError(duplicateCheck.message);
                document.getElementById('NationalId').classList.add('error-field');
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = duplicateCheck.message;
                document.getElementById('NationalId').parentNode.appendChild(detailError);
                
                document.getElementById('NationalId').focus();
                return false;
            }
            
            if (!firstName) {
                showError('First name is required');
                document.getElementById('FirstName').focus();
                return false;
            }
            
            if (!lastName) {
                showError('Last name is required');
                document.getElementById('LastName').focus();
                return false;
            }
            
            if (!phoneNumber) {
                showError('Phone number is required');
                document.getElementById('PhoneNumber').focus();
                return false;
            }
            
            // Phone number validation
            if (!validateEthiopianPhoneNumber(phoneNumber)) {
                showError('Invalid phone number format. Valid formats: 09XXXXXXXX, +251XXXXXXXXX, 251XXXXXXXXX');
                document.getElementById('PhoneNumber').classList.add('error-field');
                document.getElementById('PhoneNumber').focus();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = 'Examples: 0911223344, 251911223344, +251911223344';
                document.getElementById('PhoneNumber').parentNode.appendChild(detailError);
                return false;
            }
            
            if (!age || age < 18 || age > 120) {
                showError('Age must be between 18 and 120 years');
                document.getElementById('Age').focus();
                return false;
            }
            
            if (!nationality) {
                showError('Nationality is required');
                document.getElementById('Nationality').focus();
                return false;
            }
            
            if (!region) {
                showError('Region is required');
                document.getElementById('Region').focus();
                return false;
            }
            
            if (!sex) {
                showError('Sex is required');
                document.getElementById('Sex').focus();
                return false;
            }
            
            if (!literate) {
                showError('Please select your literacy status');
                return false;
            }
            
            const literateValue = literate.value;
            
            if (literateValue === 'Yes') {
                // Password complexity validation
                if (!password) {
                    showError('Password is required');
                    document.getElementById('Password').focus();
                    return false;
                }
                
                const passwordValidation = validatePasswordComplexity(password);
                if (!passwordValidation.isValid) {
                    showError(passwordValidation.message);
                    document.getElementById('Password').classList.add('error-field');
                    document.getElementById('Password').focus();
                    
                    const detailError = document.createElement('div');
                    detailError.className = 'field-detail-error';
                    detailError.textContent = passwordValidation.message;
                    document.getElementById('Password').parentNode.appendChild(detailError);
                    return false;
                }
                
                if (password !== confirmPassword) {
                    showError('Passwords do not match');
                    document.getElementById('ConfirmPassword').focus();
                    return false;
                }
            } else {
                if (selectedImages.length !== 4) {
                    showError('Please select exactly 4 images for your password');
                    return false;
                }
            }
            
            return true;
        }

        function hideMessages() {
            const errorDiv = document.getElementById('errorMessage');
            const successDiv = document.getElementById('successMessage');
            
            if (errorDiv) errorDiv.style.display = 'none';
            if (successDiv) successDiv.style.display = 'none';
        }

        function resetForm() {
            const form = document.getElementById('registrationForm');
            
            form.reset();
            
            document.getElementById('frontPreviewText').textContent = 'No file selected';
            document.getElementById('frontPreviewImage').innerHTML = '';
            document.getElementById('frontPreviewContainer').classList.remove('active');
            document.getElementById('backPreviewText').textContent = 'No file selected';
            document.getElementById('backPreviewImage').innerHTML = '';
            document.getElementById('backPreviewContainer').classList.remove('active');
            
            frontImageFile = null;
            backImageFile = null;
            extractedIDData = null;
            selectedImages = [];
            isLiterate = null;
            
            populateRegions();
            
            document.getElementById('debugInfo').style.display = 'none';
            
            document.querySelectorAll('.field-status').forEach(status => {
                status.style.display = 'none';
            });
            
            document.querySelectorAll('.extracted-field').forEach(field => {
                field.classList.remove('extracted-field');
                field.readOnly = false;
            });
            
            document.querySelectorAll('.literate-option').forEach(option => {
                option.classList.remove('selected');
            });
            
            document.querySelectorAll('.image-option').forEach(option => {
                option.classList.remove('selected');
            });
            document.getElementById('selectedPreview').innerHTML = '';
            document.getElementById('selectedCount').textContent = '0';
            document.getElementById('ImagePassword').value = '';
            
            document.getElementById('textPasswordSection').style.display = 'grid';
            document.getElementById('imagePasswordSection').style.display = 'none';
            
            document.querySelectorAll('.error-field').forEach(field => {
                field.classList.remove('error-field');
            });
            
            document.querySelectorAll('.field-detail-error').forEach(error => {
                error.remove();
            });
            
            setTimeout(() => {
                hideMessages();
            }, 5000);
        }

        function showError(message) {
            const errorDiv = document.getElementById('errorMessage');
            const successDiv = document.getElementById('successMessage');
            
            if (errorDiv) {
                errorDiv.innerHTML = message;
                errorDiv.style.display = 'block';
                errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            if (successDiv) {
                successDiv.style.display = 'none';
            }
            
            console.error('Registration Error:', message);
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('successMessage');
            const errorDiv = document.getElementById('errorMessage');
            
            if (successDiv) {
                successDiv.innerHTML = message;
                successDiv.style.display = 'block';
                successDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            if (errorDiv) {
                errorDiv.style.display = 'none';
            }
            
            console.log('Registration Success:', message);
        }

        function populateRegions() {
            const regionSelect = document.getElementById('Region');
            if (!regionSelect) return;
            
            regionSelect.innerHTML = '<option value="" disabled selected>Select Region</option>';
            
            ethiopiaRegions.forEach(region => {
                const option = document.createElement('option');
                option.value = region;
                option.textContent = region;
                regionSelect.appendChild(option);
            });
        }

        function showProcessingOverlay(title, message) {
            const overlay = document.getElementById('processingOverlay');
            const titleElement = document.getElementById('processingTitle');
            const statusElement = document.getElementById('processingStatus');
            
            if (overlay && titleElement && statusElement) {
                titleElement.textContent = title;
                statusElement.textContent = message;
                overlay.style.display = 'flex';
            }
        }

        function hideProcessingOverlay() {
            const overlay = document.getElementById('processingOverlay');
            if (overlay) {
                overlay.style.display = 'none';
            }
        }

        async function checkNationalIdExists(nationalId) {
            try {
                const response = await fetch('/Home/CheckNationalId?nationalId=' + encodeURIComponent(nationalId));
                const result = await response.json();
                return result;
            } catch (error) {
                console.error('Error checking National ID:', error);
                return { exists: false, message: 'Error checking National ID availability.' };
            }
        }

        function redirectToLogin() {
            window.location.href = '/Home/Login';
        }

        function registerAnother() {
            const successSection = document.getElementById('successRegistration');
            const registrationForm = document.getElementById('registrationForm');
            
            if (successSection && registrationForm) {
                successSection.style.display = 'none';
                registrationForm.style.display = 'block';
                resetForm();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        async function handleFormSubmission(event) {
            event.preventDefault();
            
            if (!await validateFormBeforeSubmit()) {
                return;
            }
            
            showProcessingOverlay('Voter Registration', 'Processing your registration...');
            
            try {
                const form = event.target;
                const formData = new FormData(form);
                
                const literate = document.querySelector('input[name="Literate"]:checked').value;
                if (literate === 'No') {
                    formData.set('ImagePassword', selectedImages.join(','));
                    formData.set('Password', 'default_visual_password');
                    formData.set('ConfirmPassword', 'default_visual_password');
                } else {
                    formData.set('ImagePassword', '');
                }
                
                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Registering...';
                
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });
                
                const responseText = await response.text();
                
                if (response.ok) {
                    hideProcessingOverlay();
                    showSuccess('✅ Registration successful! Voter has been registered in the system.');
                    resetForm();
                } else {
                    hideProcessingOverlay();
                    let errorMessage = 'Registration failed. Please try again.';
                    
                    if (responseText.includes('already registered')) {
                        errorMessage = 'This National ID is already registered in the system.';
                    } else if (response.status === 500) {
                        errorMessage = 'Server error occurred. Please try again later.';
                    }
                    
                    showError('❌ ' + errorMessage);
                    
                    if (responseText.includes('National ID')) {
                        document.getElementById('NationalId').classList.add('error-field');
                        document.getElementById('NationalId').focus();
                    }
                }
                
            } catch (error) {
                console.error('Form submission error:', error);
                hideProcessingOverlay();
                
                if (error.message.includes('NetworkError') || error.message.includes('Failed to fetch')) {
                    showError('❌ Network error: Please check your internet connection and try again.');
                } else if (error.message.includes('already exists') || error.message.includes('duplicate') || error.message.includes('already registered')) {
                    showError('❌ This National ID is already registered. Please use a different National ID.');
                    document.getElementById('NationalId').classList.add('error-field');
                    document.getElementById('NationalId').focus();
                } else {
                    showError('❌ Error: ' + error.message);
                }
                
            } finally {
                const submitBtn = document.getElementById('submitBtn');
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-user-plus"></i> Register as Voter';
                }
            }
        }
    </script>
</body>
</html>