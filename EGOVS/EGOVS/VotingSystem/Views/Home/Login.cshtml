@{
    ViewData["Title"] = "Login Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - EGOVS</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 50%, #a8dadc 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow-x: hidden;
        }

        .container {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 500px;
            margin: 20px;
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #1d3557, #457b9d);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            color: white;
            font-size: 36px;
        }

        h1 {
            text-align: center;
            color: #1d3557;
            margin-bottom: 10px;
            font-size: 28px;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 16px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            color: #333;
        }

        input {
            width: 100%;
            padding: 15px;
            border-radius: 10px;
            border: 2px solid #ddd;
            outline: none;
            background-color: #f8f9fa;
            font-size: 16px;
        }

        input:focus {
            border-color: #457b9d;
        }

        input.valid {
            border-color: #28a745;
        }

        input.invalid {
            border-color: #dc3545;
        }

        .login-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #457b9d, #1d3557);
            border: none;
            color: white;
            font-size: 18px;
            font-weight: 600;
            border-radius: 10px;
            cursor: pointer;
            margin-top: 10px;
        }

        .login-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #1d3557, #457b9d);
        }

        .login-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .action-buttons {
            margin: 25px 0;
        }

        .action-btn {
            display: block;
            width: 100%;
            padding: 20px;
            margin: 15px 0;
            border: none;
            border-radius: 10px;
            font-size: 20px;
            font-weight: 700;
            text-decoration: none;
            text-align: center;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
        }

        /* Changed: Yellow background for Forgot Password button */
        .forgot-password-btn {
            background: linear-gradient(135deg, #ffc107, #e0a800);
        }

        .forgot-password-btn:hover {
            background: linear-gradient(135deg, #e0a800, #d39e00);
            transform: translateY(-2px);
        }

        .visual-login-btn {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }

        .visual-login-btn:hover {
            background: linear-gradient(135deg, #c0392b, #e74c3c);
            transform: translateY(-2px);
        }

        .divider {
            text-align: center;
            margin: 20px 0;
            color: #666;
            font-weight: 600;
        }

        /* Removed: Demo credentials section styles */

        /* Updated: Register link with increased text size and background */
        .register-link {
            text-align: center;
            margin-top: 20px;
            padding: 20px;
            border-top: 1px solid #eee;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .register-link p {
            font-size: 18px;
            margin-bottom: 0;
            font-weight: 600;
            color: #1d3557;
        }

        .register-link a {
            font-size: 18px;
            font-weight: 700;
            color: #457b9d;
            text-decoration: none;
            transition: all 0.3s;
            padding: 5px 15px;
            border-radius: 5px;
            background: white;
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.1);
        }

        .register-link a:hover {
            color: #1d3557;
            background: #f8f9fa;
            transform: translateY(-2px);
            box-shadow: 0 5px 12px rgba(0, 0, 0, 0.15);
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: #1d3557;
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            text-decoration: none;
        }

        /* Message Styles */
        .message-container {
            margin-bottom: 20px;
        }

        .alert {
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideIn 0.3s ease-out;
        }

        .alert-success {
            background: linear-gradient(135deg, #d4edda, #c3e6cb);
            border: 2px solid #28a745;
            color: #155724;
        }

        .alert-error {
            background: linear-gradient(135deg, #f8d7da, #f5c6cb);
            border: 2px solid #dc3545;
            color: #721c24;
        }

        .alert-warning {
            background: linear-gradient(135deg, #fff3cd, #ffeaa7);
            border: 2px solid #ffc107;
            color: #856404;
        }

        .alert-info {
            background: linear-gradient(135deg, #d1ecf1, #bee5eb);
            border: 2px solid #17a2b8;
            color: #0c5460;
        }

        .alert-icon {
            font-size: 20px;
        }

        .close-btn {
            margin-left: auto;
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            color: inherit;
            opacity: 0.7;
        }

        .close-btn:hover {
            opacity: 1;
        }

        /* Validation message styles */
        .validation-message {
            font-size: 14px;
            margin-top: 5px;
            padding: 5px 10px;
            border-radius: 5px;
            display: none;
            animation: fadeIn 0.3s ease-out;
        }

        .validation-error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .validation-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .requirements-list {
            margin-top: 5px;
            padding-left: 20px;
            font-size: 14px;
            color: #6c757d;
        }

        .requirement {
            margin-bottom: 3px;
        }

        .requirement.valid {
            color: #28a745;
        }

        .requirement.invalid {
            color: #dc3545;
        }

        .requirement i {
            margin-right: 5px;
        }

        /* Password toggle eye icon */
        .password-wrapper {
            position: relative;
            width: 100%;
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
            font-size: 18px;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s;
        }

        .password-toggle:hover {
            background-color: rgba(0, 0, 0, 0.05);
            color: #1d3557;
        }

        .password-toggle:focus {
            outline: none;
            background-color: rgba(69, 123, 157, 0.1);
        }

        .password-wrapper input {
            padding-right: 50px; /* Make space for the eye icon */
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .loading-spinner {
            background: white;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Logging in...</p>
        </div>
    </div>

    <a class="back-btn" href="/Home/Index">
        <i class="fas fa-arrow-left"></i> Back
    </a>

    <div class="container">
        <div class="logo-section">
            <div class="logo">
                <i class="fas fa-vote-yea"></i>
            </div>
            <h1>EGOVS Login</h1>
            <p class="subtitle">Ethiopian Government Online Voting System</p>
        </div>

        <!-- Message Container -->
        <div class="message-container" id="messageContainer">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle alert-icon"></i>
                    <span>@TempData["SuccessMessage"]</span>
                    <button class="close-btn" onclick="this.parentElement.style.display='none'">×</button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-triangle alert-icon"></i>
                    <span>@TempData["ErrorMessage"]</span>
                    <button class="close-btn" onclick="this.parentElement.style.display='none'">×</button>
                </div>
            }
        </div>

        <!-- Login Form -->
        <form id="loginForm" method="post" asp-action="Login" asp-controller="Home">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label for="username">
                    <i class="fas fa-id-card"></i> National ID
                </label>
                <input type="text" id="username" name="username" placeholder="Enter 15-17 digit National ID" required 
                       value="@TempData["LastUsername"]" maxlength="17" inputmode="numeric">
                <div id="nationalIdError" class="validation-message validation-error">
                    <i class="fas fa-exclamation-circle"></i> National ID must be 15 to 17 digits only
                </div>
            </div>

            <div class="form-group">
                <label for="password">
                    <i class="fas fa-lock"></i> Password
                </label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" placeholder="Enter your password" required>
                    <button type="button" class="password-toggle" id="passwordToggle" aria-label="Show password">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div id="passwordError" class="validation-message validation-error">
                    <i class="fas fa-exclamation-circle"></i> Password must contain:
                    <ul class="requirements-list">
                        <li id="reqLetter" class="requirement invalid">
                            <i class="fas fa-times"></i> At least one letter (A-Z or a-z)
                        </li>
                        <li id="reqNumber" class="requirement invalid">
                            <i class="fas fa-times"></i> At least one number (0-9)
                        </li>
                        <li id="reqSpecial" class="requirement invalid">
                            <i class="fas fa-times"></i> At least one special character (!@@#$%^&* etc.)
                        </li>
                    </ul>
                </div>
            </div>

            <button type="submit" class="login-btn" id="loginButton" disabled>
                <i class="fas fa-sign-in-alt"></i> LOGIN TO SYSTEM
            </button>
        </form>

        <!-- Action Buttons - SIMPLE AND VISIBLE -->
        <div class="action-buttons">
            <a href="/Home/ForgotPassword" class="action-btn forgot-password-btn">
                <i class="fas fa-key"></i> 
                🔑 FORGOT PASSWORD? 🔑
            </a>

            <div class="divider">OR</div>

            <a href="@Url.Action("VisualLogin", "Home")" class="action-btn visual-login-btn">
                🎯 VISUAL LOGIN FOR ILLITERATE VOTERS 👁️
            </a>
        </div>

        <!-- Removed: Demo credentials section -->

        <!-- Updated: Register link with increased text size and background -->
        <div class="register-link">
            <p>New user? <a href="/Home/Register">Register here</a></p>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loginForm = document.getElementById('loginForm');
            const loginButton = document.getElementById('loginButton');
            const loadingOverlay = document.getElementById('loadingOverlay');
            const messageContainer = document.getElementById('messageContainer');
            const usernameInput = document.getElementById('username');
            const passwordInput = document.getElementById('password');
            const passwordToggle = document.getElementById('passwordToggle');
            const nationalIdError = document.getElementById('nationalIdError');
            const passwordError = document.getElementById('passwordError');
            
            // Password requirement elements
            const reqLetter = document.getElementById('reqLetter');
            const reqNumber = document.getElementById('reqNumber');
            const reqSpecial = document.getElementById('reqSpecial');

            // Toggle password visibility
            passwordToggle.addEventListener('click', function() {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                
                // Toggle eye icon
                const eyeIcon = this.querySelector('i');
                if (type === 'text') {
                    eyeIcon.classList.remove('fa-eye');
                    eyeIcon.classList.add('fa-eye-slash');
                    this.setAttribute('aria-label', 'Hide password');
                } else {
                    eyeIcon.classList.remove('fa-eye-slash');
                    eyeIcon.classList.add('fa-eye');
                    this.setAttribute('aria-label', 'Show password');
                }
            });

            // Auto-hide success messages after 5 seconds
            const successMessages = messageContainer.querySelectorAll('.alert-success');
            successMessages.forEach(message => {
                setTimeout(() => {
                    message.style.display = 'none';
                }, 5000);
            });

            // Auto-hide error messages after 8 seconds
            const errorMessages = messageContainer.querySelectorAll('.alert-error');
            errorMessages.forEach(message => {
                setTimeout(() => {
                    message.style.display = 'none';
                }, 8000);
            });

            // Validate National ID on input
            usernameInput.addEventListener('input', function() {
                validateNationalID(this.value);
                updateLoginButton();
            });

            // Validate Password on input
            passwordInput.addEventListener('input', function() {
                validatePassword(this.value);
                updateLoginButton();
            });

            // Restrict National ID input to numbers only
            usernameInput.addEventListener('keypress', function(e) {
                const char = String.fromCharCode(e.keyCode || e.which);
                if (!/^\d$/.test(char)) {
                    e.preventDefault();
                    return false;
                }
            });

            // Also prevent paste of non-numeric characters
            usernameInput.addEventListener('paste', function(e) {
                e.preventDefault();
                const pastedText = (e.clipboardData || window.clipboardData).getData('text');
                const numbersOnly = pastedText.replace(/\D/g, '');
                document.execCommand('insertText', false, numbersOnly);
            });

            // Form submission handler
            loginForm.addEventListener('submit', function(e) {
                const username = usernameInput.value.trim();
                const password = passwordInput.value.trim();

                if (!username || !password) {
                    e.preventDefault();
                    showMessage('Please fill in all fields', 'error');
                    return false;
                }

                // Validate Ethiopian National ID format (15-17 digits)
                if (!validateNationalID(username)) {
                    e.preventDefault();
                    showMessage('Please enter a valid Ethiopian National ID (15-17 digits)', 'error');
                    usernameInput.focus();
                    return false;
                }

                // Validate password format
                if (!validatePassword(password)) {
                    e.preventDefault();
                    showMessage('Password does not meet requirements', 'error');
                    passwordInput.focus();
                    return false;
                }

                // Show loading overlay
                showLoading();
                
                // Disable login button to prevent multiple submissions
                loginButton.disabled = true;
                loginButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> LOGGING IN...';
            });

            function validateNationalID(nationalId) {
                nationalId = nationalId.trim();
                
                // Ethiopian National ID pattern: 15 to 17 digits only
                const ethiopianIdPattern = /^\d{15,17}$/;
                
                if (nationalId === '') {
                    nationalIdError.style.display = 'none';
                    usernameInput.classList.remove('valid', 'invalid');
                    return false;
                }
                
                if (ethiopianIdPattern.test(nationalId)) {
                    nationalIdError.style.display = 'none';
                    usernameInput.classList.remove('invalid');
                    usernameInput.classList.add('valid');
                    return true;
                } else {
                    nationalIdError.style.display = 'block';
                    usernameInput.classList.remove('valid');
                    usernameInput.classList.add('invalid');
                    return false;
                }
            }

            function validatePassword(password) {
                password = password.trim();
                
                // Password requirements:
                // At least one letter (A-Z or a-z)
                // At least one number (0-9)
                // At least one special character
                const hasLetter = /[A-Za-z]/.test(password);
                const hasNumber = /\d/.test(password);
                // Escape special characters properly for Razor
                const hasSpecial = /[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password);
                
                // Update requirement indicators
                updateRequirementIndicator(reqLetter, hasLetter);
                updateRequirementIndicator(reqNumber, hasNumber);
                updateRequirementIndicator(reqSpecial, hasSpecial);
                
                if (password === '') {
                    passwordError.style.display = 'none';
                    passwordInput.classList.remove('valid', 'invalid');
                    return false;
                }
                
                if (hasLetter && hasNumber && hasSpecial) {
                    passwordError.style.display = 'none';
                    passwordInput.classList.remove('invalid');
                    passwordInput.classList.add('valid');
                    return true;
                } else {
                    passwordError.style.display = 'block';
                    passwordInput.classList.remove('valid');
                    passwordInput.classList.add('invalid');
                    return false;
                }
            }

            function updateRequirementIndicator(element, isValid) {
                if (isValid) {
                    element.classList.remove('invalid');
                    element.classList.add('valid');
                    element.querySelector('i').className = 'fas fa-check';
                } else {
                    element.classList.remove('valid');
                    element.classList.add('invalid');
                    element.querySelector('i').className = 'fas fa-times';
                }
            }

            function updateLoginButton() {
                const isNationalIdValid = validateNationalID(usernameInput.value);
                const isPasswordValid = validatePassword(passwordInput.value);
                
                loginButton.disabled = !(isNationalIdValid && isPasswordValid);
            }

            function showMessage(message, type) {
                // Remove any existing messages
                const existingAlerts = messageContainer.querySelectorAll('.alert');
                existingAlerts.forEach(alert => {
                    if (alert.parentElement) {
                        alert.remove();
                    }
                });

                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-' + type;
                
                let icon = 'fa-info-circle';
                if (type === 'success') icon = 'fa-check-circle';
                if (type === 'error') icon = 'fa-exclamation-triangle';
                if (type === 'warning') icon = 'fa-exclamation-circle';

                alertDiv.innerHTML = '<i class="fas ' + icon + ' alert-icon"></i>' +
                    '<span>' + message + '</span>' +
                    '<button class="close-btn" onclick="this.parentElement.style.display=\'none\'">×</button>';

                messageContainer.appendChild(alertDiv);

                // Auto-hide based on type
                const hideTime = type === 'success' ? 5000 : 8000;
                setTimeout(() => {
                    if (alertDiv.parentElement) {
                        alertDiv.style.display = 'none';
                    }
                }, hideTime);
            }

            function showLoading() {
                loadingOverlay.style.display = 'flex';
            }

            function hideLoading() {
                loadingOverlay.style.display = 'none';
                loginButton.disabled = false;
                loginButton.innerHTML = '<i class="fas fa-sign-in-alt"></i> LOGIN TO SYSTEM';
            }

            // Handle page refresh or back button - re-enable login button
            window.addEventListener('pageshow', function(event) {
                if (event.persisted) {
                    hideLoading();
                    updateLoginButton();
                }
            });

            // Check for URL parameters that might indicate messages
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('error')) {
                showMessage('Login failed. Please check your credentials and try again.', 'error');
            }
            if (urlParams.has('success')) {
                showMessage('Login successful! Redirecting...', 'success');
            }

            // Focus on username field if there's an error
            if (errorMessages.length > 0) {
                usernameInput.focus();
            }

            // Initial validation
            if (usernameInput.value) {
                validateNationalID(usernameInput.value);
            }
            if (passwordInput.value) {
                validatePassword(passwordInput.value);
            }
            updateLoginButton();
        });

        // Handle network errors
        window.addEventListener('online', function() {
            console.log('Network connection restored');
        });

        window.addEventListener('offline', function() {
            const messageContainer = document.getElementById('messageContainer');
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-error';
            alertDiv.innerHTML = '<i class="fas fa-exclamation-triangle alert-icon"></i>' +
                '<span>Network connection lost. Please check your internet connection.</span>' +
                '<button class="close-btn" onclick="this.parentElement.style.display=\'none\'">×</button>';
            messageContainer.appendChild(alertDiv);
        });
    </script>
</body>
</html>