@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Ethiopian Government Voting System</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        /* Your existing CSS styles remain the same */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1d3557, #457b9d);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            position: relative;
        }

        .container {
            background-color: #fff;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 550px;
            position: relative;
            border: 2px solid #FCD116;
        }

        h1 {
            text-align: center;
            color: #1d3557;
            margin-bottom: 10px;
            font-size: 2.2rem;
        }

        h2 {
            text-align: center;
            color: #1d3557;
            margin-bottom: 20px;
            font-size: 1.5rem;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 1.1rem;
        }

        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        label {
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            color: #333;
            font-size: 14px;
        }

        input, select {
            width: 100%;
            padding: 14px;
            border-radius: 10px;
            border: 2px solid #e1e5e9;
            outline: none;
            background-color: #f8f9fa;
            transition: all 0.3s;
            font-size: 15px;
        }

        input:focus, select:focus {
            border-color: #457b9d;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(69, 123, 157, 0.2);
            transform: translateY(-2px);
        }

        button {
            width: 100%;
            margin-top: 25px;
            padding: 15px;
            background: linear-gradient(135deg, #078930, #1d3557);
            border: none;
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        button:hover {
            background: linear-gradient(135deg, #1d3557, #078930);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        }

        .change-password-btn {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            margin-top: 15px;
        }

        .change-password-btn:hover {
            background: linear-gradient(135deg, #c0392b, #e74c3c);
        }

        .back-btn {
            position: absolute;
            top: 25px;
            left: 25px;
            text-decoration: none;
            color: white;
            font-weight: bold;
            background: rgba(0, 0, 0, 0.6);
            padding: 12px 18px;
            border-radius: 8px;
            transition: all 0.3s;
            z-index: 1000;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .back-btn:hover {
            background: rgba(0, 0, 0, 0.8);
            transform: translateX(-5px);
        }

        .error-message {
            color: #e74c3c;
            text-align: center;
            margin-top: 15px;
            padding: 15px;
            background: #f8d7da;
            border: 2px solid #f5c6cb;
            border-radius: 10px;
            display: none;
            font-weight: 600;
        }

        .success-message {
            color: #27ae60;
            text-align: center;
            margin-top: 15px;
            padding: 15px;
            background: #d4edda;
            border: 2px solid #c3e6cb;
            border-radius: 10px;
            display: none;
            font-weight: 600;
        }

        .password-display {
            background: #fff3cd;
            border: 2px solid #ffeaa7;
            border-radius: 10px;
            padding: 15px;
            margin-top: 15px;
            text-align: center;
        }

        .password-value {
            font-size: 22px;
            font-weight: bold;
            color: #e74c3c;
            background: white;
            padding: 10px 15px;
            border-radius: 5px;
            border: 2px dashed #457b9d;
            margin: 10px 0;
            font-family: 'Courier New', monospace;
            letter-spacing: 1px;
        }

        .expiry-info {
            margin: 10px 0;
            padding: 10px;
            background: #e8f5e8;
            border-radius: 5px;
            border-left: 4px solid #27ae60;
            font-size: 14px;
        }

        .login-link {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 2px solid #eee;
        }

        .login-link a {
            color: #457b9d;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
        }

        .login-link a:hover {
            text-decoration: underline;
            color: #1d3557;
        }

        .loading {
            display: none;
            text-align: center;
            margin-top: 15px;
        }

        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #457b9d;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            animation: spin 1s linear infinite;
            display: inline-block;
            margin-right: 10px;
        }

        .form-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .form-header i {
            font-size: 3rem;
            color: #078930;
            margin-bottom: 15px;
            background: linear-gradient(135deg, #078930, #FCD116);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .required::after {
            content: " *";
            color: #e74c3c;
        }

        .ethiopia-flag {
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #078930 33%, #FCD116 33% 66%, #E12026 66%);
            border-radius: 50%;
            border: 3px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .change-password-section {
            margin-top: 30px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 10px;
            border: 2px solid #e9ecef;
            display: none;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .illiterate-notice {
            background: #e3f2fd;
            border: 2px solid #2196f3;
            border-radius: 10px;
            padding: 20px;
            margin: 20px 0;
            text-align: left;
        }

        .illiterate-notice h4 {
            color: #1976d2;
            margin-bottom: 10px;
            font-size: 18px;
        }

        .illiterate-notice ul {
            margin-left: 20px;
            margin-bottom: 15px;
        }

        .illiterate-notice li {
            margin-bottom: 8px;
            color: #333;
        }

        .visual-login-link {
            display: block;
            margin-top: 15px;
            padding: 12px;
            background: linear-gradient(135deg, #2196f3, #1976d2);
            color: white;
            text-align: center;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s;
        }

        .visual-login-link:hover {
            background: linear-gradient(135deg, #1976d2, #2196f3);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(33, 150, 243, 0.3);
        }

        @@media (max-width: 768px) {
            .container {
                margin: 20px;
                padding: 30px 25px;
            }
            
            .back-btn {
                position: relative;
                top: auto;
                left: auto;
                margin-bottom: 20px;
                display: inline-block;
            }
            
            h1 {
                font-size: 1.8rem;
            }
            
            .password-value {
                font-size: 18px;
                padding: 8px 12px;
            }
            
            .illiterate-notice {
                padding: 15px;
            }
        }
    </style>
</head>
<body>
    <a class="back-btn" href="/Home/Login">
        <i class="fas fa-arrow-left"></i> Back to Login
    </a>

    <div class="container">
        <div class="ethiopia-flag"></div>
        
        <div class="form-header">
            <i class="fas fa-key"></i>
            <h1>Recover Password</h1>
            <p class="subtitle">Enter your account details to retrieve your password</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-message" style="display: block;">
                <i class="fas fa-exclamation-circle"></i> @Html.Raw(TempData["ErrorMessage"])
            </div>
        }

        @if (TempData["UpdatePasswordError"] != null)
        {
            <div class="error-message" style="display: block;">
                <i class="fas fa-exclamation-circle"></i> @Html.Raw(TempData["UpdatePasswordError"])
            </div>
        }

        @if (TempData["UpdatePasswordSuccess"] != null)
        {
            <div class="success-message" style="display: block;">
                <i class="fas fa-check-circle"></i> @Html.Raw(TempData["UpdatePasswordSuccess"])
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-message" style="display: block;">
                <i class="fas fa-check-circle"></i> @Html.Raw(TempData["SuccessMessage"])
                
                @if (TempData["RetrievedPassword"] != null)
                {
                    <div class="password-display">
                        <h4 style="color: #1d3557; margin-bottom: 10px;">
                            <i class="fas fa-key"></i> Your Temporary Password:
                        </h4>
                        <div class="password-value">
                            @TempData["RetrievedPassword"]
                        </div>
                        <div class="expiry-info">
                            <i class="fas fa-clock"></i> 
                            @if (TempData["ExpiryTime"] != null)
                            {
                                <span>This password will expire at: <strong>@TempData["ExpiryTime"]</strong></span>
                            }
                            else
                            {
                                <span>This password will expire in: <strong>10 minutes</strong></span>
                            }
                        </div>
                        
                        @if (TempData["IlliterateVoter"] != null && (string)TempData["IlliterateVoter"] == "true")
                        {
                            <div class="illiterate-notice">
                                <h4><i class="fas fa-eye"></i> Important Notice for Illiterate Voters</h4>
                                <p>This account is registered as <strong>Illiterate</strong> and requires visual login.</p>
                                <ul>
                                    <li><strong>Step 1:</strong> Use the temporary password above to login</li>
                                    <li><strong>Step 2:</strong> After login, go to <strong>"Visual Login for Illiterate Voters"</strong></li>
                                    <li><strong>Step 3:</strong> Set your 4-image password for future logins</li>
                                </ul>
                                <p><i class="fas fa-info-circle"></i> <strong>Note:</strong> The temporary password meets security requirements:</p>
                                <ul>
                                    <li>At least 6 characters long</li>
                                    <li>Contains letters (A-Z, a-z)</li>
                                    <li>Contains numbers (0-9)</li>
                                    <li>Contains special characters (!@("#")$%^&amp;*)</li>
                                </ul>
                                <a href="/Home/VisualLogin" class="visual-login-link">
                                    <i class="fas fa-images"></i> Go to Visual Login for Illiterate Voters
                                </a>
                            </div>
                        }
                        else
                        {
                            <p style="margin-top: 10px; color: #666; font-size: 14px;">
                                <i class="fas fa-info-circle"></i> Use this exact password to login to your account
                            </p>
                        }
                        
                        <button type="button" class="change-password-btn" onclick="showChangePasswordForm()">
                            <i class="fas fa-exchange-alt"></i> Change Password Now
                        </button>
                    </div>
                }
            </div>
        }

        <form id="forgotPasswordForm" method="post" asp-action="ForgotPassword" asp-controller="Home">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label for="NationalId" class="required">
                    <i class="fas fa-id-card"></i> National ID
                </label>
                <input type="text" id="NationalId" name="nationalId" placeholder="Enter your 15-17 digit National ID" required value="@TempData["RetrievedNationalId"]">
            </div>

            <div class="form-group">
                <label for="Nationality" class="required">
                    <i class="fas fa-globe"></i> Nationality
                </label>
                <select id="Nationality" name="nationality" required>
                    <option value="Ethiopian" selected>Ethiopian</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="form-group">
                <label for="FirstName" class="required">
                    <i class="fas fa-user"></i> First Name
                </label>
                <input type="text" id="FirstName" name="firstName" placeholder="Enter your first name" required>
            </div>

            <div class="form-group">
                <label for="MiddleName">
                    <i class="fas fa-user"></i> Middle Name
                </label>
                <input type="text" id="MiddleName" name="middleName" placeholder="Enter your middle name (optional)">
            </div>

            <div class="form-group">
                <label for="LastName" class="required">
                    <i class="fas fa-user"></i> Last Name
                </label>
                <input type="text" id="LastName" name="lastName" placeholder="Enter your last name" required>
            </div>

            <div class="form-group">
                <label for="Region" class="required">
                    <i class="fas fa-map-marker-alt"></i> Region
                </label>
                <select id="Region" name="region" required>
                    <option value="">Select Region</option>
                    <option value="Addis Ababa">Addis Ababa</option>
                    <option value="Afar">Afar</option>
                    <option value="Amhara">Amhara</option>
                    <option value="Benishangul-Gumuz">Benishangul-Gumuz</option>
                    <option value="Dire Dawa">Dire Dawa</option>
                    <option value="Gambela">Gambela</option>
                    <option value="Harari">Harari</option>
                    <option value="Oromia">Oromia</option>
                    <option value="Sidama">Sidama</option>
                    <option value="Somali">Somali</option>
                    <option value="Southern Nations">Southern Nations</option>
                    <option value="Tigray">Tigray</option>
                </select>
            </div>

            <div class="form-group">
                <label for="PhoneNumber" class="required">
                    <i class="fas fa-phone"></i> Phone Number
                </label>
                <input type="tel" id="PhoneNumber" name="phoneNumber" placeholder="+251 XXX XXX XXX" required>
            </div>

            <button type="submit" id="submitButton">
                <i class="fas fa-search"></i> Retrieve Password
            </button>

            <div class="loading" id="loading">
                <div class="spinner"></div> Verifying your information...
            </div>
        </form>

        <!-- Change Password Form -->
        <div class="change-password-section" id="changePasswordSection">
            <h2><i class="fas fa-exchange-alt"></i> Change Your Password</h2>
            
            <form id="changePasswordForm" method="post" asp-action="UpdatePassword" asp-controller="Home">
                @Html.AntiForgeryToken()
                
                <input type="hidden" id="ChangePasswordNationalId" name="nationalId" value="@TempData["RetrievedNationalId"]">
                
                <div class="form-group">
                    <label for="CurrentPassword" class="required">
                        <i class="fas fa-key"></i> Current/Temporary Password
                    </label>
                    <input type="password" id="CurrentPassword" name="currentPassword" placeholder="Enter your current or temporary password" required>
                </div>

                <div class="form-group">
                    <label for="NewPassword" class="required">
                        <i class="fas fa-lock"></i> New Password
                    </label>
                    <input type="password" id="NewPassword" name="newPassword" placeholder="Enter your new password (must meet requirements)" required minlength="6">
                    <small style="color: #666; font-size: 12px; display: block; margin-top: 5px;">
                        Must contain: 6+ characters, at least 1 letter, 1 number, and 1 special character (!@("#")$%^&amp;*)
                    </small>
                </div>

                <div class="form-group">
                    <label for="ConfirmPassword" class="required">
                        <i class="fas fa-lock"></i> Confirm New Password
                    </label>
                    <input type="password" id="ConfirmPassword" name="confirmPassword" placeholder="Confirm your new password" required minlength="6">
                </div>

                <button type="submit" id="changePasswordButton">
                    <i class="fas fa-check"></i> Update Password
                </button>

                <div class="loading" id="changePasswordLoading">
                    <div class="spinner"></div> Updating your password...
                </div>
            </form>
        </div>

        <div class="login-link">
            <p>Remember your password? <a href="/Home/Login">Back to Login</a></p>
            <p style="margin-top: 10px;">
                <a href="/Home/VisualLogin" style="color: #2196f3;">
                    <i class="fas fa-images"></i> Visual Login for Illiterate Voters
                </a>
            </p>
        </div>
    </div>

    <script>
        document.getElementById('forgotPasswordForm').addEventListener('submit', function(e) {
            const nationalId = document.getElementById('NationalId').value.trim();
            const firstName = document.getElementById('FirstName').value.trim();
            const lastName = document.getElementById('LastName').value.trim();
            const phoneNumber = document.getElementById('PhoneNumber').value.trim();
            const region = document.getElementById('Region').value;

            hideMessages();

            if (!nationalId) {
                e.preventDefault();
                showError("Please enter your National ID.");
                return false;
            }

            if (!firstName) {
                e.preventDefault();
                showError("Please enter your First Name.");
                return false;
            }

            if (!lastName) {
                e.preventDefault();
                showError("Please enter your Last Name.");
                return false;
            }

            if (!phoneNumber) {
                e.preventDefault();
                showError("Please enter your Phone Number.");
                return false;
            }

            if (!region) {
                e.preventDefault();
                showError("Please select your Region.");
                return false;
            }

            if (!isValidNationalId(nationalId)) {
                e.preventDefault();
                showError("Please enter a valid Ethiopian National ID (15-17 digits).");
                return false;
            }

            showLoading();
        });

        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            const currentPassword = document.getElementById('CurrentPassword').value.trim();
            const newPassword = document.getElementById('NewPassword').value.trim();
            const confirmPassword = document.getElementById('ConfirmPassword').value.trim();

            hideMessages();

            if (!currentPassword) {
                e.preventDefault();
                showError("Please enter your current/temporary password.");
                return false;
            }

            if (!newPassword) {
                e.preventDefault();
                showError("Please enter your new password.");
                return false;
            }

            if (!confirmPassword) {
                e.preventDefault();
                showError("Please confirm your new password.");
                return false;
            }

            if (newPassword.length < 6) {
                e.preventDefault();
                showError("New password must be at least 6 characters long.");
                return false;
            }

            // Validate password meets criteria
            if (!validatePassword(newPassword)) {
                e.preventDefault();
                showError("New password must:<br>" +
                         "• Be at least 6 characters long<br>" +
                         "• Contain at least one letter (A-Z or a-z)<br>" +
                         "• Contain at least one number (0-9)<br>" +
                         "• Contain at least one special character (!@("#")$%^&amp;* etc.)");
                return false;
            }

            if (newPassword !== confirmPassword) {
                e.preventDefault();
                showError("New password and confirm password do not match.");
                return false;
            }

            showChangePasswordLoading();
        });

        function showChangePasswordForm() {
            const nationalId = document.getElementById('NationalId').value.trim();
            document.getElementById('ChangePasswordNationalId').value = nationalId;
            document.getElementById('changePasswordSection').style.display = 'block';
            
            // Scroll to the change password section
            document.getElementById('changePasswordSection').scrollIntoView({ 
                behavior: 'smooth' 
            });
        }

        function isValidNationalId(nationalId) {
            const cleanId = nationalId.replace(/[^\d]/g, '');
            return cleanId.length >= 15 && cleanId.length <= 17 && /^\d+$/.test(cleanId);
        }

        function validatePassword(password) {
            // Check minimum length
            if (password.length < 6) return false;
            
            // Check for at least one letter
            if (!/[A-Za-z]/.test(password)) return false;
            
            // Check for at least one number
            if (!/[0-9]/.test(password)) return false;
            
            // Check for at least one special character
            if (!/[!@("#")$%^&*]/.test(password)) return false;
            
            return true;
        }

        function showError(message) {
            hideMessages();
            const errorElement = document.createElement('div');
            errorElement.className = 'error-message';
            errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${message}`;
            errorElement.style.display = 'block';
            document.getElementById('forgotPasswordForm').prepend(errorElement);
            hideLoading();
            hideChangePasswordLoading();
        }

        function hideMessages() {
            const messages = document.querySelectorAll('.error-message, .success-message');
            messages.forEach(msg => {
                if (!msg.style.display || msg.style.display === 'block') {
                    msg.remove();
                }
            });
        }

        function showLoading() {
            document.getElementById('loading').style.display = 'block';
            document.getElementById('submitButton').disabled = true;
            document.getElementById('submitButton').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        }

        function hideLoading() {
            document.getElementById('loading').style.display = 'none';
            document.getElementById('submitButton').disabled = false;
            document.getElementById('submitButton').innerHTML = '<i class="fas fa-search"></i> Retrieve Password';
        }

        function showChangePasswordLoading() {
            document.getElementById('changePasswordLoading').style.display = 'block';
            document.getElementById('changePasswordButton').disabled = true;
            document.getElementById('changePasswordButton').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';
        }

        function hideChangePasswordLoading() {
            document.getElementById('changePasswordLoading').style.display = 'none';
            document.getElementById('changePasswordButton').disabled = false;
            document.getElementById('changePasswordButton').innerHTML = '<i class="fas fa-check"></i> Update Password';
        }

        setInterval(hideMessages, 8000);

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('NationalId').focus();
            
            // Auto-show change password section if there was an update error
            @if (TempData["UpdatePasswordError"] != null && TempData["RetrievedPassword"] != null)
            {
                                @:setTimeout(showChangePasswordForm, 500);
            }
        });
    </script>
</body>
</html>