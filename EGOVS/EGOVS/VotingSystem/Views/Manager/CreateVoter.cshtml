@{
    ViewData["Title"] = "Create Voter";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ethiopian Voting System</title>
    <style>
        /* Enhanced Styling with Ethiopian Theme */
        :root {
            --primary-color: #1d3557;
            --secondary-color: #457b9d;
            --accent-color: #e63946;
            --success-color: #2a9d8f;
            --warning-color: #e9c46a;
            --light-color: #f1faee;
            --dark-color: #1d3557;
            --text-color: #2d3748;
            --border-radius: 12px;
            --box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 25%, #a8dadc 50%, var(--light-color) 75%, #ffffff 100%);
            min-height: 100vh;
            padding: 20px;
            position: relative;
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: #1e3c72;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
            transition: var(--transition);
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 8px;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }

        .back-btn:hover {
            background: linear-gradient(45deg, #FFA500, #FF8C00);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            overflow: hidden;
            margin-top: 60px;
        }

        .header {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.5em;
            font-weight: 700;
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .content {
            padding: 40px;
        }

        .form-section {
            background: #f8f9fa;
            padding: 30px;
            border-radius: var(--border-radius);
            margin-top: 20px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--primary-color);
            font-size: 14px;
        }

        .required::after {
            content: " *";
            color: var(--accent-color);
            font-weight: 700;
        }

        .form-group input, .form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 14px;
            transition: var(--transition);
            background: white;
            font-family: inherit;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(69, 123, 157, 0.1);
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 600;
            transition: var(--transition);
            width: 100%;
            margin-top: 10px;
            font-family: inherit;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(29, 53, 87, 0.3);
        }

        .message {
            padding: 15px;
            margin: 15px 0;
            border-radius: 8px;
            text-align: center;
            display: none;
            font-weight: 500;
        }

        .success {
            background: linear-gradient(135deg, #d1e7dd, #c3e6cb);
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error {
            background: linear-gradient(135deg, #f8d7da, #f5c6cb);
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .password-toggle {
            position: relative;
        }

        .password-toggle input {
            padding-right: 45px;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
            font-size: 16px;
        }

        .error-field {
            border: 2px solid var(--accent-color) !important;
            background: linear-gradient(135deg, #f8d7da, #f5c6cb) !important;
        }

        /* ID Upload Section Styles */
        .upload-section {
            margin: 25px 0;
            padding: 25px;
            border: 3px dashed var(--primary-color);
            border-radius: var(--border-radius);
            background: linear-gradient(135deg, rgba(241, 250, 238, 0.6), rgba(168, 218, 220, 0.4));
            text-align: center;
            transition: var(--transition);
            grid-column: 1 / -1;
        }

        .upload-section:hover {
            border-color: var(--secondary-color);
            background: linear-gradient(135deg, rgba(241, 250, 238, 0.8), rgba(168, 218, 220, 0.6));
        }

        .upload-btn {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 12px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            margin: 8px;
            transition: var(--transition);
            font-size: 14px;
            font-weight: 500;
            font-family: inherit;
        }

        .upload-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(29, 53, 87, 0.3);
        }

        .file-input {
            display: none;
        }

        .id-preview-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }

        .id-preview {
            text-align: center;
            padding: 20px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            transition: var(--transition);
        }

        .id-preview.active {
            border-color: var(--success-color);
            background: linear-gradient(135deg, rgba(42, 157, 143, 0.05), rgba(42, 157, 143, 0.1));
        }

        .id-preview img {
            max-width: 100%;
            max-height: 150px;
            border-radius: 6px;
            margin-top: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .upload-instructions {
            background: rgba(29, 53, 87, 0.1);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .upload-instructions strong {
            color: var(--primary-color);
            font-size: 16px;
        }

        .upload-quality-tips {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            font-size: 14px;
            text-align: left;
        }

        .upload-quality-tips h6 {
            margin: 0 0 10px 0;
            color: #856404;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .upload-quality-tips ul {
            margin: 0;
            padding-left: 20px;
        }

        .upload-quality-tips li {
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .action-buttons-ocr {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .action-buttons-ocr button {
            margin-top: 0;
        }

        .extract-btn {
            background: linear-gradient(135deg, var(--success-color), #248277);
        }

        .extract-btn:hover {
            background: linear-gradient(135deg, #248277, var(--success-color));
        }

        .demo-btn {
            background: linear-gradient(135deg, #6c757d, #5a6268);
        }

        .demo-btn:hover {
            background: linear-gradient(135deg, #5a6268, #6c757d);
        }

        .ocr-processing {
            background: linear-gradient(135deg, #e3f2fd, #bbdefb);
            border: 2px solid var(--primary-color);
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
            text-align: center;
            display: none;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(29, 53, 87, 0); }
            100% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0); }
        }

        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 0.2em solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border-animation .75s linear infinite;
        }

        @@keyframes spinner-border-animation {
            to { transform: rotate(360deg); }
        }

        .extracted-field {
            background-color: #f8f9fa !important;
            border: 2px solid var(--success-color) !important;
            color: #155724 !important;
            font-weight: 600 !important;
            cursor: not-allowed !important;
        }

        .field-status {
            font-size: 12px;
            margin-top: 5px;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
            font-weight: 500;
        }

        .field-status.auto-filled {
            background: #d4edda;
            color: #155724;
        }

        .field-status.manual {
            background: #fff3cd;
            color: #856404;
        }

        /* Literacy Section */
        .literate-section {
            margin: 25px 0;
            padding: 25px;
            border: 3px solid var(--primary-color);
            border-radius: var(--border-radius);
            background: linear-gradient(135deg, rgba(241, 250, 238, 0.8), rgba(255, 255, 255, 0.9));
            position: relative;
            grid-column: 1 / -1;
        }

        .literate-section::before {
            content: "✍️ Literacy Status";
            position: absolute;
            top: -12px;
            left: 25px;
            background: white;
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
        }

        .literate-options {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 15px;
        }

        .literate-option {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
            padding: 20px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            transition: var(--transition);
            background: white;
            text-align: center;
        }

        .literate-option:hover {
            border-color: var(--secondary-color);
            background: rgba(69, 123, 157, 0.05);
            transform: translateY(-2px);
        }

        .literate-option.selected {
            border-color: var(--success-color);
            background: linear-gradient(135deg, rgba(42, 157, 143, 0.1), rgba(42, 157, 143, 0.05));
            box-shadow: 0 4px 15px rgba(42, 157, 143, 0.2);
        }

        .literate-option input[type="radio"] {
            width: auto;
            margin: 0;
            transform: scale(1.1);
        }

        .literate-option label {
            margin: 0;
            cursor: pointer;
            font-weight: 500;
            color: var(--text-color);
            font-size: 14px;
        }

        .literate-icon {
            font-size: 20px;
        }

        .literate-yes .literate-icon {
            color: var(--success-color);
        }

        .literate-no .literate-icon {
            color: var(--accent-color);
        }

        /* Image Password Section */
        .image-password-section {
            margin: 25px 0;
            padding: 25px;
            border: 3px solid var(--secondary-color);
            border-radius: var(--border-radius);
            background: linear-gradient(135deg, rgba(168, 218, 220, 0.8), rgba(241, 250, 238, 0.9));
            position: relative;
            display: none;
            grid-column: 1 / -1;
        }

        .image-password-section::before {
            content: "🖼️ Image Password";
            position: absolute;
            top: -12px;
            left: 25px;
            background: white;
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            border: 2px solid var(--secondary-color);
            color: var(--secondary-color);
        }

        .image-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            margin: 20px 0;
        }

        .image-option {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            background: white;
        }

        .image-option:hover {
            border-color: var(--secondary-color);
            transform: translateY(-2px);
        }

        .image-option.selected {
            border-color: var(--success-color);
            background: linear-gradient(135deg, rgba(42, 157, 143, 0.1), rgba(42, 157, 143, 0.05));
            box-shadow: 0 4px 15px rgba(42, 157, 143, 0.2);
        }

        .image-option .emoji-image {
            font-size: 2.5rem;
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px auto;
            border-radius: 6px;
            background: rgba(29, 53, 87, 0.05);
        }

        .selected-images {
            margin-top: 20px;
            padding: 20px;
            border: 2px dashed var(--primary-color);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.7);
        }

        .selected-preview {
            display: flex;
            gap: 12px;
            margin-top: 15px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .selected-image {
            text-align: center;
        }

        .selected-image .emoji-image {
            font-size: 1.8rem;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            border: 2px solid var(--success-color);
            background: rgba(42, 157, 143, 0.1);
        }

        .selected-image .image-name {
            font-size: 11px;
            margin-top: 4px;
            color: var(--text-color);
        }

        .processing-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .processing-content {
            background: white;
            padding: 30px;
            border-radius: var(--border-radius);
            text-align: center;
            max-width: 400px;
            width: 90%;
            box-shadow: var(--box-shadow);
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: #f0f0f0;
            border-radius: 4px;
            margin: 15px 0;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            width: 0%;
            transition: width 0.3s ease;
            border-radius: 4px;
        }

        .field-detail-error {
            color: var(--accent-color);
            font-size: 12px;
            margin-top: 5px;
            font-weight: 500;
            padding: 5px 10px;
            background: rgba(230, 57, 70, 0.1);
            border-radius: 4px;
            border-left: 3px solid var(--accent-color);
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .container {
                margin: 10px;
                margin-top: 80px;
            }
            
            .content {
                padding: 20px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            
            .id-preview-container {
                grid-template-columns: 1fr;
            }
            
            .literate-options {
                grid-template-columns: 1fr;
            }
            
            .action-buttons-ocr {
                flex-direction: column;
            }
            
            .image-grid {
                grid-template-columns: repeat(3, 1fr);
            }
            
            .header h1 {
                font-size: 2rem;
            }
        }

        @@media (max-width: 480px) {
            .image-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .image-option .emoji-image {
                width: 50px;
                height: 50px;
                font-size: 2rem;
            }
            
            .header {
                padding: 20px;
            }
            
            .form-section {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <button class="back-btn" onclick="goBackToDashboard()">
        ← Back to Dashboard
    </button>
    
    <div class="container">
        <div class="header">
            <h1>👤 Create New Voter</h1>
            <p>Register a new voter in the Ethiopian E-Voting System</p>
        </div>

        <div class="content">
            <div id="message" class="message"></div>

            <!-- Create Voter Form -->
            <div class="form-section">
                <h3 style="color: var(--primary-color); margin-bottom: 20px; text-align: center;">Voter Registration Form</h3>
                <form id="createVoterFormElement">
                    <div class="form-grid">
                        <!-- Enhanced ID Upload Section -->
                        <div class="upload-section">
                            <div class="upload-instructions">
                                <strong><i class="fas fa-id-card"></i> Upload National ID Card Photos</strong><br>
                                Upload clear photos of front and back sides of voter's ID card for automatic data extraction
                            </div>

                            <div class="upload-quality-tips">
                                <h6><i class="fas fa-lightbulb"></i> For Best OCR Results:</h6>
                                <ul>
                                    <li>Use high-quality scanned images or photos with good lighting</li>
                                    <li>Ensure no shadows or glare on the ID card</li>
                                    <li>Place ID on flat surface and capture entire card</li>
                                    <li>Supported formats: JPG, PNG, BMP (Max 5MB each)</li>
                                    <li>Make sure all text is clearly visible and readable</li>
                                </ul>
                            </div>
                            
                            <div class="id-preview-container">
                                <!-- Front Side Upload -->
                                <div class="id-preview" id="voterFrontPreviewContainer">
                                    <div><strong><i class="fas fa-id-card-alt"></i> Front Side</strong></div>
                                    <div id="voterFrontPreviewText">No file selected</div>
                                    <div id="voterFrontPreviewImage"></div>
                                    <input type="file" id="voterFrontIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('voterFrontIdUpload').click()">
                                        📷 Choose Front Image
                                    </button>
                                </div>
                                
                                <!-- Back Side Upload -->
                                <div class="id-preview" id="voterBackPreviewContainer">
                                    <div><strong><i class="fas fa-id-card-alt"></i> Back Side</strong></div>
                                    <div id="voterBackPreviewText">No file selected</div>
                                    <div id="voterBackPreviewImage"></div>
                                    <input type="file" id="voterBackIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('voterBackIdUpload').click()">
                                        📷 Choose Back Image
                                    </button>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="action-buttons-ocr">
                                <button type="button" class="upload-btn extract-btn" id="voterExtractInfoBtn">
                                    🔍 Extract ID Information
                                </button>
                                <button type="button" class="upload-btn demo-btn" id="voterAutoFillBtn">
                                    📝 Auto-fill Form
                                </button>
                            </div>

                            <div id="voterOcrProcessing" class="ocr-processing">
                                <!-- Processing message will be inserted here -->
                            </div>
                        </div>

                        <!-- National ID Field -->
                        <div class="form-group">
                            <label for="voterNationalId" class="required">National ID (FAN)</label>
                            <input type="text" id="voterNationalId" name="NationalId" placeholder="Enter Ethiopian National ID" required />
                            <div class="field-status auto-filled" id="voterNationalIdStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterFirstName" class="required">First Name</label>
                            <input type="text" id="voterFirstName" name="FirstName" placeholder="Enter first name" required />
                            <div class="field-status auto-filled" id="voterFirstNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterMiddleName" class="required">Middle Name</label>
                            <input type="text" id="voterMiddleName" name="MiddleName" placeholder="Enter middle name" required />
                            <div class="field-status auto-filled" id="voterMiddleNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterLastName" class="required">Last Name</label>
                            <input type="text" id="voterLastName" name="LastName" placeholder="Enter last name" required />
                            <div class="field-status auto-filled" id="voterLastNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterPhoneNumber" class="required">Phone Number</label>
                            <input type="tel" id="voterPhoneNumber" name="PhoneNumber" placeholder="+251 XXX XXX XXX" required />
                            <div class="field-status auto-filled" id="voterPhoneNumberStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterNationality" class="required">Nationality</label>
                            <select id="voterNationality" name="Nationality" required>
                                <option value="" disabled selected>Select Nationality</option>
                                <option value="Ethiopian">Ethiopian</option>
                                <option value="Other">Other</option>
                            </select>
                            <div class="field-status auto-filled" id="voterNationalityStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="voterRegion" class="required">Region</label>
                            <select id="voterRegion" name="Region" required>
                                <option value="" disabled selected>Select Region</option>
                                <option value="Tigray">Tigray</option>
                                <option value="Afar">Afar</option>
                                <option value="Amhara">Amhara</option>
                                <option value="Oromia">Oromia</option>
                                <option value="Somali">Somali</option>
                                <option value="Benishangul-Gumuz">Benishangul-Gumuz</option>
                                <option value="Southern Nations">Southern Nations</option>
                                <option value="Gambela">Gambela</option>
                                <option value="Harari">Harari</option>
                                <option value="Addis Ababa">Addis Ababa</option>
                                <option value="Dire Dawa">Dire Dawa</option>
                            </select>
                            <div class="field-status auto-filled" id="voterRegionStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
