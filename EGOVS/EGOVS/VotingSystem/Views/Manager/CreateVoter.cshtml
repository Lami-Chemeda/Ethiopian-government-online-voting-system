                                    <div class="literate-icon"><i class="fas fa-check-circle"></i></div>
                                    <label for="Literate_Yes">Yes, can read and write</label>
                                </div>
                                <div class="literate-option literate-no" onclick="selectLiterateOption('No')">
                                    <input type="radio" id="Literate_No" name="Literate" value="No">
                                    <div class="literate-icon"><i class="fas fa-times-circle"></i></div>
                                    <label for="Literate_No">No, cannot read and write</label>
                                </div>
                            </div>
                            <div class="field-status manual" id="LiterateStatus" style="display: none;">Manual selection required</div>
                        </div>

                        <!-- Image Password Section -->
                        <div class="image-password-section" id="imagePasswordSection">
                            <label class="required">Image Password Selection</label>
                            <p style="font-size: 14px; color: #666; margin-bottom: 15px; text-align: center;">
                                <i class="fas fa-images"></i> Please select 4 images as password for illiterate voter
                            </p>
                            
                            <div class="image-grid" id="imageGrid">
                                <!-- Images will be dynamically loaded here -->
                            </div>
                            
                            <div class="selected-images" id="selectedImages">
                                <h4>Selected Images: <span id="selectedCount">0</span>/4</h4>
                                <div class="selected-preview" id="selectedPreview"></div>
                            </div>
                            
                            <input type="hidden" id="ImagePassword" name="ImagePassword" />
                            <div class="field-status manual" id="ImagePasswordStatus">Manual selection required</div>
                        </div>

                        <!-- Password Fields -->
                        <div class="form-grid" id="textPasswordSection">
                            <div class="form-group password-toggle">
                                <label for="voterPassword" class="required">Password</label>
                                <input type="password" id="voterPassword" name="Password" minlength="6" placeholder="Create password (min. 6 characters)" required />
                                <button type="button" class="toggle-password" onclick="togglePassword('voterPassword')">👁️</button>
                            </div>

                            <div class="form-group password-toggle">
                                <label for="voterConfirmPassword" class="required">Confirm Password</label>
                                <input type="password" id="voterConfirmPassword" placeholder="Confirm password" required />
                                <button type="button" class="toggle-password" onclick="togglePassword('voterConfirmPassword')">👁️</button>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">
                        <i class="fas fa-user-plus"></i> Register Voter
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Processing Overlay -->
    <div class="processing-overlay" id="processingOverlay">
        <div class="processing-content">
            <h3 id="processingTitle" style="color: var(--primary-color); margin-bottom: 15px;">Processing Registration</h3>
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <p id="processingStatus" style="color: #666;">Please wait while we process voter registration...</p>
            <div id="processingDetails" style="margin-top: 10px; font-size: 14px; color: #888;"></div>
        </div>
    </div>

    <script>
        // Ethiopia regions data
        const ethiopiaRegions = [
            "Tigray", "Afar", "Amhara", "Oromia", "Somali", "Benishangul-Gumuz", 
            "Southern Nations", "Gambela", "Harari", "Addis Ababa", "Dire Dawa"
        ];

        // Image options for illiterate users
        const imageOptions = [
            { id: 1, name: "Globe", emoji: "🌍" },
            { id: 2, name: "Mountain", emoji: "🏔️" },
            { id: 3, name: "Coffee", emoji: "☕" },
            { id: 4, name: "Wheat", emoji: "🌾" },
            { id: 5, name: "Buffalo", emoji: "🐃" },
            { id: 6, name: "Lion", emoji: "🦁" },
            { id: 7, name: "Airplane", emoji: "✈️" },
            { id: 8, name: "Building", emoji: "🏛️" },
            { id: 9, name: "Scroll", emoji: "📜" },
            { id: 10, name: "Shield", emoji: "🔰" }
        ];

        // Global variables
        let voterFrontImageFile = null;
        let voterBackImageFile = null;
        let extractedVoterIDData = null;
        let selectedImages = [];
        let isLiterate = null;

        // NEW: Ethiopian Phone Number Validation Function
        function validateEthiopianPhoneNumber(phone) {
            if (!phone) return false;
            
            // Remove all spaces, dashes, and parentheses
            const cleaned = phone.replace(/[\s\-()]/g, '');
            
            // Check different formats
            if (cleaned.startsWith('09')) {
                // Format: 09XXXXXXXXX (10 digits total)
                return cleaned.length === 10 && /^09\d{8}$/.test(cleaned);
            } else if (cleaned.startsWith('+251')) {
                // Format: +251XXXXXXXXX (13 digits with +, 9 digits after country code)
                return cleaned.length === 13 && /^\+251\d{9}$/.test(cleaned);
            } else if (cleaned.startsWith('251')) {
                // Format: 251XXXXXXXXX (12 digits total)
                return cleaned.length === 12 && /^251\d{9}$/.test(cleaned);
            }
            
            return false;
        }

        // NEW: Password Validation Function
        function validatePasswordComplexity(password) {
            if (!password) return { isValid: false, message: "Password is required" };
            
            // Minimum length check
            if (password.length < 6) {
                return {
                    isValid: false,
                    message: "Password must be at least 6 characters long"
                };
            }
            
            // At least one letter check
            if (!/[a-zA-Z]/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one letter (A-Z or a-z)"
                };
            }
            
            // At least one number check
            if (!/\d/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one number (0-9)"
                };
            }
            
            // At least one special character check
            if (!/[!@@#$%^&*]/.test(password)) {
                return {
                    isValid: false,
                    message: "Password must contain at least one special character (!@@#$%^&* etc.)"
                };
            }
            
            return {
                isValid: true,
                message: "Password is valid"
            };
        }

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            initializeVoterRegistration();
        });

        function initializeVoterRegistration() {
            try {
                setupVoterEventListeners();
                console.log('Voter Registration Manager initialized successfully');
            } catch (error) {
                console.error('Failed to initialize voter registration:', error);
            }
        }

        function goBackToDashboard() {
            window.location.href = '/Manager/Dashboard';
        }

        function setupVoterEventListeners() {
            // File upload events
            const frontUpload = document.getElementById('voterFrontIdUpload');
            const backUpload = document.getElementById('voterBackIdUpload');
            const extractBtn = document.getElementById('voterExtractInfoBtn');
            const autoFillBtn = document.getElementById('voterAutoFillBtn');

            if (frontUpload) {
                frontUpload.addEventListener('change', function(e) {
                    handleVoterFileUpload(e, 'front');
                });
            }
            if (backUpload) {
                backUpload.addEventListener('change', function(e) {
                    handleVoterFileUpload(e, 'back');
                });
            }
            if (extractBtn) {
                extractBtn.addEventListener('click', extractVoterIDInformation);
            }
            if (autoFillBtn) {
                autoFillBtn.addEventListener('click', autoFillVoterForm);
            }

            // Form submission
            const form = document.getElementById('createVoterFormElement');
            if (form) {
                form.addEventListener('submit', handleVoterFormSubmission);
            }

            // Password confirmation validation
            const confirmPassword = document.getElementById('voterConfirmPassword');
            if (confirmPassword) {
                confirmPassword.addEventListener('input', validatePasswordConfirmation);
            }

            // NEW: Phone number validation on blur
            const phoneInput = document.getElementById('voterPhoneNumber');
            if (phoneInput) {
                phoneInput.addEventListener('blur', validatePhoneNumberOnBlur);
                phoneInput.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                });
            }

            // NEW: Password validation on blur
            const passwordInput = document.getElementById('voterPassword');
            if (passwordInput) {
                passwordInput.addEventListener('blur', validatePasswordOnBlur);
                passwordInput.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                });
            }

            // Enhanced National ID checking
            const nationalIdField = document.getElementById('voterNationalId');
            if (nationalIdField) {
                nationalIdField.addEventListener('blur', async function() {
                    const nationalId = this.value.trim();
                    if (nationalId && nationalId.length >= 5) {
                        const result = await checkNationalIdExists(nationalId);
                        if (result.exists) {
                            showMessage(result.message, false);
                            this.classList.add('error-field');
                            
                            const existingError = this.parentNode.querySelector('.field-detail-error');
                            if (existingError) existingError.remove();
                            
                            const detailError = document.createElement('div');
                            detailError.className = 'field-detail-error';
                            detailError.textContent = result.message;
                            this.parentNode.appendChild(detailError);
                        } else {
                            this.classList.remove('error-field');
                            hideMessages();
                            
                            const existingError = this.parentNode.querySelector('.field-detail-error');
                            if (existingError) existingError.remove();
                        }
                    }
                });

                nationalIdField.addEventListener('input', function() {
                    this.classList.remove('error-field');
                    const existingError = this.parentNode.querySelector('.field-detail-error');
                    if (existingError) existingError.remove();
                    hideMessages();
                });
            }
        }

        // NEW: Phone number validation on blur
        function validatePhoneNumberOnBlur() {
            const phoneValue = this.value.trim();
            if (!phoneValue) return true;
            
            const isValid = validateEthiopianPhoneNumber(phoneValue);
            
            if (!isValid) {
                this.classList.add('error-field');
                const existingError = this.parentNode.querySelector('.field-detail-error');
                if (existingError) existingError.remove();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = 'Invalid phone number format. Valid formats: 09XXXXXXXX, +251XXXXXXXXX, 251XXXXXXXXX';
                this.parentNode.appendChild(detailError);
                return false;
            }
            
            this.classList.remove('error-field');
            const existingError = this.parentNode.querySelector('.field-detail-error');
            if (existingError) existingError.remove();
            return true;
        }

        // NEW: Password validation on blur
        function validatePasswordOnBlur() {
            const passwordValue = this.value;
            if (!passwordValue) return true;
            
            const validation = validatePasswordComplexity(passwordValue);
            
            if (!validation.isValid) {
                this.classList.add('error-field');
                const existingError = this.parentNode.querySelector('.field-detail-error');
                if (existingError) existingError.remove();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = validation.message;
                this.parentNode.appendChild(detailError);
                return false;
            }
            
            this.classList.remove('error-field');
            const existingError = this.parentNode.querySelector('.field-detail-error');
            if (existingError) existingError.remove();
            return true;
        }

        function handleVoterFileUpload(event, side) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateImageFile(file)) {
                showMessage('Please select a valid image file (JPG, PNG, BMP) under 5MB', false);
                event.target.value = '';
                return;
            }

            if (side === 'front') {
                voterFrontImageFile = file;
            } else {
                voterBackImageFile = file;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageData = e.target.result;
                updateVoterPreview(side, imageData, file.name);
            };
            reader.readAsDataURL(file);
        }

        function validateImageFile(file) {
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/bmp'];
            const maxSize = 5 * 1024 * 1024;
            return allowedTypes.includes(file.type) && file.size <= maxSize;
        }

        function updateVoterPreview(side, imageData, fileName) {
            const container = document.getElementById('voter' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewContainer');
            const textElement = document.getElementById('voter' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewText');
            const imageElement = document.getElementById('voter' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewImage');

            if (container && textElement && imageElement) {
                container.classList.add('active');
                textElement.textContent = fileName;
                textElement.style.color = '#28a745';
                textElement.style.fontWeight = 'bold';
                imageElement.innerHTML = '<img src="' + imageData + '" alt="' + side + ' side preview" style="max-width: 100%; max-height: 150px; border-radius: 6px;">';
            }
        }

        async function extractVoterIDInformation() {
            if (!voterFrontImageFile && !voterBackImageFile) {
                showMessage('Please upload at least one ID image (front or back)', false);
                return;
            }

            try {
                showVoterOCRProcessing('🔍 Scanning Ethiopian ID card...');

                const formData = new FormData();
                if (voterFrontImageFile) formData.append('FrontImage', voterFrontImageFile);
                if (voterBackImageFile) formData.append('BackImage', voterBackImageFile);

                const response = await fetch('/Manager/ProcessIDPhotos', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error('HTTP error! status: ' + response.status);

                const result = await response.json();
                
                if (result.success) {
                    extractedVoterIDData = result.data;
                    showMessage('✅ ' + (result.message || 'ID information extracted successfully!'), true);
                    fillVoterFormWithIDData(result.data);
                } else {
                    showMessage('❌ ' + (result.error || 'Failed to extract ID information'), false);
                }
                
            } catch (error) {
                showMessage('❌ Error scanning ID: ' + error.message, false);
            } finally {
                setTimeout(() => {
                    hideVoterOCRProcessing();
                }, 2000);
            }
        }

        function showVoterOCRProcessing(message) {
            const ocrProcessing = document.getElementById('voterOcrProcessing');
            if (ocrProcessing) {
                ocrProcessing.innerHTML = '<div style="text-align: center; padding: 15px;"><div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 10px;"><div class="spinner-border spinner-border-sm" role="status" style="color: var(--primary-color);"></div><span style="font-weight: bold; color: var(--primary-color);">' + message + '</span></div></div>';
                ocrProcessing.style.display = 'block';
            }
        }

        function hideVoterOCRProcessing() {
            const ocrProcessing = document.getElementById('voterOcrProcessing');
            if (ocrProcessing) {
                ocrProcessing.style.display = 'none';
            }
        }

        function fillVoterFormWithIDData(data) {
            console.log('🎯 Filling form with Ethiopian ID data:', data);
            
            // Validate and fill phone number
            if (data.phoneNumber && data.phoneNumber.trim() !== '') {
                const phoneValue = data.phoneNumber.trim();
                if (validateEthiopianPhoneNumber(phoneValue)) {
                    document.getElementById('voterPhoneNumber').value = phoneValue;
                    markVoterFieldAsExtractedFromOCR('PhoneNumber');
                } else {
                    // Show warning for invalid phone number but still fill it
                    document.getElementById('voterPhoneNumber').value = phoneValue;
                    showMessage('Extracted phone number format is invalid. Please correct it.', false);
                }
            }
            
            // Fill other fields
            if (data.nationalId && data.nationalId.trim() !== '') {
                document.getElementById('voterNationalId').value = data.nationalId.trim();
                markVoterFieldAsExtractedFromOCR('NationalId');
            }
            if (data.firstName && data.firstName.trim() !== '') {
                document.getElementById('voterFirstName').value = data.firstName.trim();
                markVoterFieldAsExtractedFromOCR('FirstName');
            }
            if (data.middleName && data.middleName.trim() !== '') {
                document.getElementById('voterMiddleName').value = data.middleName.trim();
                markVoterFieldAsExtractedFromOCR('MiddleName');
            }
            if (data.lastName && data.lastName.trim() !== '') {
                document.getElementById('voterLastName').value = data.lastName.trim();
                markVoterFieldAsExtractedFromOCR('LastName');
            }
            if (data.nationality && data.nationality.trim() !== '') {
                document.getElementById('voterNationality').value = data.nationality.trim();
                markVoterFieldAsExtractedFromOCR('Nationality');
            } else {
                document.getElementById('voterNationality').value = 'Ethiopian';
                markVoterFieldAsExtractedFromOCR('Nationality');
            }
            if (data.region && data.region.trim() !== '') {
                document.getElementById('voterRegion').value = data.region;
                markVoterFieldAsExtractedFromOCR('Region');
            }
            if (data.sex && data.sex.trim() !== '') {
                document.getElementById('voterSex').value = data.sex;
                markVoterFieldAsExtractedFromOCR('Sex');
            }
            if (data.age && data.age > 0) {
                document.getElementById('voterAge').value = data.age;
                markVoterFieldAsExtractedFromOCR('Age');
            }

            showMessage('✅ ID information successfully extracted! Fields are now locked.', true);
        }

        function markVoterFieldAsExtractedFromOCR(fieldId) {
            const field = document.getElementById('voter' + fieldId);
            const statusElement = document.getElementById('voter' + fieldId + 'Status');
            
            if (field) {
                field.classList.add('extracted-field');
                field.readOnly = true;
                
                if (statusElement) {
                    statusElement.style.display = 'inline-block';
                    statusElement.textContent = 'Auto-filled from ID';
                    statusElement.className = 'field-status auto-filled';
                }
            }
        }

        function autoFillVoterForm() {
            if (!extractedVoterIDData) {
                showMessage('❌ Please extract ID information first by clicking "Extract ID Information"', false);
                return;
            }
            fillVoterFormWithIDData(extractedVoterIDData);
            showMessage('✅ ID data displayed on form! Fields are now locked.', true);
        }

        function selectLiterateOption(literateValue) {
            isLiterate = literateValue;
            
            document.querySelectorAll('.literate-option').forEach(option => {
                option.classList.remove('selected');
            });
            
            const clickedOption = event.currentTarget;
            clickedOption.classList.add('selected');
            
            const radioButton = clickedOption.querySelector('input[type="radio"]');
            radioButton.checked = true;
            
            const statusElement = document.getElementById('LiterateStatus');
            if (statusElement) {
                statusElement.style.display = 'inline-block';
                statusElement.textContent = 'Manually selected';
                statusElement.className = 'field-status manual';
            }
            
            handlePasswordType(literateValue === 'Yes');
            
            console.log('Literate option selected:', literateValue);
        }

        function handlePasswordType(literate) {
            const textPasswordSection = document.getElementById('textPasswordSection');
            const imagePasswordSection = document.getElementById('imagePasswordSection');
            const passwordField = document.getElementById('voterPassword');
            const confirmPasswordField = document.getElementById('voterConfirmPassword');
            
            if (literate) {
                if (textPasswordSection) textPasswordSection.style.display = 'grid';
                if (imagePasswordSection) imagePasswordSection.style.display = 'none';
                
                if (passwordField) passwordField.required = true;
                if (confirmPasswordField) confirmPasswordField.required = true;
                
                selectedImages = [];
                updateSelectedImagesDisplay();
                
            } else {
                if (textPasswordSection) textPasswordSection.style.display = 'none';
                if (imagePasswordSection) imagePasswordSection.style.display = 'block';
                
                if (passwordField) passwordField.required = false;
                if (confirmPasswordField) confirmPasswordField.required = false;
                
                if (document.getElementById('imageGrid').children.length === 0) {
                    loadImageOptions();
                }
            }
        }

        function loadImageOptions() {
            const imageGrid = document.getElementById('imageGrid');
            imageGrid.innerHTML = '';
            
            imageOptions.forEach((image) => {
                const imageOption = document.createElement('div');
                imageOption.className = 'image-option';
                imageOption.innerHTML = '<div class="emoji-image">' + image.emoji + '</div><div class="image-name">' + image.name + '</div>';
                imageOption.onclick = function() {
                    selectImage(image.id, imageOption);
                };
                imageGrid.appendChild(imageOption);
            });
        }

        function selectImage(imageId, element) {
            const index = selectedImages.indexOf(imageId);
            
            if (index === -1) {
                if (selectedImages.length < 4) {
                    selectedImages.push(imageId);
                    element.classList.add('selected');
                } else {
                    showMessage('You can only select 4 images for the password.', false);
                    return;
                }
            } else {
                selectedImages.splice(index, 1);
                element.classList.remove('selected');
            }
            
            updateSelectedImagesDisplay();
        }

        function updateSelectedImagesDisplay() {
            const selectedCount = document.getElementById('selectedCount');
            const selectedPreview = document.getElementById('selectedPreview');
            const imagePasswordField = document.getElementById('ImagePassword');
            
            if (selectedCount) selectedCount.textContent = selectedImages.length;
            
            if (selectedPreview) {
                selectedPreview.innerHTML = '';
                
                selectedImages.forEach(imageId => {
                    const image = imageOptions.find(img => img.id === imageId);
                    if (image) {
                        const selectedImage = document.createElement('div');
                        selectedImage.className = 'selected-image';
                        selectedImage.innerHTML = '<div class="emoji-image">' + image.emoji + '</div><div class="image-name">' + image.name + '</div>';
                        selectedPreview.appendChild(selectedImage);
                    }
                });
            }
            
            if (imagePasswordField) {
                imagePasswordField.value = selectedImages.join(',');
            }
        }

        function validatePasswordConfirmation() {
            const password = document.getElementById('voterPassword');
            const confirmPassword = document.getElementById('voterConfirmPassword');
            const errorDiv = document.getElementById('message');
            
            if (!password || !confirmPassword || !errorDiv) return true;
            
            if (confirmPassword.value && password.value !== confirmPassword.value) {
                errorDiv.textContent = 'Passwords do not match!';
                errorDiv.style.display = 'block';
                return false;
            } else {
                errorDiv.style.display = 'none';
                return true;
            }
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
        }

        function showMessage(message, isSuccess) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = message;
            messageDiv.className = isSuccess ? 'message success' : 'message error';
            messageDiv.style.display = 'block';
            
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 5000);
        }

        function hideMessages() {
            const messageDiv = document.getElementById('message');
            if (messageDiv) {
                messageDiv.style.display = 'none';
            }
        }

        function showProcessingOverlay(title, message) {
            const overlay = document.getElementById('processingOverlay');
            const titleElement = document.getElementById('processingTitle');
            const statusElement = document.getElementById('processingStatus');
            
            if (overlay && titleElement && statusElement) {
                titleElement.textContent = title;
                statusElement.textContent = message;
                overlay.style.display = 'flex';
            }
        }

        function hideProcessingOverlay() {
            const overlay = document.getElementById('processingOverlay');
            if (overlay) {
                overlay.style.display = 'none';
            }
        }

        async function checkNationalIdExists(nationalId) {
            try {
                const response = await fetch('/Manager/CheckNationalId?nationalId=' + encodeURIComponent(nationalId));
                const result = await response.json();
                return result;
            } catch (error) {
                console.error('Error checking National ID:', error);
                return { exists: false, message: 'Error checking National ID availability.' };
            }
        }

        async function handleVoterFormSubmission(event) {
            event.preventDefault();
            
            const nationalId = document.getElementById('voterNationalId').value.trim();
            const firstName = document.getElementById('voterFirstName').value.trim();
            const middleName = document.getElementById('voterMiddleName').value.trim();
            const lastName = document.getElementById('voterLastName').value.trim();
            const phoneNumber = document.getElementById('voterPhoneNumber').value.trim();
            const password = document.getElementById('voterPassword').value;
            const confirmPassword = document.getElementById('voterConfirmPassword').value;
            const nationality = document.getElementById('voterNationality').value;
            const region = document.getElementById('voterRegion').value;
            const age = parseInt(document.getElementById('voterAge').value);
            const sex = document.getElementById('voterSex').value;
            const literate = document.querySelector('input[name="Literate"]:checked');
            const imagePassword = document.getElementById('ImagePassword').value;

            // Clear previous errors
            hideMessages();
            document.querySelectorAll('.error-field').forEach(field => {
                field.classList.remove('error-field');
            });
            document.querySelectorAll('.field-detail-error').forEach(error => {
                error.remove();
            });

            // Validation
            if (!nationalId || !firstName || !middleName || !lastName || !phoneNumber || !nationality || !region || !age || !sex || !literate) {
                showMessage('Please fill in all required fields.', false);
                return;
            }

            if (nationalId.length < 5) {
                showMessage('National ID must be at least 5 characters long', false);
                document.getElementById('voterNationalId').focus();
                return;
            }

            // Phone number validation
            if (!validateEthiopianPhoneNumber(phoneNumber)) {
                showMessage('Invalid phone number format. Valid formats: 09XXXXXXXX, +251XXXXXXXXX, 251XXXXXXXXX', false);
                document.getElementById('voterPhoneNumber').classList.add('error-field');
                document.getElementById('voterPhoneNumber').focus();
                
                const detailError = document.createElement('div');
                detailError.className = 'field-detail-error';
                detailError.textContent = 'Examples: 0911223344, 251911223344, +251911223344';
                document.getElementById('voterPhoneNumber').parentNode.appendChild(detailError);
                return;
            }

            if (age < 18 || age > 120) {
                showMessage('Age must be between 18 and 120.', false);
                document.getElementById('voterAge').focus();
                return;
            }

            const literateValue = literate.value;
            
            if (literateValue === 'Yes') {
                // Password complexity validation
                if (!password) {
                    showMessage('Password is required for literate users.', false);
                    document.getElementById('voterPassword').focus();
                    return;
                }
                
                const passwordValidation = validatePasswordComplexity(password);
                if (!passwordValidation.isValid) {
                    showMessage(passwordValidation.message, false);
                    document.getElementById('voterPassword').classList.add('error-field');
                    document.getElementById('voterPassword').focus();
                    
                    const detailError = document.createElement('div');
                    detailError.className = 'field-detail-error';
                    detailError.textContent = passwordValidation.message;
                    document.getElementById('voterPassword').parentNode.appendChild(detailError);
                    return;
                }
                
                if (password !== confirmPassword) {
                    showMessage('Passwords do not match.', false);
                    document.getElementById('voterConfirmPassword').focus();
                    return;
                }
            } else {
                if (selectedImages.length !== 4) {
                    showMessage('Please select exactly 4 images for the password of illiterate users.', false);
                    return;
                }
            }

            // Final duplicate check before submission
            const duplicateCheck = await checkNationalIdExists(nationalId);
            if (duplicateCheck.exists) {
                showMessage(duplicateCheck.message, false);
                document.getElementById('voterNationalId').classList.add('error-field');
                return;
            }

            showProcessingOverlay('Voter Registration', 'Processing voter registration...');

            try {
                const formData = new FormData();
                formData.append('NationalId', nationalId);
                formData.append('FirstName', firstName);
                formData.append('MiddleName', middleName);
                formData.append('LastName', lastName);
                formData.append('PhoneNumber', phoneNumber);
                formData.append('Nationality', nationality);
                formData.append('Region', region);
                formData.append('Age', age.toString());
                formData.append('Sex', sex);
                formData.append('Literate', literateValue);

                if (literateValue === 'Yes') {
                    formData.append('Password', password);
                    formData.append('ConfirmPassword', confirmPassword);
                } else {
                    formData.append('ImagePassword', imagePassword);
                    formData.append('Password', 'default_visual_password');
                    formData.append('ConfirmPassword', 'default_visual_password');
                }

                const response = await fetch('/Manager/RegisterVoter', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                
                if (result.success) {
                    hideProcessingOverlay();
                    showMessage('✅ ' + result.message, true);
                    
                    // Reset form
                    resetVoterForm();
                    
                } else {
                    hideProcessingOverlay();
                    showMessage('❌ ' + result.message, false);
                    
                    // Handle duplicate National ID from server response
                    if (result.message && (result.message.includes('already registered') || result.message.includes('National ID'))) {
                        document.getElementById('voterNationalId').classList.add('error-field');
                        document.getElementById('voterNationalId').focus();
                    }
                }
            } catch (error) {
                hideProcessingOverlay();
                showMessage('❌ Error creating voter: ' + error.message, false);
            }
        }

        function resetVoterForm() {
            const form = document.getElementById('createVoterFormElement');
            form.reset();
            
            // Reset extracted fields
            document.querySelectorAll('.extracted-field').forEach(field => {
                field.classList.remove('extracted-field');
                field.readOnly = false;
            });
            
            // Reset field status indicators
            document.querySelectorAll('.field-status').forEach(status => {
                status.style.display = 'none';
            });
            
            // Reset file uploads
            voterFrontImageFile = null;
            voterBackImageFile = null;
            extractedVoterIDData = null;
            document.getElementById('voterFrontPreviewText').textContent = 'No file selected';
            document.getElementById('voterBackPreviewText').textContent = 'No file selected';
            document.getElementById('voterFrontPreviewImage').innerHTML = '';
            document.getElementById('voterBackPreviewImage').innerHTML = '';
            document.getElementById('voterFrontPreviewContainer').classList.remove('active');
            document.getElementById('voterBackPreviewContainer').classList.remove('active');
            
            // Reset literacy selection
            document.querySelectorAll('.literate-option').forEach(option => {
                option.classList.remove('selected');
            });
            isLiterate = null;
            
            // Reset image password
            selectedImages = [];
            document.querySelectorAll('.image-option').forEach(option => {
                option.classList.remove('selected');
            });
            document.getElementById('selectedPreview').innerHTML = '';
            document.getElementById('selectedCount').textContent = '0';
            document.getElementById('ImagePassword').value = '';
            
            // Show text password section by default
            document.getElementById('textPasswordSection').style.display = 'grid';
            document.getElementById('imagePasswordSection').style.display = 'none';
            
            // Clear error fields
            document.querySelectorAll('.error-field').forEach(field => {
                field.classList.remove('error-field');
            });
            
            document.querySelectorAll('.field-detail-error').forEach(error => {
                error.remove();
            });
        }
    </script>
</body>
</html>