                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <div class="field-status auto-filled" id="voterSexStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <!-- Literacy Section -->
                        <div class="literate-section">
                            <label class="required">Are you literate?</label>
                            <p style="font-size: 14px; color: #666; margin-bottom: 15px; text-align: center;">
