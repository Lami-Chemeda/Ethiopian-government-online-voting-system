@model (List<CommentViewModel> AllComments, List<Supervisor> AvailableSupervisors)

@{
    ViewData["Title"] = "Admin Comments";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ethiopian e-Voting System</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* ALL YOUR EXISTING CSS STAYS EXACTLY THE SAME */
        :root {
            --primary-color: #1d3557;
            --secondary-color: #457b9d;
            --accent-color: #e63946;
            --success-color: #2a9d8f;
            --warning-color: #e9c46a;
            --light-color: #f1faee;
            --dark-color: #1d3557;
            --text-color: #2d3748;
            --border-radius: 16px;
            --box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Roboto', sans-serif;
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 25%, #a8dadc 50%, #f1faee 75%, #ffffff 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            margin: 0;
            padding: 0;
            position: relative;
            overflow-x: hidden;
            line-height: 1.6;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: radial-gradient(circle at 10% 20%, rgba(232, 65, 24, 0.08) 0%, transparent 40%),
                            radial-gradient(circle at 90% 80%, rgba(20, 126, 59, 0.08) 0%, transparent 40%),
                            radial-gradient(circle at 50% 50%, rgba(252, 209, 22, 0.06) 0%, transparent 50%),
                            linear-gradient(45deg, transparent 48%, rgba(29, 53, 87, 0.03) 50%, transparent 52%);
            z-index: -2;
            animation: backgroundShift 20s ease-in-out infinite;
        }

        @@keyframes backgroundShift {
            0%, 100% { transform: translateX(0px) translateY(0px); }
            50% { transform: translateX(-10px) translateY(-10px); }
        }

        .main-container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(20px);
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            width: 100%;
            max-width: 1400px;
            position: relative;
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: slideInUp 0.8s ease-out;
            margin: 20px 0;
            overflow: hidden;
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(50px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .header {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 40px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.8em;
            font-weight: 300;
            position: relative;
            z-index: 1;
        }

        .header p {
            font-size: 1.2em;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .back-home-btn {
            position: absolute;
            top: 30px;
            left: 30px;
            padding: 12px 20px;
            background: var(--accent-color);
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: var(--transition);
            font-size: 15px;
            box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
            font-family: 'Inter', sans-serif;
            z-index: 2;
        }

        .back-home-btn:hover {
            background: #c1121f;
            transform: translateX(-5px) scale(1.05);
            box-shadow: 0 6px 20px rgba(193, 18, 31, 0.4);
        }

        .content {
            padding: 40px;
            min-height: 600px;
        }

        /* Tab Styles */
        .tabs-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .tabs-header {
            display: flex;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            padding: 0;
        }

        .tab-btn {
            flex: 1;
            padding: 20px;
            background: none;
            border: none;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .tab-btn::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 3px;
            background: var(--warning-color);
            transition: var(--transition);
            transform: translateX(-50%);
        }

        .tab-btn.active::before {
            width: 100%;
        }

        .tab-btn:hover {
            background: rgba(255,255,255,0.1);
        }

        .tab-content {
            display: none;
            padding: 30px;
            animation: fadeIn 0.5s ease-in-out;
        }

        .tab-content.active {
            display: block;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-color);
        }

        .form-control {
            width: 100%;
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 16px;
            transition: var(--transition);
            background: white;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(69, 123, 157, 0.1);
        }

        textarea.form-control {
            resize: vertical;
            min-height: 120px;
            font-family: inherit;
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--success-color), #1a936f);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            width: 100%;
        }

        .submit-btn:hover {
            background: linear-gradient(135deg, #1a936f, var(--success-color));
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(42, 157, 143, 0.4);
        }

        /* Supervisor Select Styles */
        .supervisor-select-container {
            position: relative;
        }

        .supervisor-select-dropdown {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            padding: 15px;
            position: relative;
            min-height: 50px;
            display: flex;
            align-items: center;
        }

        .supervisor-select-dropdown::after {
            content: '▼';
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
        }

        .supervisor-select-dropdown.open::after {
            content: '▲';
        }

        .dropdown-options {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            background: white;
            border: 2px solid #e2e8f0;
            border-top: none;
            border-radius: 0 0 8px 8px;
            max-height: 200px;
            overflow-y: auto;
            z-index: 1000;
            display: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .dropdown-options.open {
            display: block;
        }

        .supervisor-option {
            padding: 12px 15px;
            cursor: pointer;
            border-bottom: 1px solid #f1f3f4;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition);
        }

        .supervisor-option:hover {
            background: #f8f9fa;
        }

        .supervisor-option.selected {
            background: var(--light-color);
            border-left: 4px solid var(--success-color);
        }

        .supervisor-option input[type="radio"] {
            margin: 0;
        }

        .supervisor-info {
            flex: 1;
        }

        .supervisor-name {
            font-weight: 600;
            color: var(--text-color);
        }

        .supervisor-details {
            font-size: 12px;
            color: #666;
        }

        /* Statistics Cards */
        .stats-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, #ffffff, #f8f9fa);
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            border-left: 5px solid var(--success-color);
            transition: transform 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card i {
            font-size: 2.5em;
            color: var(--secondary-color);
            margin-bottom: 15px;
        }

        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: var(--primary-color);
            display: block;
        }

        .stat-label {
            color: #666;
            font-size: 0.9em;
        }

        /* Comment List Styles */
        .comments-list {
            max-height: 500px;
            overflow-y: auto;
        }

        .comment-item {
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: var(--transition);
            border-left: 5px solid var(--success-color);
            position: relative;
        }

        .comment-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(42, 157, 143, 0.15);
        }

        .comment-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }

        .comment-sender {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sender-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 1.2em;
        }

        .sender-info h4 {
            color: var(--primary-color);
            margin-bottom: 5px;
            font-size: 1.3em;
        }

        .sender-badge {
            background: var(--secondary-color);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }

        .comment-time {
            color: #6c757d;
            font-size: 0.9em;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .comment-content {
            color: var(--text-color);
            line-height: 1.6;
            font-size: 1.05em;
            padding: 15px 0;
            border-top: 1px solid #e9ecef;
            border-bottom: 1px solid #e9ecef;
            margin: 15px 0;
        }

        .comment-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #f1f3f4;
            gap: 10px;
        }

        .comment-meta {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .comment-type {
            background: var(--warning-color);
            color: var(--primary-color);
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: bold;
        }

        .read-status {
            background: var(--secondary-color);
            color: white;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.8em;
            font-weight: bold;
        }

        /* Delete Button Styles */
        .delete-btn {
            background: #e63946;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8em;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .delete-btn:hover {
            background: #c1121f;
            transform: scale(1.05);
        }

        /* Alert Styles */
        .alert {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideInAlert 0.3s ease;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .alert-warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeaa7;
        }

        @@keyframes slideInAlert {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
        }

        .empty-icon {
            font-size: 4em;
            color: #a8dadc;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: var(--secondary-color);
            margin-bottom: 10px;
            font-size: 1.5em;
        }

        /* Filter Section */
        .filter-section {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 25px;
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .container {
                margin: 10px;
                padding: 0;
            }

            .content {
                padding: 20px;
            }

            .header {
                padding: 30px 20px;
            }

            .header h1 {
                font-size: 2.2em;
            }

            .tabs-header {
                flex-direction: column;
            }

            .tab-btn {
                padding: 15px;
            }

            .comment-header {
                flex-direction: column;
                gap: 10px;
            }

            .back-home-btn {
                position: relative;
                top: 0;
                left: 0;
                margin: 20px;
                align-self: flex-start;
            }

            .stats-cards {
                grid-template-columns: 1fr;
            }

            .comment-actions {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
            }

            .comment-meta {
                width: 100%;
                justify-content: space-between;
            }

            .delete-btn {
                align-self: flex-end;
            }
        }

        @@media (max-width: 480px) {
            .main-container {
                padding: 10px;
            }

            .header h1 {
                font-size: 1.8em;
            }

            .content {
                padding: 15px;
            }

            .comment-item {
                padding: 15px;
            }

            .sender-avatar {
                width: 40px;
                height: 40px;
                font-size: 1em;
            }

            .comment-meta {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="container">
            <a href="@Url.Action("Dashboard", "Admin")" class="back-home-btn">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>

            <div class="header">
                <h1><i class="fas fa-comments"></i> Admin Communication Center</h1>
                <p>Manage Communications with Supervisors and Monitor System Messages</p>
            </div>

            <div class="content">
                <!-- Display TempData messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> @TempData["Warning"]
                    </div>
                }

                <!-- Statistics Cards -->
                <div class="stats-cards">
                    <div class="stat-card">
                        <i class="fas fa-comment-dots"></i>
                        <span class="stat-number" id="totalComments">0</span>
                        <div class="stat-label">Total Comments</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-user-shield"></i>
                        <span class="stat-number" id="supervisorComments">0</span>
                        <div class="stat-label">From Supervisors</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-users"></i>
                        <span class="stat-number" id="voterComments">0</span>
                        <div class="stat-label">From Voters</div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-eye-slash"></i>
                        <span class="stat-number" id="unreadComments">0</span>
                        <div class="stat-label">Unread Messages</div>
                    </div>
                </div>

                <div class="tabs-container">
                    <div class="tabs-header">
                        <button class="tab-btn active" data-tab="to-supervisor">
                            <i class="fas fa-user-shield"></i> Message to Supervisor
                        </button>
                        <button class="tab-btn" data-tab="from-supervisors">
                            <i class="fas fa-inbox"></i> From Supervisors
                        </button>
                    </div>

                    <!-- Message to Supervisor Tab -->
                    <div class="tab-content active" id="to-supervisor">
                        <h3 style="color: var(--primary-color); margin-bottom: 20px;">
                            <i class="fas fa-user-shield"></i> Send Message to Supervisor
                        </h3>
                        <form method="post" action="@Url.Action("CreateCommentToSupervisor", "Admin")" id="supervisorMessageForm">
                            <div class="form-group">
                                <label for="supervisorSelect">Select Supervisor:</label>
                                <div class="supervisor-select-container">
                                    <div class="supervisor-select-dropdown" id="supervisorDropdown">
                                        Click to select a supervisor...
                                    </div>
                                    <div class="dropdown-options" id="supervisorOptions">
                                        @if (Model.AvailableSupervisors != null && Model.AvailableSupervisors.Any())
                                        {
                                            @foreach (var supervisor in Model.AvailableSupervisors)
                                            {
                                                <div class="supervisor-option" data-name="@supervisor.FirstName @supervisor.LastName" data-id="@supervisor.NationalId">
                                                    <input type="radio" name="supervisorNationalId" value="@supervisor.NationalId" id="supervisor_@supervisor.NationalId">
                                                    <div class="supervisor-info">
                                                        <div class="supervisor-name">@supervisor.FirstName @supervisor.LastName</div>
                                                        <div class="supervisor-details">ID: @supervisor.NationalId | Region: @supervisor.Region</div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="supervisor-option" style="justify-content: center; color: #666;">
                                                <i class="fas fa-exclamation-circle"></i> No active supervisors found
                                            </div>
                                        }
                                    </div>
                                </div>
                                <input type="hidden" id="selectedSupervisorId" name="supervisorNationalId">
                                <input type="hidden" id="selectedSupervisorName" name="supervisorName">
                            </div>
                            <div class="form-group">
                                <label for="subjectSupervisor">Subject:</label>
                                <input type="text" class="form-control" id="subjectSupervisor" name="subject" value="Administrative Instruction" required>
                            </div>
                            <div class="form-group">
                                <label for="contentSupervisor">Your Message:</label>
                                <textarea class="form-control" id="contentSupervisor" name="content" placeholder="Enter your message to the supervisor..." required maxlength="1000"></textarea>
                                <small style="color: #666; margin-top: 5px; display: block;">Maximum 1000 characters</small>
                            </div>
                            <button type="submit" class="submit-btn">
                                <i class="fas fa-paper-plane"></i> Send to Supervisor
                            </button>
                        </form>
                    </div>

                    <!-- From Supervisors Tab -->
                    <div class="tab-content" id="from-supervisors">
                        <h3 style="color: var(--primary-color); margin-bottom: 20px;">
                            <i class="fas fa-inbox"></i> Messages from Supervisors
                        </h3>
                        
                        <!-- Filter Section (PRESERVED FUNCTIONALITY) -->
                        <div class="filter-section">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="commentTypeFilter" class="form-label">Filter by Type:</label>
                                    <select class="form-select" id="commentTypeFilter">
                                        <option value="all">All Comments</option>
                                        <option value="SupervisorToAdmin">From Supervisors</option>
                                        <option value="VoterToAdmin">From Voters</option>
                                        <option value="AdminToSupervisor">To Supervisors</option>
                                        <option value="SupervisorToVoter">To Voters</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="dateFilter" class="form-label">Filter by Date:</label>
                                    <select class="form-select" id="dateFilter">
                                        <option value="all">All Time</option>
                                        <option value="today">Today</option>
                                        <option value="week">This Week</option>
                                        <option value="month">This Month</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="comments-list" id="supervisorCommentsList">
                            <!-- Comments will be loaded dynamically using preserved functionality -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

   <!-- Add AntiForgeryToken for security -->
@Html.AntiForgeryToken()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        initializeSupervisorSelect();
        loadAllComments(); // PRESERVED FUNCTIONALITY
        updateStatistics();
        
        // Add filter event listeners (PRESERVED FUNCTIONALITY)
        document.getElementById('commentTypeFilter').addEventListener('change', loadAllComments);
        document.getElementById('dateFilter').addEventListener('change', loadAllComments);

        // Add click handlers to dynamically loaded comment items for mark as read
        setTimeout(() => {
            const commentItems = document.querySelectorAll('.comment-item');
            
            commentItems.forEach(item => {
                const commentId = item.getAttribute('data-comment-id');
                
                // Add click event to mark as read when clicking anywhere on the comment
                item.addEventListener('click', function(e) {
                    // Don't trigger if delete button was clicked
                    if (!e.target.closest('.delete-btn')) {
                        const readStatus = item.querySelector('.read-status');
                        const isRead = readStatus ? readStatus.textContent.includes('Read') : false;
                        if (!isRead) {
                            markAsRead(commentId, item);
                        }
                    }
                });
            });

            // Add smooth animations
            commentItems.forEach((item, index) => {
                item.style.opacity = '0';
                item.style.transform = 'translateY(20px)';
                
                setTimeout(() => {
                    item.style.transition = 'all 0.5s ease';
                    item.style.opacity = '1';
                    item.style.transform = 'translateY(0)';
                }, index * 100);
            });
        }, 100);
    });

    // NEW: Function to mark comment as read (from SupervisorController)
    async function markAsRead(commentId, element) {
        try {
            console.log('Marking comment as read:', commentId);
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            console.log('AntiForgeryToken found:', !!token);
            
            const requestBody = {
                commentId: commentId
            };
            
            console.log('Sending request body:', requestBody);
            
            const response = await fetch('@Url.Action("MarkCommentAsRead", "Admin")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(requestBody)
            });

            console.log('Response status:', response.status);
            
            const result = await response.json();
            console.log('Server response:', result);
            
            if (result.success) {
                // Update UI exactly like supervisor controller
                element.classList.add('read');
                element.classList.remove('unread');
                
                const readStatus = document.getElementById(`read-status-${commentId}`);
                if (readStatus) {
                    readStatus.innerHTML = '<i class="fas fa-eye"></i> Read';
                    readStatus.style.background = "#2a9d8f";
                    readStatus.classList.add('read');
                    readStatus.classList.remove('unread');
                }
                
                // Update statistics
                updateStatistics();
                console.log('Comment marked as read successfully');
            } else {
                console.error('Failed to mark comment as read:', result.message);
                showAlert(result.message || 'Failed to mark comment as read', 'error');
            }
        } catch (error) {
            console.error('Error marking comment as read:', error);
            showAlert('Error marking comment as read. Please try again.', 'error');
        }
    }

    // UPDATED: Function to delete comment (using SupervisorController's approach)
    async function deleteComment(commentId, event) {
        if (event) {
            event.stopPropagation();
        }
        
        if (!confirm('Are you sure you want to delete this message?')) {
            return;
        }

        try {
            console.log('Deleting comment:', commentId);
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            const requestBody = {
                commentId: commentId
            };
            
            console.log('Sending request body:', requestBody);
            
            const response = await fetch('@Url.Action("DeleteComment", "Admin")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(requestBody)
            });

            console.log('Response status:', response.status);
            
            const result = await response.json();
            console.log('Server response:', result);
            
            if (result.success) {
                const commentElement = document.querySelector(`[data-comment-id="${commentId}"]`);
                if (commentElement) {
                    commentElement.style.opacity = '0';
                    commentElement.style.transform = 'translateX(-100px)';
                    setTimeout(() => {
                        commentElement.remove();
                        updateCommentsCount();
                        updateStatistics();
                    }, 300);
                }
                
                showAlert('Message deleted successfully!', 'success');
            } else {
                console.error('Delete failed:', result.message);
                showAlert(result.message || 'Failed to delete message', 'error');
            }
        } catch (error) {
            console.error('Error deleting message:', error);
            showAlert('Error deleting message. Please try again.', 'error');
        }
    }

    // Function to show alert messages (PRESERVED)
    function showAlert(message, type) {
        // Remove existing alerts
        const existingAlerts = document.querySelectorAll('.alert');
        existingAlerts.forEach(alert => alert.remove());

        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type}`;
        alertDiv.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check' : 'exclamation'}-circle"></i>
            ${message}
        `;
        
        const content = document.querySelector('.content');
        const statsCards = document.querySelector('.stats-cards');
        content.insertBefore(alertDiv, statsCards);
        
        // Auto remove after 5 seconds
        setTimeout(() => {
            if (alertDiv.parentElement) {
                alertDiv.style.opacity = '0';
                alertDiv.style.transform = 'translateY(-10px)';
                setTimeout(() => alertDiv.remove(), 300);
            }
        }, 5000);
    }

    // Update comments count after deletion (PRESERVED)
    function updateCommentsCount() {
        const commentItems = document.querySelectorAll('.comment-item');
        console.log(`Remaining comments: ${commentItems.length}`);
    }

    // Supervisor Select Functionality (PRESERVED)
    function initializeSupervisorSelect() {
        const supervisorDropdown = document.getElementById('supervisorDropdown');
        const supervisorOptions = document.getElementById('supervisorOptions');
        const supervisorRadios = supervisorOptions.querySelectorAll('input[type="radio"]');
        const selectedSupervisorId = document.getElementById('selectedSupervisorId');
        const selectedSupervisorName = document.getElementById('selectedSupervisorName');

        // Toggle dropdown
        supervisorDropdown.addEventListener('click', function(e) {
            e.stopPropagation();
            supervisorOptions.classList.toggle('open');
            supervisorDropdown.classList.toggle('open');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!supervisorDropdown.contains(e.target)) {
                supervisorOptions.classList.remove('open');
                supervisorDropdown.classList.remove('open');
            }
        });

        // Handle supervisor selection
        supervisorRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                const supervisorOption = this.closest('.supervisor-option');
                const supervisorName = supervisorOption.getAttribute('data-name');
                const supervisorId = this.value;

                // Update selected display
                supervisorDropdown.textContent = supervisorName;
                
                // Update hidden fields
                selectedSupervisorId.value = supervisorId;
                selectedSupervisorName.value = supervisorName;

                // Update UI
                supervisorRadios.forEach(r => {
                    r.closest('.supervisor-option').classList.remove('selected');
                });
                supervisorOption.classList.add('selected');

                // Close dropdown
                supervisorOptions.classList.remove('open');
                supervisorDropdown.classList.remove('open');
            });
        });
    }

    // Form validation for supervisor message (PRESERVED)
    document.getElementById('supervisorMessageForm').addEventListener('submit', function(e) {
        const supervisorId = document.getElementById('selectedSupervisorId').value;
        const message = document.getElementById('contentSupervisor').value.trim();
        const subject = document.getElementById('subjectSupervisor').value.trim();

        if (!supervisorId) {
            e.preventDefault();
            alert('Please select a supervisor.');
            return false;
        }

        if (!message) {
            e.preventDefault();
            alert('Please enter a message.');
            return false;
        }

        if (!subject) {
            e.preventDefault();
            alert('Please enter a subject.');
            return false;
        }

        return true;
    });

    // PRESERVED: Load all comments dynamically
    async function loadAllComments() {
        try {
            const response = await fetch('@Url.Action("GetCommentsData", "Admin")');
            const data = await response.json();
            
            if (data.success) {
                displayAllComments(data.comments);
                updateStatistics(data.comments);
                
                // Re-attach event listeners to newly loaded comments
                setTimeout(() => {
                    const commentItems = document.querySelectorAll('.comment-item');
                    
                    commentItems.forEach(item => {
                        const commentId = item.getAttribute('data-comment-id');
                        
                        // Add click event to mark as read when clicking anywhere on the comment
                        item.addEventListener('click', function(e) {
                            // Don't trigger if delete button was clicked
                            if (!e.target.closest('.delete-btn')) {
                                const readStatus = item.querySelector('.read-status');
                                const isRead = readStatus ? readStatus.textContent.includes('Read') : false;
                                if (!isRead) {
                                    markAsRead(commentId, item);
                                }
                            }
                        });
                    });
                }, 100);
            } else {
                console.error('Failed to load comments:', data.message);
                document.getElementById('supervisorCommentsList').innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <h3>Error Loading Comments</h3>
                        <p>Unable to load comments at the moment. Please try again later.</p>
                    </div>
                `;
            }
        } catch (error) {
            console.error('Error loading comments:', error);
        }
    }

    // PRESERVED: Display all comments with filtering
    function displayAllComments(comments) {
        const commentsList = document.getElementById('supervisorCommentsList');
        const typeFilter = document.getElementById('commentTypeFilter').value;
        const dateFilter = document.getElementById('dateFilter').value;
        
        // Filter comments
        let filteredComments = comments.filter(comment => 
            typeFilter === 'all' || comment.commentType === typeFilter
        );

        // Filter by date
        if (dateFilter === 'today') {
            const today = new Date().toDateString();
            filteredComments = filteredComments.filter(comment => 
                new Date(comment.createdAt).toDateString() === today
            );
        } else if (dateFilter === 'week') {
            const weekAgo = new Date();
            weekAgo.setDate(weekAgo.getDate() - 7);
            filteredComments = filteredComments.filter(comment => 
                new Date(comment.createdAt) >= weekAgo
            );
        } else if (dateFilter === 'month') {
            const monthAgo = new Date();
            monthAgo.setMonth(monthAgo.getMonth() - 1);
            filteredComments = filteredComments.filter(comment => 
                new Date(comment.createdAt) >= monthAgo
            );
        }

        if (filteredComments.length === 0) {
            commentsList.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-comment-slash"></i>
                    </div>
                    <h3>No Comments Found</h3>
                    <p>No comments match your current filter criteria.</p>
                </div>
            `;
            return;
        }

        commentsList.innerHTML = filteredComments.map(comment => `
            <div class="comment-item" data-comment-id="${comment.id}">
                <div class="comment-header">
                    <div class="comment-sender">
                        <div class="sender-avatar">
                            ${comment.senderName ? comment.senderName.substring(0, 1) : 'U'}
                        </div>
                        <div class="sender-info">
                            <h4>${comment.senderName}</h4>
                            <div class="sender-badge">
                                <i class="fas fa-${comment.senderType === 'Supervisor' ? 'user-shield' : comment.senderType === 'Admin' ? 'user-cog' : 'user'}"></i>
                                ${comment.senderType}
                            </div>
                        </div>
                    </div>
                    <div class="comment-time">
                        <i class="far fa-clock"></i>
                        ${formatTimeAgo(comment.createdAt)}
                    </div>
                </div>

                <div class="comment-content">
                    <p>${comment.content}</p>
                </div>

                <div class="comment-actions">
                    <div class="comment-meta">
                        <span class="comment-type">
                            <i class="fas fa-tag"></i>
                            ${comment.commentType}
                        </span>
                        <span class="read-status" id="read-status-${comment.id}" style="background: ${comment.isRead ? '#2a9d8f' : '#e63946'};">
                            <i class="fas fa-${comment.isRead ? 'eye' : 'eye-slash'}"></i>
                            ${comment.isRead ? 'Read' : 'Unread'}
                        </span>
                        <span style="background: var(--warning-color); color: var(--primary-color); padding: 4px 12px; border-radius: 15px; font-weight: bold; font-size: 0.9em;">
                            <i class="fas fa-paperclip"></i>
                            ${comment.subject}
                        </span>
                    </div>
                    <button class="delete-btn" onclick="deleteComment(${comment.id}, event)">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        `).join('');
    }

    // PRESERVED: Update statistics
    function updateStatistics(comments = []) {
        // If no comments provided, use the model data
        if (comments.length === 0) {
            comments = @Json.Serialize(Model.AllComments ?? new List<CommentViewModel>());
        }

        document.getElementById('totalComments').textContent = comments.length;
        document.getElementById('supervisorComments').textContent = comments.filter(c => c.senderType === 'Supervisor').length;
        document.getElementById('voterComments').textContent = comments.filter(c => c.senderType === 'Voter').length;
        document.getElementById('unreadComments').textContent = comments.filter(c => !c.isRead).length;
    }

    // PRESERVED: Format time ago
    function formatTimeAgo(dateString) {
        const date = new Date(dateString);
        const timeSpan = new Date() - date;
        const days = Math.floor(timeSpan / (1000 * 60 * 60 * 24));
        const hours = Math.floor(timeSpan / (1000 * 60 * 60));
        const minutes = Math.floor(timeSpan / (1000 * 60));

        if (days >= 1) {
            return `${days} day${days !== 1 ? 's' : ''} ago`;
        } else if (hours >= 1) {
            return `${hours} hour${hours !== 1 ? 's' : ''} ago`;
        } else {
            return `${minutes} minute${minutes !== 1 ? 's' : ''} ago`;
        }
    }

    // Tab functionality (PRESERVED)
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const tabId = this.getAttribute('data-tab');
            
            // Remove active class from all buttons and contents
            tabBtns.forEach(b => b.classList.remove('active'));
            tabContents.forEach(c => c.classList.remove('active'));
            
            // Add active class to current button and content
            this.classList.add('active');
            document.getElementById(tabId).classList.add('active');

            // Load comments when switching to from-supervisors tab
            if (tabId === 'from-supervisors') {
                loadAllComments();
            }
        });
    });

    // Auto-hide alerts after 5 seconds (PRESERVED)
    setTimeout(() => {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            alert.style.transition = 'opacity 0.5s ease';
            alert.style.opacity = '0';
            setTimeout(() => alert.remove(), 500);
        });
    }, 5000);
</script>
</body>
</html>