        // EXISTING: Load all users
        async function loadAllUsers() {
            const loadingElement = document.getElementById('usersLoading');
            const tableElement = document.getElementById('usersTable');
            
            loadingElement.style.display = 'block';
            tableElement.style.display = 'none';
            
            try {
                const response = await fetch('/Admin/GetAllUsers');
                const result = await response.json();
                
                if (result.success) {
                    allUsers = result.users;
                    filteredUsers = [...allUsers];
                    displayUsers(allUsers);
                    populateUserDropdowns();
                    
                    loadingElement.style.display = 'none';
                    tableElement.style.display = 'table';
                } else {
                    showMessage('Error loading users: ' + result.message, false);
                    loadingElement.style.display = 'none';
