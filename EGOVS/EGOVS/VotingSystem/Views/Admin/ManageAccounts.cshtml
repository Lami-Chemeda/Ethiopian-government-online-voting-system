        // NEW: Handle candidate image upload
        function handleCandidateImageUpload(event, type) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateImageFile(file)) {
                showMessage('Please select a valid image file (JPG, PNG, BMP) under 5MB', false);
                event.target.value = '';
                return;
            }

            // Store file reference
            if (type === 'photo') candidatePhotoFile = file;
            else if (type === 'logo') candidateLogoFile = file;
            else if (type === 'symbol') candidateSymbolFile = file;

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageData = e.target.result;
                updateCandidatePreview(type, imageData);
            };
            reader.readAsDataURL(file);
        }

