        // EXISTING: Display users
        function displayUsers(users) {
            const tbody = document.getElementById('usersTableBody');
            tbody.innerHTML = '';
            
            if (users.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center; padding: 20px;">No users found</td></tr>';
                return;
            }
            
            users.forEach(user => {
                const row = document.createElement('tr');
                
                // Add candidate-specific information if available
                const candidateInfo = user.role === 'Candidate' ? 
                    `<br><small>Party: ${user.party || 'N/A'} | Symbol: ${user.symbolName || 'N/A'}</small>` : '';
                
                row.innerHTML = `
                    <td>${user.nationalId}</td>
                    <td>
                        ${user.firstName} ${user.middleName} ${user.lastName}
                        ${candidateInfo}
                    </td>
                    <td><span class="role-badge role-${user.role.toLowerCase()}">${user.role}</span></td>
                    <td>
                        ${user.phoneNumber}<br>
                        <small>${user.email || 'No email'}</small>
                    </td>
                    <td>${user.region}</td>
                    <td><span class="status-badge ${user.isActive ? 'status-active' : 'status-inactive'}">${user.isActive ? 'ACTIVE' : 'INACTIVE'}</span></td>
                    <td>${new Date(user.createdAt).toLocaleDateString()}</td>
                    <td class="action-cell">
                        <button class="btn-edit" onclick="editUser('${user.nationalId}', '${user.role}')" title="Edit">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-toggle ${!user.isActive ? 'inactive' : ''}" onclick="quickToggleStatus('${user.nationalId}', '${user.role}', ${!user.isActive})" title="${user.isActive ? 'Deactivate' : 'Activate'}">
                            <i class="fas fa-power-off"></i>
                        </button>
                        <button class="btn-delete" onclick="quickDeleteUser('${user.nationalId}', '${user.role}')" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // EXISTING: Populate user dropdowns
        function populateUserDropdowns() {
            const dropdowns = [
                'updateUserSelect', 'deleteUserSelect', 'toggleUserSelect'
            ];
            
            dropdowns.forEach(dropdownId => {
                const select = document.getElementById(dropdownId);
                if (select) {
                    select.innerHTML = '<option value="">Select a user</option>';
                    allUsers.forEach(user => {
                        const option = new Option(
                            `${user.firstName} ${user.lastName} - ${user.role} (${user.nationalId})`,
                            user.nationalId
                        );
                        select.add(option);
                    });
                }
            });
        }

        // EXISTING: Filter and Search
        function filterUsers() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const roleFilter = document.getElementById('roleFilter').value;
            const statusFilter = document.getElementById('statusFilter').value;
            
            filteredUsers = allUsers.filter(user => {
                const matchesSearch = 
                    user.nationalId.toLowerCase().includes(searchTerm) ||
                    user.firstName.toLowerCase().includes(searchTerm) ||
                    user.lastName.toLowerCase().includes(searchTerm) ||
                    user.role.toLowerCase().includes(searchTerm) ||
                    (user.party && user.party.toLowerCase().includes(searchTerm));
                
                const matchesRole = !roleFilter || user.role === roleFilter;
                const matchesStatus = statusFilter === '' || user.isActive.toString() === statusFilter;
                
                return matchesSearch && matchesRole && matchesStatus;
            });
            
            displayUsers(filteredUsers);
        }

        // EXISTING: Form Operations
        async function validateNationalId(nationalId) {
            if (!nationalId || nationalId.length < 5) return true;
            
            try {
                const response = await fetch(`/Admin/CheckNationalId?nationalId=${encodeURIComponent(nationalId)}`);
                const result = await response.json();
                
                const errorElement = document.getElementById('nationalIdError');
                const nationalIdField = document.getElementById('createNationalId');
                
                if (result.exists) {
                    errorElement.textContent = result.message;
                    errorElement.style.display = 'block';
                    nationalIdField.classList.add('error-field');
                    return false;
                } else {
                    errorElement.style.display = 'none';
                    nationalIdField.classList.remove('error-field');
                    return true;
                }
            } catch (error) {
                console.error('Error validating National ID:', error);
                return true;
            }
        }

        // ENHANCED: Create user with FormData support and proper voter literacy handling
        async function createUser(e) {
            e.preventDefault();
            
            console.log('🎯 Starting user creation process...');
            
            const nationalId = document.getElementById('createNationalId').value.trim();
            const role = document.getElementById('createRole').value;
            const literate = isLiterate; // Get from global variable
            
            // Basic validation
            if (!nationalId || !role) {
                showMessage('National ID and Role are required fields.', false);
                return;
            }
            
            // Validate National ID
            const isNationalIdValid = await validateNationalId(nationalId);
            if (!isNationalIdValid) {
                showMessage('Please fix the National ID error before submitting.', false);
                return;
            }
            
            // Validate required fields
            const requiredFields = [
                'createFirstName', 'createMiddleName', 'createLastName', 
                'createPhoneNumber', 'createNationality', 'createRegion', 
                'createAge', 'createSex'
            ];
            
            for (const fieldId of requiredFields) {
                const field = document.getElementById(fieldId);
                if (!field.value.trim()) {
                    showMessage(`Please fill in all required fields: ${fieldId.replace('create', '')}`, false);
                    field.focus();
                    return;
                }
            }
            
            // Phone validation
            const phoneNumber = document.getElementById('createPhoneNumber').value.trim();
            if (!validatePhoneNumber(phoneNumber)) {
                showMessage('Invalid phone number format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)', false);
                return;
            }
            
            // Voter-specific validation
            if (role === 'Voter') {
                if (!literate) {
                    showMessage('Please select literacy status for voter.', false);
                    return;
                }
                
                if (literate === 'No') {
                    if (selectedImages.length !== 4) {
                        showMessage('Please select exactly 4 images for the password of illiterate voters.', false);
                        return;
                    }
                } else {
                    // For literate voters, validate text password
                    const password = document.getElementById('createPassword').value;
                    const confirmPassword = document.getElementById('createConfirmPassword').value;
                    
                    if (!password || password.length < 6) {
                        showMessage('Password must be at least 6 characters long for literate voters.', false);
                        return;
                    }
                    
                    // Password strength validation
                    if (!validatePassword(password)) {
                        showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                        return;
                    }
                    
                    if (password !== confirmPassword) {
                        showMessage('Passwords do not match for literate voters.', false);
                        return;
                    }
                }
            } else {
                // For non-voter roles, validate text password
                const password = document.getElementById('createPassword').value;
                const confirmPassword = document.getElementById('createConfirmPassword').value;
                
                if (!password || password.length < 6) {
                    showMessage('Password must be at least 6 characters long.', false);
                    return;
                }
                
                // Password strength validation
                if (!validatePassword(password)) {
                    showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                    return;
                }
                
                if (password !== confirmPassword) {
                    showMessage('Passwords do not match.', false);
                    return;
                }
            }
            
            // Email validation for Manager and Supervisor
            if (role === 'Manager' || role === 'Supervisor') {
                const email = document.getElementById('createEmail').value.trim();
                if (email && !validateEmail(email)) {
                    showMessage('Email must contain at least one letter, @@ symbol, and at least one number (e.g., user123@@example.com)', false);
                    return;
                }
            }
            
            // Username validation for Manager
            if (role === 'Manager') {
                const username = document.getElementById('createUsername').value.trim();
                if (username && !validateUsername(username)) {
                    showMessage('Username can only contain letters (A-Z, a-z), numbers, underscores, and hyphens', false);
                    return;
                }
            }
            
            // Candidate-specific validation
            if (role === 'Candidate') {
                const party = document.getElementById('createParty').value.trim();
                const symbolName = document.getElementById('createSymbolName').value;
                const symbolUnicode = document.getElementById('createSymbolUnicode').value;
                const partyColor = document.getElementById('createPartyColor').value;
                
                if (!party) {
                    showMessage('Political party is required for candidates.', false);
                    return;
                }
                
                if (!symbolName) {
                    showMessage('Symbol name is required for candidates.', false);
                    return;
                }
                
                if (!symbolUnicode) {
                    showMessage('Symbol unicode is required for candidates.', false);
                    return;
                }
                
                if (!partyColor) {
                    showMessage('Party color is required for candidates.', false);
                    return;
                }
            }
            
            // Manager-specific validation
            if (role === 'Manager') {
                const email = document.getElementById('createEmail').value.trim();
                const username = document.getElementById('createUsername').value.trim();
                
                if (!email) {
                    showMessage('Email is required for managers.', false);
                    return;
                }
                
                if (!username) {
                    // Auto-generate username if not provided
                    document.getElementById('createUsername').value = nationalId;
                }
            }
            
            // Supervisor-specific validation
            if (role === 'Supervisor') {
                const email = document.getElementById('createEmail').value.trim();
                if (!email) {
                    showMessage('Email is required for supervisors.', false);
                    return;
                }
            }
            
            // Age validation
            const age = parseInt(document.getElementById('createAge').value);
            if (age < 18 || age > 120) {
                showMessage('Age must be between 18 and 120.', false);
                return;
            }

            // Sex validation
            const sex = document.getElementById('createSex').value;
            if (sex !== 'Male' && sex !== 'Female') {
                showMessage('Sex must be Male or Female.', false);
                return;
            }
            
            // Prepare form data with FormData
            const formData = new FormData();
            formData.append('NationalId', nationalId);
            formData.append('FirstName', document.getElementById('createFirstName').value.trim());
            formData.append('MiddleName', document.getElementById('createMiddleName').value.trim());
            formData.append('LastName', document.getElementById('createLastName').value.trim());
            formData.append('PhoneNumber', document.getElementById('createPhoneNumber').value.trim());
            formData.append('Password', document.getElementById('createPassword').value);
            formData.append('Role', role);
            formData.append('Nationality', document.getElementById('createNationality').value);
            formData.append('Region', document.getElementById('createRegion').value);
            formData.append('Age', parseInt(document.getElementById('createAge').value));
            formData.append('Sex', document.getElementById('createSex').value);
            formData.append('Email', document.getElementById('createEmail').value || '');
            formData.append('Username', document.getElementById('createUsername').value || '');
            formData.append('Party', document.getElementById('createParty').value || '');
            formData.append('Bio', document.getElementById('createBio').value || '');
            formData.append('Literate', literate || '');
            formData.append('ImagePassword', document.getElementById('ImagePassword').value || '');
            formData.append('QRCodeData', document.getElementById('createQRCodeData').value);
            formData.append('VisualPIN', document.getElementById('createVisualPIN').value);
            formData.append('PrefersVisualLogin', document.getElementById('createPrefersVisualLogin').value === 'true');
            
            // Add candidate-specific fields
            formData.append('SymbolName', document.getElementById('createSymbolName').value || '');
            formData.append('SymbolUnicode', document.getElementById('createSymbolUnicode').value || '');
            formData.append('PartyColor', document.getElementById('createPartyColor').value || '#1d3557');
            
            // Append candidate image files
            if (role === 'Candidate') {
                console.log('📸 Appending candidate image files to FormData...');
                
                // Append candidate photo
                if (candidatePhotoFile) {
                    console.log('📷 Appending candidate photo:', candidatePhotoFile.name);
                    formData.append('createPhotoUpload', candidatePhotoFile);
                }
                
                // Append party logo
                if (candidateLogoFile) {
                    console.log('🏢 Appending party logo:', candidateLogoFile.name);
                    formData.append('createLogoUpload', candidateLogoFile);
                }
                
                // Append symbol image
                if (candidateSymbolFile) {
                    console.log('🖼️ Appending symbol image:', candidateSymbolFile.name);
                    formData.append('createSymbolUpload', candidateSymbolFile);
                }
            }
            
            console.log('📦 Sending user data with FormData');
            console.log('📋 FormData entries:');
            for (let pair of formData.entries()) {
                console.log(`   ${pair[0]}:`, pair[0].includes('Upload') ? `FILE - ${pair[1].name}` : pair[1]);
            }
            
            try {
                showMessage('⏳ Creating user account...', true);
                
                const response = await fetch('/Admin/CreateUser', {
                    method: 'POST',
                    body: formData
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    resetCreateForm();
                    await loadAllUsers();
                    await loadUserStatistics();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                console.error('Error creating user:', error);
                showMessage('❌ Error creating user: ' + error.message, false);
            }
        }

