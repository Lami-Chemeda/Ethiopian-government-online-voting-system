            }
            if (data.phoneNumber && data.phoneNumber.trim() !== '') {
                document.getElementById('createPhoneNumber').value = data.phoneNumber.trim();
                markFieldAsExtractedFromOCR('PhoneNumber');
            }
            if (data.nationality && data.nationality.trim() !== '') {
                document.getElementById('createNationality').value = data.nationality.trim();
                markFieldAsExtractedFromOCR('Nationality');
            } else {
                document.getElementById('createNationality').value = 'Ethiopian';
                markFieldAsExtractedFromOCR('Nationality');
            }
            if (data.region && data.region.trim() !== '') {
                document.getElementById('createRegion').value = data.region;
                markFieldAsExtractedFromOCR('Region');
            }
            if (data.sex && data.sex.trim() !== '') {
                document.getElementById('createSex').value = data.sex;
                markFieldAsExtractedFromOCR('Sex');
            }
            if (data.age && data.age > 0) {
                document.getElementById('createAge').value = data.age;
                markFieldAsExtractedFromOCR('Age');
            }

            showMessage('✅ ID information successfully extracted! Fields are now locked.', true);
        }

