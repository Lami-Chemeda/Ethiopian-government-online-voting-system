        // EXISTING: Handle file upload
        function handleFileUpload(event, side) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateImageFile(file)) {
                showMessage('Please select a valid image file (JPG, PNG, BMP) under 5MB', false);
                event.target.value = '';
                return;
            }

            if (side === 'front') {
                frontImageFile = file;
            } else {
                backImageFile = file;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageData = e.target.result;
                updatePreview(side, imageData, file.name);
            };
            reader.readAsDataURL(file);
        }

        // EXISTING: Validate image file
        function validateImageFile(file) {
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/bmp'];
            const maxSize = 5 * 1024 * 1024;
            return allowedTypes.includes(file.type) && file.size <= maxSize;
        }

        // EXISTING: Update preview
        function updatePreview(side, imageData, fileName) {
            const container = document.getElementById(side + 'PreviewContainer');
            const textElement = document.getElementById(side + 'PreviewText');
            const imageElement = document.getElementById(side + 'PreviewImage');

            if (container && textElement && imageElement) {
                container.classList.add('active');
                textElement.textContent = fileName;
                textElement.style.color = '#28a745';
                textElement.style.fontWeight = 'bold';
                imageElement.innerHTML = `<img src="${imageData}" alt="${side} side preview" style="max-width: 100%; max-height: 120px; border-radius: 6px;">`;
            }
        }

        // EXISTING: Extract ID information
        async function extractIDInformation() {
            if (!frontImageFile && !backImageFile) {
                showMessage('Please upload at least one ID image (front or back)', false);
                return;
            }

            try {
                showOCRProcessing('🔍 Scanning Ethiopian ID card...');

                const formData = new FormData();
                if (frontImageFile) formData.append('FrontImage', frontImageFile);
                if (backImageFile) formData.append('BackImage', backImageFile);

                const response = await fetch('/Admin/ProcessIDPhotos', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const result = await response.json();
                
                if (result.success) {
                    extractedIDData = result.data;
                    showMessage(`✅ ${result.message || 'ID information extracted successfully!'}`, true);
                    fillFormWithIDData(result.data);
                } else {
                    showMessage('❌ ' + (result.error || 'Failed to extract ID information'), false);
                }
                
            } catch (error) {
                showMessage('❌ Error scanning ID: ' + error.message, false);
            } finally {
                setTimeout(() => {
                    hideOCRProcessing();
                }, 2000);
            }
        }

