                field.style.display = 'none';
            });
            
            // Reset voter-specific fields
            isLiterate = null;
            selectedImages = [];
            document.querySelectorAll('.literate-option').forEach(option => {
                option.classList.remove('selected');
            });
            document.querySelectorAll('.image-option').forEach(option => {
                option.classList.remove('selected');
            });
            
            const selectedPreview = document.getElementById('selectedPreview');
            const selectedCount = document.getElementById('selectedCount');
            const imagePasswordField = document.getElementById('ImagePassword');
            
            if (selectedPreview) selectedPreview.innerHTML = '';
            if (selectedCount) selectedCount.textContent = '0';
            if (imagePasswordField) imagePasswordField.value = '';
            
            // Show text password section by default
            const textPasswordSection = document.getElementById('textPasswordSection');
            const imagePasswordSection = document.getElementById('imagePasswordSection');
            const voterSpecificSection = document.getElementById('voterSpecificSection');
            const candidateSymbolSection = document.getElementById('candidateSymbolSection');
            
            if (textPasswordSection) textPasswordSection.style.display = 'grid';
            if (imagePasswordSection) imagePasswordSection.style.display = 'none';
            if (voterSpecificSection) voterSpecificSection.style.display = 'none';
            if (candidateSymbolSection) candidateSymbolSection.style.display = 'none';
            
            // Clear error fields
            clearAllFieldErrors();
            
            // Re-initialize voter fields
            initializeVoterFields();
        }

        // ENHANCED: Update User functionality with candidate support
        function loadUserForUpdate() {
            const nationalId = document.getElementById('updateUserSelect').value;
            const user = allUsers.find(u => u.nationalId === nationalId);
            
            if (user) {
                document.getElementById('updateRole').value = user.role;
                document.getElementById('updateNationalId').value = user.nationalId;
                document.getElementById('updateName').value = `${user.firstName} ${user.middleName} ${user.lastName}`;
                document.getElementById('updateEmail').value = user.email || '';
                document.getElementById('updatePhoneNumber').value = user.phoneNumber;
                document.getElementById('updateIsActive').value = user.isActive.toString();
                document.getElementById('updateParty').value = user.party || '';
                document.getElementById('updateBio').value = user.bio || '';
                document.getElementById('updateSymbolName').value = user.symbolName || '';
                document.getElementById('updatePartyColor').value = user.partyColor || '#1d3557';
                document.getElementById('updateColorPreview').style.backgroundColor = user.partyColor || '#1d3557';
                document.getElementById('updateColorValue').textContent = user.partyColor || '#1d3557';
                document.getElementById('updateLiterate').value = user.literate || 'Yes';
                
                // Clear password fields
                document.getElementById('updatePassword').value = '';
                document.getElementById('updateConfirmPassword').value = '';
                
                // Clear any validation errors
                clearFieldError('updateEmail');
                clearFieldError('updateUsername');
                clearFieldError('updatePassword');
                clearFieldError('updateConfirmPassword');
                
                // Show/hide role-specific fields
                document.getElementById('updatePartyGroup').style.display = user.role === 'Candidate' ? 'block' : 'none';
                document.getElementById('updateBioGroup').style.display = user.role === 'Candidate' ? 'block' : 'none';
                document.getElementById('updateSymbolNameGroup').style.display = user.role === 'Candidate' ? 'block' : 'none';
                document.getElementById('updatePartyColorGroup').style.display = user.role === 'Candidate' ? 'block' : 'none';
                document.getElementById('updateLiterateGroup').style.display = user.role === 'Voter' ? 'block' : 'none';
            }
        }

        // ENHANCED: Update user with candidate support and validation
        async function updateUser(e) {
            e.preventDefault();
            
            const nationalId = document.getElementById('updateUserSelect').value;
            const role = document.getElementById('updateRole').value;
            
            // Phone validation
            const phoneNumber = document.getElementById('updatePhoneNumber').value.trim();
            if (!validatePhoneNumber(phoneNumber)) {
                showMessage('Invalid phone number format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)', false);
                return;
            }
            
            // Email validation (optional but if provided, validate)
            const email = document.getElementById('updateEmail').value.trim();
            if (email && !validateEmail(email)) {
                showMessage('Email must contain at least one letter, @@ symbol, and at least one number (e.g., user123@@example.com)', false);
                return;
            }
            
            // Username validation (optional)
            const username = document.getElementById('updateUsername').value.trim();
            if (username && !validateUsername(username)) {
                showMessage('Username can only contain letters (A-Z, a-z), numbers, underscores, and hyphens', false);
                return;
            }
            
            // Password validation (optional)
            const password = document.getElementById('updatePassword').value;
            const confirmPassword = document.getElementById('updateConfirmPassword').value;
            
            if (password) {
                if (password !== confirmPassword) {
                    showMessage('Password and Confirm Password do not match.', false);
                    return;
                }

                if (!validatePassword(password)) {
                    showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
                    return;
                }
            }
            
            const userData = {
                NationalId: nationalId,
                Role: role,
                Email: email,
                PhoneNumber: phoneNumber,
                Password: password,
                IsActive: document.getElementById('updateIsActive').value === 'true',
                Party: document.getElementById('updateParty').value,
                Bio: document.getElementById('updateBio').value,
                SymbolName: document.getElementById('updateSymbolName').value,
                PartyColor: document.getElementById('updatePartyColor').value,
                Literate: document.getElementById('updateLiterate').value
            };
            
            try {
                const response = await fetch('/Admin/UpdateUser', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(userData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    // Reset password fields only
                    document.getElementById('updatePassword').value = '';
                    document.getElementById('updateConfirmPassword').value = '';
                    // Clear validation errors
                    clearFieldError('updatePassword');
                    clearFieldError('updateConfirmPassword');
                    await loadAllUsers();
                    await loadUserStatistics();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                showMessage('❌ Error updating user: ' + error.message, false);
            }
        }

        // EXISTING: Delete User functionality
        async function deleteUser(e) {
            e.preventDefault();
            
            const nationalId = document.getElementById('deleteUserSelect').value;
            const user = allUsers.find(u => u.nationalId === nationalId);
            
            if (!user) {
                showMessage('Please select a user to delete', false);
                return;
            }
            
            if (!confirm(`Are you sure you want to permanently delete ${user.firstName} ${user.lastName} (${user.role})? This action cannot be undone.`)) {
                return;
            }
            
            const userData = {
                NationalId: nationalId,
                Role: user.role
            };
            
            try {
                const response = await fetch('/Admin/DeleteUser', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(userData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showMessage('✅ ' + result.message, true);
                    e.target.reset();
                    document.getElementById('deleteUserInfo').style.display = 'none';
                    await loadAllUsers();
                    await loadUserStatistics();
                } else {
                    showMessage('❌ ' + result.message, false);
                }
            } catch (error) {
                showMessage('❌ Error deleting user: ' + error.message, false);
            }
        }

