@{
    ViewData["Title"] = "Manage Supervisors";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1d3557 0%, #457b9d 25%, #a8dadc 50%, #f1faee 75%, #ffffff 100%);
            min-height: 100vh;
            padding: 20px;
            position: relative;
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            background: linear-gradient(45deg, #FFD700, #FFA500);
            color: #8B0000;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
            transition: all 0.3s ease;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn:hover {
            background: linear-gradient(45deg, #FFA500, #FF8C00);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            overflow: hidden;
            margin-top: 60px;
        }

        .header {
            background: linear-gradient(135deg, #8B0000, #B22222);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .content {
            padding: 40px;
        }

        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .action-btn {
            background: linear-gradient(45deg, #8B0000, #B22222);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            background: linear-gradient(45deg, #B22222, #8B0000);
            transform: translateY(-2px);
        }

        .form-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            margin-top: 20px;
            display: none;
        }

        .form-group {
            margin-bottom: 15px;
            position: relative;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #8B0000;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }

        .form-group textarea {
            height: 100px;
            resize: vertical;
        }

        .submit-btn {
            background: linear-gradient(45deg, #8B0000, #B22222);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            background: linear-gradient(45deg, #B22222, #8B0000);
            transform: translateY(-2px);
        }

        .supervisors-list {
            margin-top: 30px;
        }

        .supervisor-item {
            background: white;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            border-left: 4px solid #8B0000;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .supervisor-actions button {
            margin-left: 10px;
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .edit-btn {
            background: #FFA500;
            color: white;
        }

        .delete-btn {
            background: #DC143C;
            color: white;
        }

        .status-btn {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #808080;
        }

        .message {
            padding: 10px;
            margin: 10px 0;
            border-radius: 5px;
            text-align: center;
            display: none;
        }

        .success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .status-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }

        .status-active {
            background: #32CD32;
            color: white;
        }

        .status-inactive {
            background: #DC143C;
            color: white;
        }

        .password-toggle {
            position: relative;
        }

        .password-toggle input {
            padding-right: 40px;
        }

        .toggle-password {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
        }

        /* Supervisor Registration Styles */
        .upload-section {
            margin: 15px 0;
            padding: 15px;
            border: 2px dashed #1d3557;
            border-radius: 8px;
            background: #f8f9fa;
            text-align: center;
        }

        .upload-btn {
            background: #1d3557;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin: 5px;
        }

        .upload-btn:hover {
            background: #457b9d;
        }

        .file-input {
            display: none;
        }

        .id-preview-container {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .id-preview {
            flex: 1;
            text-align: center;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: white;
        }

        .id-preview.active {
            border-color: #28a745;
            background: #f8fff9;
        }

        .id-preview img {
            max-width: 100%;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

        .upload-instructions {
            background: #e7f3ff;
            border: 1px solid #b3d9ff;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 10px;
            text-align: center;
        }

        .ocr-processing {
            background: linear-gradient(135deg, #e3f2fd, #bbdefb);
            border: 2px solid #1d3557;
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
            text-align: center;
            display: none;
            animation: pulse-animation 2s infinite;
        }

        .upload-quality-tips {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            padding: 10px;
            border-radius: 6px;
            margin-top: 10px;
            font-size: 14px;
            text-align: left;
        }

        .upload-quality-tips h6 {
            margin: 0 0 8px 0;
            color: #856404;
        }

        .upload-quality-tips ul {
            margin: 0;
            padding-left: 20px;
        }

        .upload-quality-tips li {
            margin-bottom: 5px;
        }

        .action-buttons-ocr {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .action-buttons-ocr button {
            flex: 1;
            margin-top: 0;
        }

        .extract-btn {
            background: #28a745;
        }

        .extract-btn:hover {
            background: #218838;
        }

        .demo-btn {
            background: #6c757d;
        }

        .demo-btn:hover {
            background: #5a6268;
        }

        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 0.2em solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border-animation .75s linear infinite;
        }

        @@keyframes spinner-border-animation {
            to { transform: rotate(360deg); }
        }

        @@keyframes pulse-animation {
            0% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(29, 53, 87, 0); }
            100% { box-shadow: 0 0 0 0 rgba(29, 53, 87, 0); }
        }

        .processing-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .processing-content {
            background: white;
            padding: 30px;
            border-radius: 10px;
            text-align: center;
            max-width: 400px;
            width: 90%;
        }

        .progress-bar {
            width: 100%;
            height: 20px;
            background: #f0f0f0;
            border-radius: 10px;
            margin: 15px 0;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: #1d3557;
            width: 0%;
            transition: width 0.3s ease;
        }

        .extracted-field {
            background-color: #f8f9fa !important;
            border: 2px solid #28a745 !important;
            color: #155724 !important;
            font-weight: bold !important;
            cursor: not-allowed !important;
        }

        .field-status {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: inline-block;
        }

        .field-status.auto-filled {
            background: #d4edda;
            color: #155724;
        }

        .field-status.manual {
            background: #fff3cd;
            color: #856404;
        }

        .error-field {
            border: 2px solid #dc3545 !important;
            background-color: #f8d7da !important;
        }

        .required::after {
            content: " *";
            color: red;
        }

        .readonly-field {
            background-color: #f8f9fa !important;
            cursor: not-allowed !important;
            color: #6c757d !important;
        }

        /* ADDED VALIDATION STYLES FROM MANAGER */
        .field-error {
            font-size: 12px;
            margin-top: 2px;
            padding: 2px 6px;
            border-radius: 4px;
            display: none;
        }

        .field-error.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .field-error.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .validation-hint {
            font-size: 11px;
            color: #6c757d;
            margin-top: 2px;
            display: block;
        }
    </style>
</head>
<body>
    <a class="back-btn" href="/Admin/Dashboard">
        ← Back to Dashboard
    </a>
    
    <div class="container">
        <div class="header">
            <h1>👨‍💼 Manage Supervisors</h1>
            <p>Create, Update, and Delete System Supervisors</p>
        </div>

        <div class="content">
            <div id="message" class="message"></div>

            <!-- Supervisors Section -->
            <div id="supervisors">
                <div class="action-buttons">
                    <button class="action-btn" onclick="showForm('createSupervisorForm')">➕ Create Supervisor</button>
                    <button class="action-btn" onclick="showForm('updateSupervisorForm')">✏️ Update Supervisor</button>
                    <button class="action-btn" onclick="showForm('deleteSupervisorForm')">🗑️ Delete Supervisor</button>
                </div>

                <!-- Enhanced Create Supervisor Form -->
                <div id="createSupervisorForm" class="form-section">
                    <h3>Create New Supervisor</h3>
                    <form id="createSupervisorFormElement">
                        <!-- National ID Field -->
                        <div class="form-group">
                            <label for="supervisorNationalId" class="required">National ID (FAN)</label>
                            <input type="text" id="supervisorNationalId" name="NationalId" placeholder="Enter National ID" required />
                            <div class="field-status auto-filled" id="supervisorNationalIdStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <!-- Enhanced ID Upload Section -->
                        <div class="upload-section">
                            <div class="upload-instructions">
                                <strong>📁 Upload National ID Card Photos</strong><br>
                                Upload clear photos of front and back sides of supervisor's ID card
                            </div>

                            <div class="upload-quality-tips">
                                <h6>📝 For Best OCR Results:</h6>
                                <ul>
                                    <li>Use high-quality scanned images or photos</li>
                                    <li>Ensure good lighting without shadows or glare</li>
                                    <li>Place ID on flat surface</li>
                                    <li>Capture entire ID card clearly</li>
                                    <li>File formats: JPG, PNG, BMP (Max 5MB)</li>
                                </ul>
                            </div>
                            
                            <div class="id-preview-container">
                                <div class="id-preview" id="supervisorFrontPreviewContainer">
                                    <div><strong>Front Side</strong></div>
                                    <div id="supervisorFrontPreviewText">No file selected</div>
                                    <div id="supervisorFrontPreviewImage"></div>
                                    <input type="file" id="supervisorFrontIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('supervisorFrontIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Front Image
                                    </button>
                                </div>
                                
                                <div class="id-preview" id="supervisorBackPreviewContainer">
                                    <div><strong>Back Side</strong></div>
                                    <div id="supervisorBackPreviewText">No file selected</div>
                                    <div id="supervisorBackPreviewImage"></div>
                                    <input type="file" id="supervisorBackIdUpload" class="file-input" accept="image/*" />
                                    <button type="button" class="upload-btn" onclick="document.getElementById('supervisorBackIdUpload').click()" style="margin-top: 10px;">
                                        📷 Choose Back Image
                                    </button>
                                </div>
                            </div>

                            <div class="action-buttons-ocr">
                                <button type="button" class="upload-btn extract-btn" id="supervisorExtractInfoBtn">
                                    🔍 Extract ID Information
                                </button>
                                <button type="button" class="upload-btn demo-btn" id="supervisorAutoFillBtn">
                                    📝 Auto-fill Form
                                </button>
                            </div>

                            <div id="supervisorOcrProcessing" class="ocr-processing">
                                <!-- Processing message will be inserted here -->
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorFirstName" class="required">First Name</label>
                            <input type="text" id="supervisorFirstName" name="FirstName" placeholder="Enter first name" required />
                            <div class="field-status auto-filled" id="supervisorFirstNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorMiddleName" class="required">Middle Name</label>
                            <input type="text" id="supervisorMiddleName" name="MiddleName" placeholder="Enter middle name" required />
                            <div class="field-status auto-filled" id="supervisorMiddleNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorLastName" class="required">Last Name</label>
                            <input type="text" id="supervisorLastName" name="LastName" placeholder="Enter last name" required />
                            <div class="field-status auto-filled" id="supervisorLastNameStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorPhoneNumber" class="required">Phone Number</label>
                            <input type="tel" id="supervisorPhoneNumber" name="PhoneNumber" placeholder="Enter phone number" required />
                            <div class="field-status auto-filled" id="supervisorPhoneNumberStatus" style="display: none;">Auto-filled from ID</div>
                            <!-- ADDED VALIDATION HINT -->
                            <span class="validation-hint">Format: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)</span>
                            <div class="field-error" id="supervisorPhoneNumberError"></div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorEmail">Email Address</label>
                            <input type="email" id="supervisorEmail" name="Email" placeholder="Enter email address" />
                        </div>

                        <div class="form-group password-toggle">
                            <label for="supervisorPassword" class="required">Password</label>
                            <input type="password" id="supervisorPassword" name="Password" placeholder="Enter password" required />
                            <button type="button" class="toggle-password" onclick="togglePassword('supervisorPassword')">👁️</button>
                            <!-- ADDED VALIDATION HINT -->
                            <span class="validation-hint">Min 6 chars: at least one letter, one number, and one special character</span>
                            <div class="field-error" id="supervisorPasswordError"></div>
                        </div>

                        <div class="form-group password-toggle">
                            <label for="supervisorConfirmPassword" class="required">Confirm Password</label>
                            <input type="password" id="supervisorConfirmPassword" name="ConfirmPassword" placeholder="Confirm password" required />
                            <button type="button" class="toggle-password" onclick="togglePassword('supervisorConfirmPassword')">👁️</button>
                            <div class="field-error" id="supervisorConfirmPasswordError"></div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorNationality" class="required">Nationality</label>
                            <select id="supervisorNationality" name="Nationality" required>
                                <option value="" disabled selected>Select Nationality</option>
                                <option value="Ethiopian">Ethiopian</option>
                                <option value="Other">Other</option>
                            </select>
                            <div class="field-status auto-filled" id="supervisorNationalityStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorRegion" class="required">Region</label>
                            <select id="supervisorRegion" name="Region" required>
                                <option value="" disabled selected>Select Region</option>
                            </select>
                            <div class="field-status auto-filled" id="supervisorRegionStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorAge" class="required">Age</label>
                            <input type="number" id="supervisorAge" name="Age" min="18" max="120" placeholder="Enter age" required />
                            <div class="field-status auto-filled" id="supervisorAgeStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorSex" class="required">Sex</label>
                            <select id="supervisorSex" name="Sex" required>
                                <option value="" disabled selected>Select Sex</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <div class="field-status auto-filled" id="supervisorSexStatus" style="display: none;">Auto-filled from ID</div>
                        </div>

                        <div class="form-group">
                            <label for="supervisorIsActive">Account Status</label>
                            <select id="supervisorIsActive" name="IsActive">
                                <option value="true" selected>Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>

                        <button type="submit" class="submit-btn">Create Supervisor</button>
                    </form>
                </div>

                <!-- Update Supervisor Form -->
                <div id="updateSupervisorForm" class="form-section">
                    <h3>Update Supervisor</h3>
                    <form id="updateSupervisorFormElement">
                        <div class="form-group">
                            <label for="updateSupervisorNationalId">Select Supervisor *</label>
                            <select id="updateSupervisorNationalId" required onchange="loadSupervisorData(this.value)">
                                <option value="">Select a supervisor</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateFirstName">First Name *</label>
                            <input type="text" id="updateFirstName" name="FirstName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateMiddleName">Middle Name *</label>
                            <input type="text" id="updateMiddleName" name="MiddleName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateLastName">Last Name *</label>
                            <input type="text" id="updateLastName" name="LastName" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updatePhoneNumber">Phone Number *</label>
                            <input type="tel" id="updatePhoneNumber" name="PhoneNumber" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateEmail">Email Address *</label>
                            <input type="email" id="updateEmail" name="Email" required>
                        </div>
                        <div class="form-group">
                            <label for="updateNationality">Nationality *</label>
                            <select id="updateNationality" name="Nationality" required readonly class="readonly-field">
                                <option value="Ethiopian">Ethiopian</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateRegion">Region *</label>
                            <select id="updateRegion" name="Region" required readonly class="readonly-field">
                                <option value="">Select Region</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="updateAge">Age *</label>
                            <input type="number" id="updateAge" name="Age" min="18" max="120" required readonly class="readonly-field">
                        </div>
                        <div class="form-group">
                            <label for="updateSex">Sex *</label>
                            <select id="updateSex" name="Sex" required readonly class="readonly-field">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div class="form-group password-toggle">
                            <label for="updatePassword">New Password (leave blank to keep current)</label>
                            <input type="password" id="updatePassword" name="Password" placeholder="Enter new password">
                            <button type="button" class="toggle-password" onclick="togglePassword('updatePassword')">👁️</button>
                            <!-- ADDED VALIDATION HINT -->
                            <span class="validation-hint">Min 6 chars: at least one letter, one number, and one special character</span>
                            <div class="field-error" id="updatePasswordError"></div>
                        </div>
                        <div class="form-group password-toggle">
                            <label for="updateConfirmPassword">Confirm New Password</label>
                            <input type="password" id="updateConfirmPassword" placeholder="Confirm new password">
                            <button type="button" class="toggle-password" onclick="togglePassword('updateConfirmPassword')">👁️</button>
                            <div class="field-error" id="updateConfirmPasswordError"></div>
                        </div>
                        <button type="submit" class="submit-btn">Update Supervisor</button>
                    </form>
                </div>

                <!-- Delete Supervisor Form -->
                <div id="deleteSupervisorForm" class="form-section">
                    <h3>Delete Supervisor</h3>
                    <form id="deleteSupervisorFormElement">
                        <div class="form-group">
                            <label for="deleteSupervisorNationalId">Select Supervisor to Delete *</label>
                            <select id="deleteSupervisorNationalId" required>
                                <option value="">Select a supervisor</option>
                            </select>
                        </div>
                        <button type="submit" class="submit-btn" style="background: #DC143C;">Delete Supervisor</button>
                    </form>
                </div>

                <!-- Supervisors List -->
                <div class="supervisors-list">
                    <h3>Current Supervisors</h3>
                    <div id="supervisorsContainer">
                        <!-- Supervisors will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Processing Overlay -->
    <div class="processing-overlay" id="processingOverlay">
        <div class="processing-content">
            <h3 id="processingTitle">Processing Registration</h3>
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <p id="processingStatus">Please wait...</p>
            <div id="processingDetails"></div>
        </div>
    </div>

<script>
// Ethiopia regions data
const ethiopiaRegions = [
    "Tigray", "Afar", "Amhara", "Oromia", "Somali", "Benishangul-Gumuz", 
    "Southern Nations, Nationalities, and Peoples' Region", "Gambela", 
    "Harari", "Addis Ababa", "Dire Dawa"
