// Supervisor OCR Functions
function handleSupervisorFileUpload(event, side) {
    const file = event.target.files[0];
    if (!file) return;

    if (!validateImageFile(file)) {
        showMessage('Please select a valid image file (JPG, PNG, BMP) under 5MB', false);
        event.target.value = '';
        return;
    }

    if (side === 'front') {
        supervisorFrontImageFile = file;
    } else {
        supervisorBackImageFile = file;
    }

    const reader = new FileReader();
    reader.onload = function(e) {
        const imageData = e.target.result;
        updateSupervisorPreview(side, imageData, file.name);
    };
    reader.readAsDataURL(file);
}

function validateImageFile(file) {
    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/bmp'];
    const maxSize = 5 * 1024 * 1024;
    return allowedTypes.includes(file.type) && file.size <= maxSize;
}

function updateSupervisorPreview(side, imageData, fileName) {
    const container = document.getElementById('supervisor' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewContainer');
    const textElement = document.getElementById('supervisor' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewText');
    const imageElement = document.getElementById('supervisor' + side.charAt(0).toUpperCase() + side.slice(1) + 'PreviewImage');

    if (container && textElement && imageElement) {
        container.classList.add('active');
        textElement.textContent = fileName;
        textElement.style.color = '#28a745';
        textElement.style.fontWeight = 'bold';
        imageElement.innerHTML = `<img src="${imageData}" alt="${side} side preview" style="max-width: 100px; max-height: 80px; border-radius: 4px;">`;
    }
}

function markSupervisorFieldAsExtractedFromOCR(fieldId) {
    const field = document.getElementById('supervisor' + fieldId);
    const statusElement = document.getElementById('supervisor' + fieldId + 'Status');
    
    if (field) {
        field.classList.add('extracted-field');
        field.readOnly = true;
        
        if (statusElement) {
            statusElement.style.display = 'inline-block';
            statusElement.textContent = 'Auto-filled from ID';
            statusElement.className = 'field-status auto-filled';
        }
    }
}

function fillSupervisorFormWithIDData(data) {
    if (data.nationalId && data.nationalId.trim() !== '') {
        document.getElementById('supervisorNationalId').value = data.nationalId.trim();
        markSupervisorFieldAsExtractedFromOCR('NationalId');
    }
    if (data.firstName && data.firstName.trim() !== '') {
        document.getElementById('supervisorFirstName').value = data.firstName.trim();
        markSupervisorFieldAsExtractedFromOCR('FirstName');
    }
    if (data.middleName && data.middleName.trim() !== '') {
        document.getElementById('supervisorMiddleName').value = data.middleName.trim();
        markSupervisorFieldAsExtractedFromOCR('MiddleName');
    } else if (data.firstName && data.firstName.length > 0) {
        document.getElementById('supervisorMiddleName').value = data.firstName.charAt(0) + '.';
        markSupervisorFieldAsExtractedFromOCR('MiddleName');
    }
    if (data.lastName && data.lastName.trim() !== '') {
        document.getElementById('supervisorLastName').value = data.lastName.trim();
        markSupervisorFieldAsExtractedFromOCR('LastName');
    }
    if (data.phoneNumber && data.phoneNumber.trim() !== '') {
        document.getElementById('supervisorPhoneNumber').value = data.phoneNumber.trim();
        markSupervisorFieldAsExtractedFromOCR('PhoneNumber');
    }
    if (data.nationality && data.nationality.trim() !== '') {
        document.getElementById('supervisorNationality').value = data.nationality.trim();
        markSupervisorFieldAsExtractedFromOCR('Nationality');
    } else {
        document.getElementById('supervisorNationality').value = 'Ethiopian';
        markSupervisorFieldAsExtractedFromOCR('Nationality');
    }
    if (data.region && data.region.trim() !== '') {
        document.getElementById('supervisorRegion').value = data.region;
        markSupervisorFieldAsExtractedFromOCR('Region');
    }
    if (data.sex && data.sex.trim() !== '') {
        document.getElementById('supervisorSex').value = data.sex;
        markSupervisorFieldAsExtractedFromOCR('Sex');
    }
    if (data.age && data.age > 0) {
        document.getElementById('supervisorAge').value = data.age;
        markSupervisorFieldAsExtractedFromOCR('Age');
    } else if (data.dateOfBirth) {
        const age = calculateAgeFromDate(data.dateOfBirth);
        if (age > 0) {
            document.getElementById('supervisorAge').value = age;
            markSupervisorFieldAsExtractedFromOCR('Age');
        }
    }

    showMessage('✅ Supervisor ID information successfully extracted! Fields are now locked.', true);
}

async function extractSupervisorIDInformation() {
    if (!supervisorFrontImageFile && !supervisorBackImageFile) {
        showMessage('Please upload at least one ID image (front or back)', false);
        return;
    }

    try {
        showSupervisorOCRProcessing('🔍 Scanning Supervisor ID card...');

        const formData = new FormData();
        if (supervisorFrontImageFile) formData.append('FrontImage', supervisorFrontImageFile);
        if (supervisorBackImageFile) formData.append('BackImage', supervisorBackImageFile);

        const response = await fetch('/Home/ProcessIDPhotos', {
            method: 'POST',
            body: formData
        });

        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

        const result = await response.json();
        
        if (result.success) {
            extractedSupervisorIDData = result.data;
            showMessage(`✅ ${result.message || 'Supervisor ID information extracted successfully!'}`, true);
            fillSupervisorFormWithIDData(result.data);
        } else {
            showMessage('❌ ' + (result.error || 'Failed to extract supervisor ID information'), false);
        }
        
    } catch (error) {
        showMessage('❌ Error scanning supervisor ID: ' + error.message, false);
    } finally {
        setTimeout(() => {
            hideSupervisorOCRProcessing();
        }, 2000);
    }
}

function showSupervisorOCRProcessing(message) {
