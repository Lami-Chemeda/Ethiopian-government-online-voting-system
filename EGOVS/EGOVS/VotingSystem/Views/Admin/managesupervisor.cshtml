function calculateAgeFromDate(dateString) {
    try {
        let birthDate;
        if (dateString.includes('/')) {
            const parts = dateString.split('/');
            if (parts.length === 3) {
                const day = parseInt(parts[0]);
                const month = parseInt(parts[1]);
                const year = parseInt(parts[2]);
                const gregorianYear = year - 8;
                birthDate = new Date(gregorianYear, month - 1, day);
            }
        } else {
            birthDate = new Date(dateString);
        }
        
        if (birthDate && !isNaN(birthDate.getTime())) {
            const today = new Date();
            let age = today.getFullYear() - birthDate.getFullYear();
            const monthDiff = today.getMonth() - birthDate.getMonth();
            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }
            return age > 0 ? age : 0;
        }
    } catch (error) {
        console.error('Error calculating age:', error);
    }
    return 0;
}

// Enhanced Update Supervisor functionality with proper error handling
document.getElementById('updateSupervisorFormElement').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const nationalId = document.getElementById('updateSupervisorNationalId').value;
    const email = document.getElementById('updateEmail').value;
    const password = document.getElementById('updatePassword').value;
    const confirmPassword = document.getElementById('updateConfirmPassword').value;

    if (!nationalId) {
        showMessage('Please select a supervisor to update.', false);
        return;
    }

    if (!email) {
        showMessage('Email is required.', false);
        return;
    }

    if (password && password !== confirmPassword) {
        showMessage('Password and Confirm Password do not match.', false);
        return;
    }

    if (password && password.length < 6) {
        showMessage('Password must be at least 6 characters long.', false);
        return;
    }

    try {
        const formData = new FormData();
        formData.append('NationalId', nationalId);
        formData.append('Email', email);
        
        if (password) {
            formData.append('Password', password);
            formData.append('ConfirmPassword', confirmPassword);
        }

        console.log('Updating supervisor with data:', {
            NationalId: nationalId,
            Email: email,
            HasPassword: !!password
        });

        const response = await fetch('/Admin/UpdateSupervisor', {
            method: 'POST',
            body: formData
        });

        console.log('Update response status:', response.status);

        // Check if response is OK before parsing JSON
        if (!response.ok) {
            const errorText = await response.text();
            console.error('Update error response:', errorText);
            throw new Error(`Server error: ${response.status} ${response.statusText}`);
        }

        const result = await response.json();
        console.log('Update result:', result);
        
        if (result.success) {
            showMessage('✅ ' + result.message, true);
            // Reset password fields only
            document.getElementById('updatePassword').value = '';
            document.getElementById('updateConfirmPassword').value = '';
            await loadSupervisorsFromServer();
        } else {
            showMessage('❌ ' + result.message, false);
        }
    } catch (error) {
        console.error('Error updating supervisor:', error);
        showMessage('❌ Error updating supervisor: ' + error.message, false);
    }
});

