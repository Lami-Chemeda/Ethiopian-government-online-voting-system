    const firstName = document.getElementById('supervisorFirstName').value;
    const middleName = document.getElementById('supervisorMiddleName').value;
    const lastName = document.getElementById('supervisorLastName').value;
    const phoneNumber = document.getElementById('supervisorPhoneNumber').value;
    const email = document.getElementById('supervisorEmail').value;
    const password = document.getElementById('supervisorPassword').value;
    const confirmPassword = document.getElementById('supervisorConfirmPassword').value;
    const nationality = document.getElementById('supervisorNationality').value;
    const region = document.getElementById('supervisorRegion').value;
    const age = parseInt(document.getElementById('supervisorAge').value);
    const sex = document.getElementById('supervisorSex').value;

    // Validation
    if (!nationalId || !firstName || !middleName || !lastName || !phoneNumber || !password || !confirmPassword || !nationality || !region || !age || !sex) {
        showMessage('Please fill in all required fields.', false);
        return;
    }

    // ADDED PHONE VALIDATION
    if (!validatePhoneNumber(phoneNumber)) {
        showMessage('Invalid phone number format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)', false);
        return;
    }

    if (password !== confirmPassword) {
        showMessage('Passwords do not match.', false);
        return;
    }

    // ADDED PASSWORD VALIDATION
    if (!validatePassword(password)) {
        showMessage('Password must be at least 6 characters with at least one letter, one number, and one special character', false);
        return;
    }

    if (age < 18 || age > 120) {
        showMessage('Age must be between 18 and 120.', false);
        return;
    }

    if (sex !== 'Male' && sex !== 'Female') {
        showMessage('Sex must be Male or Female.', false);
        return;
    }

    try {
        // First check if National ID already exists in any table using the enhanced check
        console.log('Checking if National ID exists in all tables...');
        const checkResponse = await fetch(`/Admin/CheckNationalId?nationalId=${encodeURIComponent(nationalId)}`);
        if (!checkResponse.ok) {
            throw new Error(`HTTP error! status: ${checkResponse.status}`);
        }
        const checkResult = await checkResponse.json();
        
        if (checkResult.exists) {
            showMessage('❌ ' + checkResult.message, false);
            return;
        }

        // Create form data
        const formData = new FormData();
        formData.append('NationalId', nationalId);
        formData.append('FirstName', firstName);
        formData.append('MiddleName', middleName);
        formData.append('LastName', lastName);
        formData.append('PhoneNumber', phoneNumber);
        formData.append('Email', email);
        formData.append('Password', password);
        formData.append('Nationality', nationality);
        formData.append('Region', region);
        formData.append('Age', age.toString());
        formData.append('Sex', sex);

        console.log('Sending registration request to /Admin/RegisterSupervisor...');
        
        const response = await fetch('/Admin/RegisterSupervisor', {
            method: 'POST',
            body: formData
        });

        const result = await response.json();
        
        if (result.success) {
            showMessage('✅ Supervisor registered successfully!', true);
            
            // Reset form
            this.reset();
            
            // Reset extracted fields
            document.querySelectorAll('.extracted-field').forEach(field => {
                field.classList.remove('extracted-field');
                field.readOnly = false;
            });
            document.querySelectorAll('.field-status').forEach(status => {
                status.style.display = 'none';
            });
            
            // Reset file uploads
            supervisorFrontImageFile = null;
            supervisorBackImageFile = null;
            extractedSupervisorIDData = null;
            document.getElementById('supervisorFrontPreviewText').textContent = 'No file selected';
            document.getElementById('supervisorBackPreviewText').textContent = 'No file selected';
            document.getElementById('supervisorFrontPreviewImage').innerHTML = '';
            document.getElementById('supervisorBackPreviewImage').innerHTML = '';
            document.getElementById('supervisorFrontPreviewContainer').classList.remove('active');
            document.getElementById('supervisorBackPreviewContainer').classList.remove('active');
            
            // Reload supervisors list
            await loadSupervisorsFromServer();
        } else {
            showMessage('❌ ' + result.message, false);
        }
    } catch (error) {
        console.error('Error creating supervisor:', error);
        showMessage('❌ Error creating supervisor: ' + error.message, false);
    }
});

