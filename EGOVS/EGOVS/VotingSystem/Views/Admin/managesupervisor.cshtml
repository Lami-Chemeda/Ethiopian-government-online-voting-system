function setupValidationListeners() {
    // Create form validations
    const createPhone = document.getElementById('supervisorPhoneNumber');
    const createPassword = document.getElementById('supervisorPassword');
    const createConfirmPassword = document.getElementById('supervisorConfirmPassword');

    // Update form validations
    const updatePassword = document.getElementById('updatePassword');
    const updateConfirmPassword = document.getElementById('updateConfirmPassword');

    if (createPhone) {
        createPhone.addEventListener('blur', function() {
            const phone = this.value.trim();
            if (phone && !validatePhoneNumber(phone)) {
                showFieldError('supervisorPhoneNumber', 
                    'Invalid format. Use: 09XXXXXXXX (10 digits), 251XXXXXXXXX (12 digits), or +251XXXXXXXXX (13 digits)');
            } else {
                clearFieldError('supervisorPhoneNumber');
            }
        });
    }

    if (createPassword) {
        createPassword.addEventListener('input', function() {
            const password = this.value;
            if (password && !validatePassword(password)) {
                showFieldError('supervisorPassword', 
                    'Password must be at least 6 characters with at least one letter, one number, and one special character');
            } else {
                clearFieldError('supervisorPassword');
            }
        });
    }

    if (createConfirmPassword) {
        createConfirmPassword.addEventListener('input', function() {
            const password = document.getElementById('supervisorPassword').value;
            const confirmPassword = this.value;
            
            if (password && confirmPassword && password !== confirmPassword) {
                showFieldError('supervisorConfirmPassword', 'Passwords do not match');
            } else {
                clearFieldError('supervisorConfirmPassword');
            }
        });
    }

    if (updatePassword) {
        updatePassword.addEventListener('input', function() {
            const password = this.value;
            if (password && !validatePassword(password)) {
                showFieldError('updatePassword', 
                    'Password must be at least 6 characters with at least one letter, one number, and one special character');
            } else {
                clearFieldError('updatePassword');
            }
        });
    }

    if (updateConfirmPassword) {
        updateConfirmPassword.addEventListener('input', function() {
            const password = document.getElementById('updatePassword').value;
            const confirmPassword = this.value;
            
            if (password && confirmPassword && password !== confirmPassword) {
                showFieldError('updateConfirmPassword', 'Passwords do not match');
            } else {
                clearFieldError('updateConfirmPassword');
            }
        });
    }
}

